BTC:{addr:'ADRESSE_BTC_TRUST_WALLET',        name:'Bitcoin',     icon:'₿',color:'#F7931A',min:5,network:'Bitcoin'},
ETH:{addr:'ADRESSE_ETH_TRUST_WALLET',        name:'Ethereum',    icon:'Ξ',color:'#627EEA',min:5,network:'ERC20'},
BNB:{addr:'ADRESSE_BNB_TRUST_WALLET',        name:'BNB',         icon:'B',color:'#F3BA2F',min:5,network:'BEP20'},
TRX:{addr:'ADRESSE_TRX_TRUST_WALLET',        name:'TRON',        icon:'T',color:'#FF060A',min:5,network:'TRC20'},
LTC:{addr:'ADRESSE_LTC_TRUST_WALLET',        name:'Litecoin',    icon:'Ł',color:'#BFBBBB',min:5,network:'LTC'},
