var CACHE_ESPN_MS    =90*1000;
function fetchTimeout(url,opts,ms){
ms=ms||8000;
return new Promise(function(resolve,reject){
var tid=setTimeout(function(){reject(new Error('timeout'));},ms);
fetch(url,opts||{})
.then(function(r){clearTimeout(tid);resolve(r);})
.catch(function(e){clearTimeout(tid);reject(e);});
});
}
function fetchOddsAPI(lgId){
var sk=ODDS_SPORT_KEY[lgId];
if(!sk)return Promise.resolve([]);
if(_oddsCache[lgId]&&Date.now()-_oddsCache[lgId].ts<CACHE_ODDS_MS){
return Promise.resolve(_oddsCache[lgId].data);
}
var url=ODDS_BASE+'/sports/'+sk+'/odds/?apiKey='+ODDS_KEY
+'&regions=eu&markets=h2h&oddsFormat=decimal&dateFormat=iso';
return fetchTimeout(url)
.then(function(r){
if(!r.ok){console.warn('Odds API',r.status);return[];}
var rem=r.headers.get('x-requests-remaining');
var used=r.headers.get('x-requests-used');
if(rem)console.log('Odds API crédits:'+used+' utilisés,'+rem+' restants');
return r.json();
})
.then(function(data){
var parsed=(data||[]).map(function(ev){
var bms=ev.bookmakers||[];
var bm=bms.find(function(b){return b.key==='bet365';})
||bms.find(function(b){return b.key==='unibet_eu';})
||bms[0];
if(!bm)return null;
var h2h=bm.markets&&bm.markets.find(function(m){return m.key==='h2h';});
if(!h2h)return null;
var o1=h2h.outcomes.find(function(x){return x.name===ev.home_team;});
var od=h2h.outcomes.find(function(x){return x.name==='Draw';});
var o2=h2h.outcomes.find(function(x){return x.name===ev.away_team;});
if(!o1||!o2)return null;
return{
id:ev.id,home:ev.home_team,away:ev.away_team,
start:ev.commence_time,
h:o1?+o1.price.toFixed(2):null,
d:od?+od.price.toFixed(2):null,
a:o2?+o2.price.toFixed(2):null,
bm:bm.title
};
}).filter(Boolean);
_oddsCache[lgId]={ts:Date.now(),data:parsed};
return parsed;
})
.catch(function(e){console.warn('Odds API err:',e.message||e);return[];});
}
var PROXY_LIST=[
{
name:'corsproxy.io',
wrap:function(url){return 'https://corsproxy.io/?'+encodeURIComponent(url);},
parse:function(r){return r.json();}
},
{
name:'allorigins.win',
wrap:function(url){return 'https://api.allorigins.win/get?url='+encodeURIComponent(url);},
parse:function(r){return r.json().then(function(d){return JSON.parse(d.contents);});}
},
{
name:'allorigins-raw',
wrap:function(url){return 'https://api.allorigins.win/raw?url='+encodeURIComponent(url);},
parse:function(r){return r.json();}
},
{
name:'thingproxy',
wrap:function(url){return 'https://thingproxy.freeboard.io/fetch/'+url;},
parse:function(r){return r.json();}
},
{
name:'htmldriven',
wrap:function(url){return 'https://cors-proxy.htmldriven.com/?url='+encodeURIComponent(url);},
parse:function(r){return r.json();}
}
];
var _proxyOkIdx   =0;
var _proxyFails   ={};
var _proxyTestDone=false;
function testProxies(){
if(_proxyTestDone)return;
_proxyTestDone=true;
var testUrl='https://api.sofascore.com/api/v1/sport/football/events/live';
PROXY_LIST.forEach(function(proxy,idx){
var t0=Date.now();
fetchTimeout(proxy.wrap(testUrl),{headers:SOFA_HEADERS},6000)
.then(function(r){
if(!r.ok)throw new Error('HTTP '+r.status);
var ms=Date.now()-t0;
console.log('[PROXY]✅ '+proxy.name+' — '+ms+'ms');
if(idx<_proxyOkIdx)_proxyOkIdx=idx;
})
.catch(function(){
console.warn('[PROXY]❌ '+proxy.name+' — indisponible');
_proxyFails[proxy.name]=(_proxyFails[proxy.name]||0)+10;
});
});
}
function fetchWithProxy(url){
var order=[];
for(var i=0;i<PROXY_LIST.length;i++){
order.push((_proxyOkIdx+i)% PROXY_LIST.length);
}
function tryNext(remaining){
if(!remaining.length){
return Promise.reject(new Error('Tous les proxies ont échoué pour:'+url));
}
var idx   =remaining[0];
var rest  =remaining.slice(1);
var proxy =PROXY_LIST[idx];
return fetchTimeout(proxy.wrap(url),{headers:SOFA_HEADERS},8000)
.then(function(r){
if(!r.ok)throw new Error('HTTP '+r.status);
return proxy.parse(r).then(function(data){
_proxyOkIdx=idx;
_proxyFails[proxy.name]=0;
return data;
});
})
.catch(function(e){
_proxyFails[proxy.name]=(_proxyFails[proxy.name]||0)+1;
console.warn('[PROXY]'+proxy.name+' fail('+_proxyFails[proxy.name]+'x):',e.message||e);
if(_proxyFails[proxy.name]>=3&&idx===_proxyOkIdx){
_proxyOkIdx=(idx+1)% PROXY_LIST.length;
}
return tryNext(rest);
});
}
return tryNext(order);
}
