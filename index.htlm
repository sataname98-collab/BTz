if(!AUTH.user){box.innerHTML='';return;}
var vPct=100;
var isVirt=S.activeAcc==='virt';
box.innerHTML=
(isVirt?
'<div style="display:flex;flex-direction:column;align-items:flex-end">'
+'<div style="display:flex;align-items:center;gap:4px;background:var(--acc2);border:1px solid rgba(0,230,118,.2);border-radius:14px;padding:4px 10px 4px 8px">'
+'<i class="fas fa-coins" style="color:var(--gold);font-size:11px"></i>'
+'<span style="font-weight:700;font-size:13px;color:var(--acc);font-variant-numeric:tabular-nums">$'+fo(S.virtBal)+'</span>'
+'<span style="font-size:9px;color:var(--text3);font-weight:600">VIRTUEL</span></div>'
+'<div style="width:100%;height:3px;background:var(--bg4);border-radius:2px;margin-top:2px;overflow:hidden"><div style="height:100%;width:'+vPct+'%;background:linear-gradient(90deg,var(--acc),var(--gold));border-radius:2px;transition:width .4s"></div></div>'
+'</div>'
:
'<div style="display:flex;align-items:center;gap:4px;background:rgba(41,121,255,.12);border:1px solid rgba(41,121,255,.25);border-radius:14px;padding:4px 10px 4px 8px">'
+'<i class="fas fa-dollar-sign" style="color:var(--blue);font-size:11px"></i>'
+'<span style="font-weight:700;font-size:13px;color:var(--blue);font-variant-numeric:tabular-nums">$'+fo(S.realBal)+'</span>'
+'<span style="font-size:9px;color:var(--text3);font-weight:600">RÉEL</span></div>'
);
}
function renderAccSwitcher(){
var sw=document.getElementById('accSwitcher');if(!sw)return;
if(!AUTH.user){sw.innerHTML='';return;}
var vPct=100;
sw.innerHTML=
'<button class="acc-btn'+(S.activeAcc==='virt'?' on virt':'')+'" data-acc="virt">'
+'<i class="fas fa-gamepad"></i>Virtuel'
+'<span style="font-size:10px;font-weight:700;margin-left:2px;color:'+(S.activeAcc==='virt'?'var(--acc)':'var(--text3)')+'">$'+fo(S.virtBal)+'</span>'
+'</button>'
+'<button class="acc-btn'+(S.activeAcc==='real'?' on real':'')+'" data-acc="real">'
+'<i class="fas fa-credit-card"></i>Réel'
+'<span style="font-size:10px;font-weight:700;margin-left:2px;color:'+(S.activeAcc==='real'?'var(--blue)':'var(--text3)')+'">$'+fo(S.realBal)+'</span>'
+'</button>'
+'<div style="margin-left:auto;display:flex;align-items:center;gap:3px;font-size:9px;color:var(--text3)">'
+(S.activeAcc==='virt'?'<div style="width:48px;height:4px;background:var(--bg4);border-radius:2px;overflow:hidden"><div style="height:100%;width:'+vPct+'%;background:linear-gradient(90deg,var(--acc),var(--gold));border-radius:2px"></div></div>':'')
+'</div>';
document.querySelectorAll('[data-acc]').forEach(function(b){
b.addEventListener('click',function(e){
e.stopPropagation();
var acc=b.dataset.acc;
if(acc==='virt'&&S.virtBal<=0){toast('Compte virtuel épuisé — déposez sur le compte réel','err');return;}
S.activeAcc=acc;dbSave();updBal();renderAllSlips();
});
});
}
function checkBroke(){
var bal=getActiveBal();
if(bal>0){
var existing=document.getElementById('brokeOv');
if(existing)existing.remove();
return;
}
if(S.activeAcc==='virt'){
if(S.realBal>0){
S.activeAcc='real';
updBal();
renderAllSlips();
toast('Compte virtuel épuisé → Compte Réel activé','inf');
return;
}
var old=document.getElementById('brokeOv');if(old)old.remove();
var ov=document.createElement('div');ov.id='brokeOv';ov.className='broke-ov';
ov.innerHTML=
'<div class="broke-icon">💸</div>'
+'<div class="broke-title">Compte Épuisé</div>'
+'<div class="broke-sub">'
+'Votre solde virtuel est à<strong>$0</strong>.<br>'
+'Rechargez avec un dépôt réel ou réinitialisez<br>'
+'votre compte virtuel à<strong style="color:var(--acc)">$'+VIRT_START+'</strong>pour recommencer.'
+'</div>'
+'<button class="broke-btn" id="brokeResetBtn" style="background:linear-gradient(135deg,var(--acc),#00C853);color:#000;margin-bottom:10px">'
+'<i class="fas fa-redo"></i>Réinitialiser le compte virtuel($'+VIRT_START+')'
+'</button>'
+'<button class="broke-btn" id="brokeDepBtn">'
+'<i class="fas fa-credit-card"></i>Déposer — Compte Réel'
+'</button>';
document.getElementById('app').appendChild(ov);
document.getElementById('brokeResetBtn').addEventListener('click',function(){
S.virtBal=VIRT_START;
ov.remove();
updBal();
renderAllSlips();
dbSave();
authPersist();
toast('✅ Compte virtuel réinitialisé à $'+VIRT_START,'ok');
});
document.getElementById('brokeDepBtn').addEventListener('click',function(){
ov.remove();S.activeAcc='real';openDeposit();updBal();
});
}else{
var old2=document.getElementById('brokeOv');if(old2)old2.remove();
var ov2=document.createElement('div');ov2.id='brokeOv';ov2.className='broke-ov';
ov2.innerHTML=
'<div class="broke-icon">💳</div>'
+'<div class="broke-title">Solde Réel Épuisé</div>'
+'<div class="broke-sub">Votre compte réel est à $0.<br>Déposez pour continuer à jouer.</div>'
+'<button class="broke-btn" id="brokeDepBtn2"><i class="fas fa-credit-card"></i>Déposer maintenant</button>'
+'<button class="broke-btn" style="margin-top:10px;background:rgba(0,230,118,.1);color:var(--acc);border:1px solid rgba(0,230,118,.3)" id="brokeVirtBtn">'
+'🎮 Passer au compte virtuel'
+'</button>';
document.getElementById('app').appendChild(ov2);
document.getElementById('brokeDepBtn2').addEventListener('click',function(){ov2.remove();openDeposit();});
document.getElementById('brokeVirtBtn').addEventListener('click',function(){
ov2.remove();S.activeAcc='virt';updBal();renderAllSlips();
if(S.virtBal<=0){S.virtBal=VIRT_START;dbSave();authPersist();}
toast('Compte virtuel activé','inf');
});
}
}
