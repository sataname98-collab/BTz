function parseSofaEvent(ev,lgId,sp,cfg){
if(!ev)return null;
try{
var home=ev.homeTeam&&ev.homeTeam.name?ev.homeTeam.name:'Home';
var away=ev.awayTeam&&ev.awayTeam.name?ev.awayTeam.name:'Away';
var hs=(ev.homeScore&&ev.homeScore.current !=null)?parseInt(ev.homeScore.current)||0:0;
var as2=(ev.awayScore&&ev.awayScore.current !=null)?parseInt(ev.awayScore.current)||0:0;
var gmin=(ev.time&&ev.time.current !=null)?parseInt(ev.time.current)||0:0;
var injuryTime=(ev.time&&ev.time.injuryTime1)?parseInt(ev.time.injuryTime1)||0:0;
var minStr=gmin?(gmin+(injuryTime?'+'+injuryTime:'')+"'"):'';
var sofaStatus=ev.status&&ev.status.type?ev.status.type:'';
var sofaDesc  =ev.status&&ev.status.description?ev.status.description:'';
var status='upcoming';
if(sofaStatus==='inprogress')status='live';
else if(sofaStatus==='finished')status='fin';
else if(sofaDesc==='Halftime'){status='live';minStr='MT';gmin=45;}
else if(sofaDesc==='Postponed'||sofaDesc==='Canceled')return null;
var startStr='--:--';
if(ev.startTimestamp){
try{startStr=new Date(ev.startTimestamp*1000).toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});}catch(e){}
}
var sofaId=ev.id;
var hl=ev.homeTeam&&ev.homeTeam.id
?'https://api.sofascore.app/api/v1/team/'+ev.homeTeam.id+'/image'
:null;
var al=ev.awayTeam&&ev.awayTeam.id
?'https://api.sofascore.app/api/v1/team/'+ev.awayTeam.id+'/image'
:null;
var lgName=ev.tournament&&ev.tournament.name?ev.tournament.name
:(SOFA_TOURNAMENT[lgId]?SOFA_TOURNAMENT[lgId].name:(lgId||'?'));
var hcorn=0,acorn=0,hshots=0,ashots=0;
if(ev.statistics){
var stHome=ev.statistics.home||{};
var stAway=ev.statistics.away||{};
hcorn =parseInt(stHome.cornerKicks)||0;
acorn =parseInt(stAway.cornerKicks)||0;
hshots=parseInt(stHome.shotsOnTarget)||0;
ashots=parseInt(stAway.shotsOnTarget)||0;
}
return{
id:      'sf_'+sofaId,
sofaId:  sofaId,
lg:      lgName,
lgId:    lgId,
sport:   sp,
src:     'SofaScore',
home:    home,
away:    away,
hl:      hl,
al:      al,
hs:      hs,
as:      as2,
gmin:    gmin,
min:     status==='live'?(minStr||'LIVE'):(status==='fin'?(sofaDesc==='Halftime'?'MT':'FT'):''),
start:   status==='upcoming'?startStr:(status==='fin'?'FT':''),
status:  status,
hcorn:   hcorn,
acorn:   acorn,
hshots:  hshots,
ashots:  ashots,
hfouls:  0,
afouls:  0
};
}catch(e){
console.warn('parseSofaEvent err:',e.message,ev);
return null;
}
}
function strSim(a,b){
if(!a||!b)return 0;
a=a.toLowerCase();b=b.toLowerCase();
if(a===b)return 2;
if(a.includes(b)||b.includes(a))return 1.5;
var wa=a.split(' '),wb=b.split(' ');
return wa.filter(function(w){return wb.includes(w)&&w.length>3;}).length*0.5;
}
function injectOdds(matches,oddsArr){
matches.forEach(function(m){
if(!oddsArr||!oddsArr.length)return;
var best=null,bestScore=0;
oddsArr.forEach(function(o){
var sc =strSim(m.home,o.home)+strSim(m.away,o.away);
var sc2=strSim(m.home,o.away)+strSim(m.away,o.home);
if(Math.max(sc,sc2)>bestScore){
bestScore=Math.max(sc,sc2);
best=o;
if(sc2>sc){var tmp=best.h;best.h=best.a;best.a=tmp;}
}
});
if(best&&bestScore>0.8){
if(best.h){m.odds.h=best.h;if(best.d)m.odds.d=best.d;m.odds.a=best.a;}
m.odds._prev={h:m.odds.h,d:m.odds.d,a:m.odds.a};
m.realOdds=true;m.bm=best.bm;
}
});
}
function fetchSportWithOdds(sp,silent){
var cfg=SCFG[sp];
if(!cfg||cfg.virtual)return;
if(!silent){S.loading[sp]=true;S.errors[sp]=null;renderList();}
var sportSlug=SOFA_SPORT_SLUG[sp]||'football';
var livePromise=fetchSofaLive(sportSlug).then(function(liveEvents){
var lgIds=cfg.lgs.map(function(l){return l.id;});
var relevant=liveEvents.filter(function(ev){
if(!ev.tournament)return false;
var tid=ev.tournament.uniqueTournament&&ev.tournament.uniqueTournament.id;
return lgIds.some(function(lgId){
var t=SOFA_TOURNAMENT[lgId];
return t&&(t.id===tid||t.id===ev.tournament.id);
});
});
return relevant;
}).catch(function(){return[];});
var scheduledPromises=cfg.lgs.map(function(lg){
return Promise.all([
fetchSofaScheduled(lg.id),
fetchSofaFinished(lg.id)
]).then(function(results){
return{lg:lg,upcoming:results[0]||[],finished:results[1]||[]};
}).catch(function(){return{lg:lg,upcoming:[],finished:[]};});
});
Promise.all([livePromise,Promise.all(scheduledPromises)]).then(function(all){
var liveEvents  =all[0]||[];
var lgResults   =all[1]||[];
var allMs=[];
var srcs ={};
if(liveEvents.length){
srcs['SofaScore 🔴']=1;
liveEvents.forEach(function(ev){
var lgId=null;
cfg.lgs.forEach(function(lg){
var t=SOFA_TOURNAMENT[lg.id];
if(t&&ev.tournament){
var tid=ev.tournament.uniqueTournament&&ev.tournament.uniqueTournament.id;
if(t.id===tid||t.id===ev.tournament.id)lgId=lg.id;
}
});
if(!lgId)lgId=cfg.lgs[0]&&cfg.lgs[0].id;
var m=parseSofaEvent(ev,lgId,sp,cfg);
if(m){m.odds=calcOdds(m);allMs.push(m);}
});
}
lgResults.forEach(function(res){
var lg=res.lg;
srcs['SofaScore']=1;
var liveIds=allMs.filter(function(m){return m.lgId===lg.id;}).map(function(m){return m.sofaId;});
res.upcoming.slice(0,8).forEach(function(ev){
if(liveIds.indexOf(ev.id)>=0)return;
var m=parseSofaEvent(ev,lg.id,sp,cfg);
if(m&&m.status==='upcoming'){m.odds=calcOdds(m);allMs.push(m);}
});
res.finished.slice(0,4).forEach(function(ev){
var m=parseSofaEvent(ev,lg.id,sp,cfg);
if(m&&m.status==='fin'){m.odds=calcOdds(m);allMs.push(m);}
});
});
if(!allMs.length){
console.log('SofaScore vide → ESPN fallback');
var espnPromises=cfg.lgs.map(function(lg){return _fetchESPN(lg,sp,cfg);});
Promise.all(espnPromises).then(function(espnResults){
var espnMs=[];
espnResults.forEach(function(r){r.ms.forEach(function(m){espnMs.push(m);});});
S.cache[sp]={ms:espnMs,ts:Date.now(),src:['ESPN(fallback)']};
S.loading[sp]=false;S.errors[sp]=null;
settleBets();
if(S.sport===sp)renderList();
renderNav();
_injectOddsBackground(sp,espnMs,{'ESPN(fallback)':1});
});
return;
}
var seen={};
allMs=allMs.filter(function(m){
if(seen[m.id])return false;
seen[m.id]=1;return true;
});
allMs.sort(function(a,b){
var order={live:0,upcoming:1,fin:2};
if((order[a.status]||1)!==(order[b.status]||1))return(order[a.status]||1)-(order[b.status]||1);
return(a.start||'').localeCompare(b.start||'');
});
S.cache[sp]={ms:allMs,ts:Date.now(),src:Object.keys(srcs)};
S.loading[sp]=false;S.errors[sp]=null;
settleBets();
if(S.sport===sp)renderList();
renderNav();
buildTicker();
_injectOddsBackground(sp,allMs,srcs);
}).catch(function(e){
console.warn('fetchSportWithOdds err:',e);
S.errors[sp]='Erreur réseau';S.loading[sp]=false;
if(S.sport===sp)renderList();
var espnPromises=cfg.lgs.map(function(lg){return _fetchESPN(lg,sp,cfg);});
Promise.all(espnPromises).then(function(results){
var ms2=[];
results.forEach(function(r){r.ms.forEach(function(m){ms2.push(m);});});
S.cache[sp]={ms:ms2,ts:Date.now(),src:['ESPN']};
S.loading[sp]=false;S.errors[sp]=null;
settleBets();
if(S.sport===sp)renderList();
renderNav();
});
});
}
function _injectOddsBackground(sp,allMs,srcs){
var cfg=SCFG[sp];
if(!cfg)return;
cfg.lgs.forEach(function(lg){
var lgMs=allMs.filter(function(m){return m.lgId===lg.id;});
var upcomingCount=lgMs.filter(function(m){return m.status==='upcoming';}).length;
if(upcomingCount<1)return;
fetchOddsAPI(lg.id).then(function(odds){
if(odds.length){
var upMs=lgMs.filter(function(m){return m.status==='upcoming';});
injectOdds(upMs,odds);
S.cache[sp].src=Object.keys(srcs).concat(['The Odds API']);
}
if(S.sport===sp)renderList();
});
});
}
function _fetchESPN(lg,sp,cfg){
var ck=lg.id;
if(_espnCache[ck]&&Date.now()-_espnCache[ck].ts<CACHE_ESPN_MS){
return Promise.resolve({lg:lg,ms:_espnCache[ck].ms,src:'ESPN'});
}
var url=ESPN_BASE2+'/'+cfg.espn+'/'+lg.id+'/scoreboard';
return fetchTimeout(url)
.then(function(r){if(!r.ok)throw r.status;return r.json();})
.then(function(d){
var ms=(d.events||[]).map(function(ev){
var m=parseESPN(ev,lg,sp,cfg);
if(m)m.odds=calcOdds(m);
return m;
}).filter(Boolean);
_espnCache[ck]={ts:Date.now(),ms:ms};
return{lg:lg,ms:ms,src:'ESPN'};
})
.catch(function(){return{lg:lg,ms:[],src:'err'};});
}
var FIFA_RATIO=18,FIFA_DUR=300;
var _ft=null;
function initChampionship(lgId){
var lg=FIFA[lgId];
var teams=lg.teams.slice();
var standings={};
teams.forEach(function(t){
standings[t.id]={id:t.id,n:t.n,logo:t.logo,pts:ri(0,35),w:0,d:0,l:0,gf:ri(0,50),ga:ri(0,40),gd:0,played:ri(8,25)};
standings[t.id].gd=standings[t.id].gf-standings[t.id].ga;
var pl=standings[t.id].played,pts=standings[t.id].pts;
standings[t.id].w=Math.floor(pts/3);
standings[t.id].d=pts%3;
standings[t.id].l=Math.max(0,pl-standings[t.id].w-standings[t.id].d);
});
return standings;
}
function sortStandings(st){
return Object.values(st).sort(function(a,b){
if(b.pts!==a.pts)return b.pts-a.pts;
return b.gd-a.gd;
});
}
function genJournee(lgId){
var lg=FIFA[lgId];
var teams=shuf(lg.teams.slice());
var fixtures=[];
for(var i=0;i<teams.length-1;i+=2){
var h=teams[i],a=teams[i+1];
var hSt=S.fifaSaison.standings[lgId]&&S.fifaSaison.standings[lgId][h.id];
var aSt=S.fifaSaison.standings[lgId]&&S.fifaSaison.standings[lgId][a.id];
var hPts=hSt?hSt.pts:15,aPts=aSt?aSt.pts:15;
var diff=(hPts-aPts)/30;
fixtures.push({h:h,a:a,hPts:hPts,aPts:aPts,standingsDiff:diff});
}
return fixtures;
}
function initFifa(){
if(!S.fifaSaison){
S.fifaSaison={journee:ri(12,28),standings:{},fixtures:{}};
FIFA_LGS.forEach(function(lgId){
S.fifaSaison.standings[lgId]=initChampionship(lgId);
S.fifaSaison.fixtures[lgId]=genJournee(lgId);
});
}
if(!Object.keys(S.fmatches).length)genFifaMatchday();
syncF();
if(!_ft)_ft=setInterval(tickF,1000);
}
function genFifaMatchday(){
S.fmatches={};
FIFA_LGS.forEach(function(lgId){
var lg=FIFA[lgId];
var fixtures=S.fifaSaison.fixtures[lgId]||genJournee(lgId);
fixtures.forEach(function(fix,i){
var id='f_'+lgId+'_'+i;
var isLive=i===0;
var isFin=i===fixtures.length-1&&fixtures.length>2;
var el=isLive?ri(60,200):0;
var gmin=Math.min(90,Math.floor(el*FIFA_RATIO/60));
var st=isLive?'live':(isFin?'fin':'upcoming');
var hs=0,as=0;
if(st==='live'||st==='fin'){
hs=ri(0,4);as=ri(0,3);
if(rng()<0.2){hs=ri(3,6);as=ri(0,2);}
}
var kickoffs=['15:00','17:30','20:00','20:45','21:00'];
var ko=kickoffs[i%kickoffs.length];
var m={id:id,sport:'fifa_virtual',virtual:true,fifa:true,
lgId:lgId,lg:lg.name,flag:lg.flag,
home:fix.h.n,away:fix.a.n,hl:fix.h.logo,al:fix.a.logo,
homeId:fix.h.id,awayId:fix.a.id,
hPts:fix.hPts,aPts:fix.aPts,standingsDiff:fix.standingsDiff,
hs:hs,as:as,el:el,gmin:gmin,dur:FIFA_DUR,
min:st==='live'?gmin+"'":(st==='fin'?"90'":''),
start:st==='upcoming'?ko:(st==='fin'?'FT':''),
status:st,goals:[],hcorn:ri(0,8),acorn:ri(0,8),
hshots:ri(0,12),ashots:ri(0,10),hfouls:ri(0,15),afouls:ri(0,14)};
m.odds=calcFifaOdds(m);
S.fmatches[id]=m;
});
});
}
function calcFifaOdds(m){
var hs=m.hs||0,as=m.as||0;
var live=m.status==='live';
var gmin=m.gmin||0;
var timeLeft=Math.max(0,90-gmin);
var diff=hs-as;
var ab=Math.abs(diff);
var margin=1.06+rnd(0,0.015);
if(!live){
var sd=m.standingsDiff||0;
var noise=rnd(-0.20,0.20);
var hAdv=clamp(sd+noise+0.07,-0.45,0.55);
var bH=clamp(0.40+hAdv,0.12,0.74);
var bA=clamp(0.40-hAdv,0.12,0.74);
var bD=clamp(1-bH-bA,0.10,0.34);
var s=bH+bA+bD;bH/=s;bA/=s;bD/=s;
var h=+clamp(margin/bH,1.10,7.50).toFixed(2);
var d=+clamp(margin/bD,2.60,5.50).toFixed(2);
var a=+clamp(margin/bA,1.10,7.50).toFixed(2);
return _buildFifaReturn(m,h,d,a,margin,timeLeft,hs,as,live,gmin);
}
var tD=1-(timeLeft/90);
var tD2=tD*tD;
var h,d,a;
if(ab===0){
var sd2=m.standingsDiff||0;
var noise2=rnd(-0.10,0.10);
var hAdv2=clamp(sd2+noise2+0.05,-0.30,0.40);
var bH2=clamp(0.40+hAdv2,0.15,0.70);
var bA2=clamp(0.40-hAdv2,0.15,0.70);
var bD2=clamp(1-bH2-bA2,0.12,0.32);
var s2=bH2+bA2+bD2;bH2/=s2;bA2/=s2;bD2/=s2;
var phase1=Math.min(tD,80/90);
var phase2=Math.max(0,(tD-80/90)/(10/90));
var sideBoostP1=1+phase1*0.30;
var sideBoostP2=1+phase2*1.50;
var sideBoost=sideBoostP1*sideBoostP2;
var drawBoostP1=1+phase1*0.08;
var drawBoostP2=1-phase2*0.60;
var drawBoost=drawBoostP1*drawBoostP2;
h=+clamp((margin/bH2)*sideBoost,1.40,14.00).toFixed(2);
d=+clamp((margin/bD2)*drawBoost,1.10,5.50).toFixed(2);
a=+clamp((margin/bA2)*sideBoost,1.40,14.00).toFixed(2);
}else{
var leadFactor=ab===1?0.92:ab===2?0.96:ab===3?0.98:1.00;
var pressure=leadFactor*tD2;
var sd3=m.standingsDiff||0;
var winBase,loseBase;
if(diff>0){
winBase=clamp(1.10+(1-clamp(sd3+0.1,-0.5,0.6))*1.20,1.10,3.50);
loseBase=clamp(1.80+(clamp(sd3+0.1,-0.5,0.6)+0.5)*2.00,1.80,5.00);
}else{
winBase=clamp(1.10+(1-clamp(-sd3+0.1,-0.5,0.6))*1.40,1.10,4.00);
loseBase=clamp(1.80+(clamp(-sd3+0.1,-0.5,0.6)+0.5)*1.60,1.80,4.50);
}
var winCote=1.00+(winBase-1.00)*(1-pressure);
winCote=+clamp(winCote,1.00,winBase).toFixed(2);
var loseCote=loseBase+(120.00-loseBase)*pressure;
loseCote=+clamp(loseCote,loseBase,120.00).toFixed(2);
var drawBase=clamp(margin/0.22,2.60,5.00);
var drawCote=drawBase+(30.00-drawBase)*pressure*0.80;
drawCote=+clamp(drawCote,drawBase,35.00).toFixed(2);
if(diff>0){h=winCote;d=drawCote;a=loseCote;}
else{a=winCote;d=drawCote;h=loseCote;}
}
return _buildFifaReturn(m,h,d,a,margin,timeLeft,hs,as,live,gmin);
}
function _buildFifaReturn(m,h,d,a,margin,timeLeft,hs,as,live,gmin){
var tot=hs+as;
var avgRate=2.7/90,ou={};
[0.5,1.5,2.5,3.5].forEach(function(th){
var lam=avgRate*Math.max(0,timeLeft);
var pO=live?clamp(1-poisCDF(Math.max(0,Math.ceil(th-tot)-1),lam),0.03,0.97):(0.5+rnd(-0.18,0.18));
var k=String(th).replace('.','_');
ou['o'+k]=+clamp(margin/pO,1.05,15).toFixed(2);
ou['u'+k]=+clamp(margin/(1-pO),1.05,15).toFixed(2);
ou['lo'+k]=live&&tot>th;ou['lu'+k]=live&&tot>=th;
});
var bttsY=+(1.6+rnd(0,0.8)).toFixed(2),bttsN=+(1.8+rnd(0,0.8)).toFixed(2);
var bttsLk=live&&hs>0&&as>0,bttsNLk=bttsLk;
var htH=+(1.8+rnd(0,1.0)).toFixed(2),htX=+(2.2+rnd(0,0.9)).toFixed(2),htA=+(2.9+rnd(0,1.8)).toFixed(2);
var htLk=live&&gmin>=45;
var dc1x,dc12,dcx2;
if(live&&Math.abs(hs-as)>0){
var pH=clamp(margin/h,0.01,0.99);
var pD=clamp(margin/d,0.01,0.99);
var pA=clamp(margin/a,0.01,0.99);
var tot2=pH+pD+pA;pH/=tot2;pD/=tot2;pA/=tot2;
dc1x=+clamp(margin/(pH+pD),1.00,4.00).toFixed(2);
dc12=+clamp(margin/(pH+pA),1.00,4.00).toFixed(2);
dcx2=+clamp(margin/(pD+pA),1.00,4.00).toFixed(2);
}else{
dc1x=+clamp(margin/(0.62),1.05,2.50).toFixed(2);
dc12=+clamp(margin/(0.78),1.05,2.00).toFixed(2);
dcx2=+clamp(margin/(0.62),1.05,2.50).toFixed(2);
}
var hcpH=+(1.55+rnd(0,0.8)).toFixed(2),hcpA=+(1.75+rnd(0,0.8)).toFixed(2);
var sc={};
[[hs,as],[hs+1,as],[hs,as+1],[hs+1,as+1],[hs+2,as],[hs,as+2],[hs+2,as+1],[hs+1,as+2]].forEach(function(sv){
var d2=Math.abs(sv[0]-hs)+Math.abs(sv[1]-as);
var p=Math.pow(0.4,d2)*(0.12+rnd(0,0.07));
var k='sc_'+sv[0]+'_'+sv[1];
sc[k]=+clamp(margin/p,1.05,45).toFixed(2);sc['l_'+k]=live&&(sv[0]<hs||sv[1]<as);
});
var hGoalP=[],aGoalP=[];
[0.5,1.5,2.5].forEach(function(th){
var lH=Math.max(0,(1.4/90)*timeLeft),lA=Math.max(0,(1.2/90)*timeLeft);
var pOH=live?clamp(1-poisCDF(Math.max(0,Math.ceil(th-hs)-1),lH),0.04,0.95):(0.45+rnd(-0.15,0.15));
var pOA=live?clamp(1-poisCDF(Math.max(0,Math.ceil(th-as)-1),lA),0.04,0.95):(0.40+rnd(-0.15,0.15));
hGoalP.push({th:th,o:+clamp(margin/pOH,1.05,10).toFixed(2),u:+clamp(margin/(1-pOH),1.05,10).toFixed(2),lko:live&&hs>th,lku:live&&hs>=th});
aGoalP.push({th:th,o:+clamp(margin/pOA,1.05,10).toFixed(2),u:+clamp(margin/(1-pOA),1.05,10).toFixed(2),lko:live&&as>th,lku:live&&as>=th});
});
var sot_ou=[[3.5,0.48],[4.5,0.42],[5.5,0.35]].map(function(x){return{th:x[0],o:+clamp(margin/x[1],1.05,5).toFixed(2),u:+clamp(margin/(1-x[1]),1.05,5).toFixed(2)};});
var faul_ou=[[8.5,0.52],[10.5,0.40],[12.5,0.28]].map(function(x){return{th:x[0],o:+clamp(margin/x[1],1.05,5).toFixed(2),u:+clamp(margin/(1-x[1]),1.05,5).toFixed(2)};});
var cornOu={};
[7.5,9.5,11.5].forEach(function(th){var p=0.5+rnd(-0.18,0.18);var k=String(th).replace('.','_');cornOu['co'+k]=+clamp(margin/p,1.05,6).toFixed(2);cornOu['cu'+k]=+clamp(margin/(1-p),1.05,6).toFixed(2);cornOu['lco'+k]=false;cornOu['lcu'+k]=false;});
return{h,d,a,ou,bttsY,bttsN,bttsLk,bttsNLk,htH,htX,htA,htLk,dc1x,dc12,dcx2,sc,hcpH,hcpA,cornOu,hcorn:+(1.6+rnd(0,.7)).toFixed(2),acorn:+(1.8+rnd(0,.7)).toFixed(2),shotH:+(1.6+rnd(0,.8)).toFixed(2),shotA:+(1.8+rnd(0,.8)).toFixed(2),sot_ou,faul_ou,hGoalP,aGoalP,_prev:{h,d,a},_ts:Date.now()};
}
function syncF(){S.cache['fifa_virtual']={ms:Object.values(S.fmatches),ts:Date.now(),src:['FIFA Virtuel']};}
function tickF(){
S.tick++;var ch=false;
Object.values(S.fmatches).forEach(function(m){
if(m.status==='live'){
m.el++;
m.gmin=Math.min(90,Math.floor(m.el*FIFA_RATIO/60));
m.min=m.gmin+"'";
if(rng()<2.7/(90*FIFA_RATIO)){
var sc=rng()<0.52?'home':'away';
if(sc==='home')m.hs++;else m.as++;
m.goals.push({t:m.el,gm:m.gmin,sc:sc});
m.odds=calcFifaOdds(m);ch=true;
}else if(S.tick%3===0){m.odds=driftFifaOdds(m.odds,m);}
if(m.gmin>=45&&!m.htDone){m.htDone=true;if(m.odds)m.odds.htLk=true;ch=true;}
if(m.el>=FIFA_DUR){
m.status='fin';m.min="90'";m.gmin=90;m.start='FT';
m.odds=calcFifaOdds(m);ch=true;settleBets();
updateStandings(m);
setTimeout(function(){scheduleNextFifaMatch(m);},ri(10000,20000));
}
}
if(m.status==='upcoming'&&rng()<0.003){
m.status='live';m.el=0;m.gmin=0;m.min="0'";ch=true;
}
});
if(ch||S.tick%5===0){syncF();if(S.sport==='fifa_virtual')renderList();}
}
function driftFifaOdds(prev,m){
var nx=calcFifaOdds(m);
var f=0.35;
var diff=m.hs-m.as,ab=Math.abs(diff);
var gmin=m.gmin||0,timeLeft=Math.max(0,90-gmin);
var tD=1-(timeLeft/90),tD2=tD*tD;
var hMn,hMx,aMn,aMx,dMn,dMx;
if(!m.status||m.status!=='live'){
hMn=1.10;hMx=7.50;aMn=1.10;aMx=7.50;dMn=2.60;dMx=5.50;
}else if(ab===0){
hMn=1.50;hMx=9.00;aMn=1.50;aMx=9.00;dMn=1.20;dMx=4.50;
}else{
var leadF=ab===1?0.50:ab===2?0.70:ab===3?0.85:1.00;
var pressure=leadF*tD2;
if(diff>0){
hMn=1.00;hMx=Math.max(1.00,3.50*(1-pressure));
aMn=Math.max(1.80,1.80+(120-1.80)*pressure*0.5);aMx=120;
}else{
aMn=1.00;aMx=Math.max(1.00,3.50*(1-pressure));
hMn=Math.max(1.80,1.80+(120-1.80)*pressure*0.5);hMx=120;
}
dMn=Math.max(2.60,2.60+(35-2.60)*pressure*0.5);dMx=35;
}
function blend(a,b,mn,mx){return+clamp(a*(1-f)+b*f+rnd(-0.001,0.001),mn,mx).toFixed(2);}
return Object.assign({},nx,{
h:blend(prev.h,nx.h,hMn,hMx),
d:blend(prev.d,nx.d,dMn,dMx),
a:blend(prev.a,nx.a,aMn,aMx),
_prev:{h:prev.h,d:prev.d,a:prev.a},_ts:Date.now()
});
}
function updateStandings(m){
if(!S.fifaSaison||!S.fifaSaison.standings[m.lgId])return;
var st=S.fifaSaison.standings[m.lgId];
var hst=st[m.homeId],ast=st[m.awayId];
if(!hst||!ast)return;
hst.played++;ast.played++;hst.gf+=m.hs;hst.ga+=m.as;ast.gf+=m.as;ast.ga+=m.hs;
hst.gd=hst.gf-hst.ga;ast.gd=ast.gf-ast.ga;
if(m.hs>m.as){hst.w++;hst.pts+=3;ast.l++;}
else if(m.hs<m.as){ast.w++;ast.pts+=3;hst.l++;}
else{hst.d++;hst.pts++;ast.d++;ast.pts++;}
}
function scheduleNextFifaMatch(m){
var lg=FIFA[m.lgId];
var teams=shuf(lg.teams.slice());
var h=teams[0],a=teams[1];
var hSt=S.fifaSaison.standings[m.lgId]&&S.fifaSaison.standings[m.lgId][h.id];
var aSt=S.fifaSaison.standings[m.lgId]&&S.fifaSaison.standings[m.lgId][a.id];
var hPts=hSt?hSt.pts:15,aPts=aSt?aSt.pts:15;
m.home=h.n;m.away=a.n;m.hl=h.logo;m.al=a.logo;
m.homeId=h.id;m.awayId=a.id;
m.hPts=hPts;m.aPts=aPts;m.standingsDiff=(hPts-aPts)/30;
m.hs=0;m.as=0;m.el=0;m.gmin=0;m.goals=[];m.htDone=false;
m.hcorn=0;m.acorn=0;m.status='upcoming';m.min='';m.start='';
m.odds=calcFifaOdds(m);
syncF();if(S.sport==='fifa_virtual')renderList();
setTimeout(function(){m.status='live';m.el=0;m.gmin=0;m.min="0'";m.odds=calcFifaOdds(m);syncF();if(S.sport==='fifa_virtual')renderList();},ri(5000,12000));
}
function evalSel(sel,m){
var hs=m.hs,as=m.as,tot=hs+as;
switch(sel.t){
case '1h':return{w:hs>as,r:'Score:'+hs+'-'+as};
case '1x':return{w:hs===as,r:'Score:'+hs+'-'+as};
case '1a':return{w:as>hs,r:'Score:'+hs+'-'+as};
case 'btts_y':return{w:hs>0&&as>0,r:hs+'-'+as};
case 'btts_n':return{w:hs===0||as===0,r:hs+'-'+as};
case 'ht1':return{w:hs>as,r:'MT:'+hs+'-'+as};
case 'htX':return{w:hs===as,r:'MT:'+hs+'-'+as};
case 'ht2':return{w:as>hs,r:'MT:'+hs+'-'+as};
case 'dc1x':return{w:hs>=as,r:hs+'-'+as};
case 'dc12':return{w:hs!==as,r:hs+'-'+as};
case 'dcx2':return{w:as>=hs,r:hs+'-'+as};
case 'hcpH':return{w:(hs-1.5)>as,r:hs+'-1.5 vs '+as};
case 'hcpA':return{w:(as+1.5)>hs,r:as+'+1.5 vs '+hs};
default:
if(sel.t.startsWith('ou_o')){var th=parseFloat(sel.t.replace('ou_o',''));return{w:tot>th,r:'Total:'+tot};}
if(sel.t.startsWith('ou_u')){var th2=parseFloat(sel.t.replace('ou_u',''));return{w:tot<th2,r:'Total:'+tot};}
if(sel.t.startsWith('sc_')){var pts=sel.t.split('_');return{w:hs===parseInt(pts[1])&&as===parseInt(pts[2]),r:hs+'-'+as};}
if(sel.t.startsWith('hg_o')){var th3=parseFloat(sel.t.replace('hg_o',''));return{w:hs>th3,r:'Buts dom:'+hs};}
if(sel.t.startsWith('hg_u')){var th4=parseFloat(sel.t.replace('hg_u',''));return{w:hs<th4,r:'Buts dom:'+hs};}
if(sel.t.startsWith('ag_o')){var th5=parseFloat(sel.t.replace('ag_o',''));return{w:as>th5,r:'Buts ext:'+as};}
if(sel.t.startsWith('ag_u')){var th6=parseFloat(sel.t.replace('ag_u',''));return{w:as<th6,r:'Buts ext:'+as};}
return{w:rng()<0.5,r:'Calculé'};
}
}
function findM(id){
if(S.vmatches[id])return S.vmatches[id];
if(S.fmatches[id])return S.fmatches[id];
var ks=Object.keys(S.cache);
for(var i=0;i<ks.length;i++){var c=S.cache[ks[i]];if(c&&c.ms){var m=c.ms.find(function(x){return x.id===id;});if(m)return m;}}
return null;
}
function settleBets(){
var ch=false;
S.hist.forEach(function(b){
if(b.status!=='pending')return;
var done=true,won=true;
b.sels.forEach(function(sel){
if(sel.settled){if(!sel.won)won=false;return;}
var m=findM(sel.mid);if(!m||m.status!=='fin'){done=false;return;}
var r=evalSel(sel,m);sel.settled=true;sel.won=r.w;sel.reason=r.r;sel.score=m.hs+'-'+m.as;
if(!r.w)won=false;
});
if(done){
b.status=won?'won':'lost';ch=true;
if(won){
addBal(b.gain);
trackEvent('bet_won',{betNum:b.betNum||b.id,gain:b.gain,stake:b.stake});
}else{
trackEvent('bet_lost',{betNum:b.betNum||b.id,stake:b.stake});
}
}
});
if(ch){updBal();dbSave();renderNav();}
}
function calcCashoutValue(bet){
if(bet.status !=='pending')return 0;
if(!bet.sels||!bet.sels.length)return 0;
var totalOddsOrig=bet.sels.reduce(function(a,s){return a*s.odd;},1);
var stake=bet.stake||0;
var grossPotential=totalOddsOrig*stake;
var selScores=bet.sels.map(function(sel){
var m=findM(sel.mid);
if(!m)return{progress:0.5,timeRatio:0};
var gmin=m.gmin||m.el||0;
var dur =m.dur ||90*60;
var timeRatio=m.sport==='fifa_virtual'
?Math.min(1,gmin/90)
:Math.min(1,(typeof gmin==='number'?gmin:0)/90);
if(m.status==='fin'){
var r=evalSel(sel,m);
return{progress:r.w?1.0:0.0,timeRatio:1.0};
}
if(m.status !=='live')return{progress:0.5,timeRatio:0};
var hs=m.hs||0,as=m.as||0,diff=hs-as;
var t=sel.t;
var progress=0.5;
if(t==='1h'){
if(diff>0)      progress=0.65+Math.min(diff,3)*0.08+timeRatio*0.15;
else if(diff<0) progress=0.15-timeRatio*0.10;
else             progress=0.42-timeRatio*0.05;
}else if(t==='1a'){
if(diff<0)      progress=0.65+Math.min(-diff,3)*0.08+timeRatio*0.15;
else if(diff>0) progress=0.15-timeRatio*0.10;
else             progress=0.42-timeRatio*0.05;
}else if(t==='1x'){
if(diff===0)    progress=0.55+timeRatio*0.20;
else             progress=0.20-timeRatio*0.10;
}else if(t==='dc1x'){
progress=diff>=0?0.70+timeRatio*0.15:0.30-timeRatio*0.10;
}else if(t==='dcx2'){
progress=diff<=0?0.70+timeRatio*0.15:0.30-timeRatio*0.10;
}else if(t==='dc12'){
progress=diff!==0?0.65+timeRatio*0.12:0.35-timeRatio*0.08;
}else if(t.startsWith('ou_o')){
var thStr=t.replace('ou_o','').replace('_','.');var th=parseFloat(thStr)||2.5;
var tot=hs+as;
if(tot>th)      progress=1.0;
else{
var needed=Math.ceil(th+1)-tot;
var rateLeft=(2.7/90)*Math.max(0,90-(m.gmin||0));
progress=Math.min(0.90,0.3+rateLeft/needed*0.5);
}
}else if(t.startsWith('ou_u')){
var thStr2=t.replace('ou_u','').replace('_','.');var th2=parseFloat(thStr2)||2.5;
var tot2=hs+as;
if(tot2>=th2)   progress=0.0;
else             progress=0.50+timeRatio*0.30;
}else if(t==='btts_y'){
if(hs>0&&as>0)  progress=1.0;
else if(hs>0||as>0)progress=0.55+timeRatio*0.15;
else             progress=0.30-timeRatio*0.15;
}else if(t==='btts_n'){
if(hs>0&&as>0)  progress=0.0;
else if(hs>0||as>0)progress=0.45-timeRatio*0.25;
else             progress=0.60+timeRatio*0.20;
}else{
progress=0.50+diff*0.04;
}
progress=Math.max(0.02,Math.min(0.98,progress));
return{progress:progress,timeRatio:timeRatio};
});
var isSingle=bet.btype==='single';
var combinedProgress;
if(isSingle){
combinedProgress=selScores.reduce(function(a,s){return a+s.progress;},0)/selScores.length;
}else{
combinedProgress=selScores.reduce(function(a,s){return a*s.progress;},1);
combinedProgress=Math.pow(combinedProgress,1/selScores.length);
}
var bookmarginCut=0.92;
var jitter=0.95+Math.random()*0.10;
var cashoutVal=grossPotential*combinedProgress*bookmarginCut*jitter;
cashoutVal=Math.max(stake*0.02,Math.min(grossPotential*0.97,cashoutVal));
return Math.round(cashoutVal*100)/100;
}
function doCashout(betId){
var bet=S.hist.find(function(b){return b.id===betId||b.betNum===betId;});
if(!bet||bet.status !=='pending'){
toast('Ce pari ne peut pas être cashé','err');return;
}
var val=calcCashoutValue(bet);
if(val<=0){toast('Cashout non disponible','err');return;}
showCfm(
'💰 Cashout:$'+fo(val)+'\n(Gain potentiel:$'+fo(bet.gain)+')\nConfirmer?',
function(){
addBal(val);
bet.status  ='cashout';
bet.cashout =val;
bet.cashoutAt=new Date().toLocaleString('fr-FR');
updBal();dbSave();authPersist();
if(S.tab==='mybets')renderList();
toast('💰 Cashout de $'+fo(val)+' crédité!','ok');
trackEvent('cashout',{id:betId,val:val,stake:bet.stake});
}
);
}
function progressMatchStats(){
Object.values(S.cache).forEach(function(c){
if(!c||!c.ms)return;
c.ms.forEach(function(m){
if(m.status !=='live')return;
if(!m.stats){
m.stats={
possession_home:45+Math.floor(Math.random()*11),
possession_away:0,
shots_home:     Math.floor(Math.random()*8),
shots_away:     Math.floor(Math.random()*8),
corners_home:   m.hcorn||0,
corners_away:   m.acorn||0,
fouls_home:     Math.floor(Math.random()*8),
fouls_away:     Math.floor(Math.random()*8)
};
m.stats.possession_away=100-m.stats.possession_home;
}
var st=m.stats;
var drift=Math.floor(Math.random()*3)-1;
st.possession_home=Math.max(30,Math.min(70,st.possession_home+drift));
st.possession_away=100-st.possession_home;
if(Math.random()<0.13)st.shots_home++;
if(Math.random()<0.13)st.shots_away++;
if(Math.random()<0.11){st.corners_home++;m.hcorn=(m.hcorn||0)+1;}
if(Math.random()<0.11){st.corners_away++;m.acorn=(m.acorn||0)+1;}
if(Math.random()<0.22)st.fouls_home++;
if(Math.random()<0.22)st.fouls_away++;
});
});
}
setInterval(progressMatchStats,60000);
function renderNav(){
document.getElementById('snav').innerHTML=SIDS.map(function(id){
var cfg=SCFG[id];
var c=S.cache[id];
var lc=c?c.ms.filter(function(m){return m.status==='live';}).length:0;
var cls=cfg.virtual?(cfg.fifa?'fv':'virt'):'';
return'<button class="stab '+cls+(S.sport===id?' on':'')+'" data-sp="'+id+'">'+cfg.icon+' '+esc(cfg.name)+(lc?'<span class="scnt">'+lc+'</span>':'')+'</button>';
}).join('');
}
var TABS=[{id:'live',l:'<span class="ldot"></span>En Direct'},{id:'upcoming',l:'📅 À Venir'},{id:'fin',l:'📊 Résultats'},{id:'mybets',l:'🎯 Mes Paris'}];
function renderSub(){
var pc=S.hist.filter(function(b){return b.status==='pending';}).length;
document.getElementById('subtabs').innerHTML=TABS.map(function(t){
var lbl=t.l+(t.id==='mybets'&&pc?'<span class="bbdg">'+pc+'</span>':'');
return'<button class="sub'+(S.tab===t.id?' on':'')+'" data-tab="'+t.id+'">'+lbl+'</button>';
}).join('');
}
function renderList(){
var area=document.getElementById('mlist');
if(S.tab==='mybets'){renderMyBets(area);return;}
var cfg=SCFG[S.sport];
if(cfg&&cfg.virtual){if(cfg.fifa)renderFifaList(area);else renderVirtList(area);return;}
var c=S.cache[S.sport];
var ms=c?c.ms.filter(function(m){return m.status===(S.tab==='live'?'live':S.tab==='upcoming'?'upcoming':'fin');}):[];
var html='';
if(c){
var ago=Math.round((Date.now()-c.ts)/1000);
var at=ago<60?ago+'s':Math.round(ago/60)+'min';
var srcs=(c.src||[]).map(function(s){
var cl='espn',ico='📡';
if(s.indexOf('SofaScore')>=0){cl='real';ico='🟢';}
else if(s.indexOf('Odds API')>=0){cl='virt';ico='💹';}
else if(s.indexOf('ESPN')>=0){cl='espn';ico='📺';}
return'<span class="api-src '+cl+'">'+ico+' '+esc(s)+'</span>';
}).join(' ');
html+='<div class="src-bar">'+srcs+'<span class="src-time">'+at+' ago</span></div>';
}
if(S.loading[S.sport]&&!c){html+=skelH();area.innerHTML=html;return;}
if(!c){html+='<div class="empty"><i class="fas fa-satellite-dish"></i><p>Cliquez actualiser</p><button class="retry-btn" data-retry="'+S.sport+'"><i class="fas fa-download"></i>Charger</button></div>';area.innerHTML=html;return;}
if(!ms.length){html+='<div class="empty"><i class="fas fa-calendar-times"></i><p>Aucun match</p></div>';area.innerHTML=html;return;}
var byLg={};ms.forEach(function(m){var lgKey=m.lg&&typeof m.lg==='object'?m.lg.n:(m.lg||m.lgId||'?');if(!byLg[lgKey])byLg[lgKey]=[];byLg[lgKey].push(m);});
Object.keys(byLg).forEach(function(lg){
html+='<div style="display:flex;align-items:center;gap:6px;padding:8px 3px 5px;font-size:11px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.4px"><span>⚽ '+esc(lg)+'</span><span style="margin-left:auto;color:var(--text3);font-size:10px">'+byLg[lg].length+' matchs</span></div>';
byLg[lg].forEach(function(m){html+=mcardH(m);});
});
area.innerHTML=html;
}
function skelH(){var h='';for(var i=0;i<4;i++)h+='<div class="skc"><div class="sk" style="height:11px;width:40%;margin-bottom:7px"></div><div class="sk" style="height:16px;width:80%;margin-bottom:9px"></div><div style="display:grid;grid-template-columns:repeat(3,1fr);gap:5px"><div class="sk" style="height:36px"></div><div class="sk" style="height:36px"></div><div class="sk" style="height:36px"></div></div></div>';return h;}
function logoH(src,name,sz){sz=sz||20;if(src)return'<img class="tlogo" src="'+esc(src)+'" width="'+sz+'" height="'+sz+'" style="width:'+sz+'px;height:'+sz+'px;object-fit:contain" onerror="this.style.display=\'none\'">';return'<div class="tph" style="width:'+sz+'px;height:'+sz+'px;font-size:'+(sz>22?'10px':'8px')+'">'+esc((name||'?').substring(0,2).toUpperCase())+'</div>';}
function obH(mid,type,lbl,odd,locked,m){
var fin=m&&m.status==='fin';
if(fin)return'<div class="ob dis"><span class="ol">'+esc(lbl)+'</span><span class="ov">'+fo(odd)+'</span></div>';
var o=m&&m.odds||{};
if(!locked&&m&&m.status==='live'){
if(type==='1h') locked=o.hLk;
if(type==='1a') locked=o.aLk;
if(type==='1x') locked=o.dLk;
if(type==='dc1x')locked=o.dc1xLk;
if(type==='dc12')locked=o.dc12Lk;
if(type==='dcx2')locked=o.dcx2Lk;
}
var isFloor=odd<=1.01;
if(isFloor||locked){
return'<div class="ob lk ob-floor" title="Marché fermé — Résultat quasi-certain">'
+'<span class="ol">'+esc(lbl)+'</span>'
+'<span class="ov ob-locked-val">'+fo(odd)+'</span>'
+'<span style="position:absolute;bottom:2px;left:0;right:0;text-align:center;font-size:7px;color:var(--red);font-weight:800;letter-spacing:.3px">FERMÉ</span>'
+'</div>';
}
var sel=S.slip.some(function(b){return b.mid===mid&&b.t===type;});
var prev=m&&m.odds&&m.odds._prev;
var dir='',dc='';
if(prev){
if(type==='1h'&&odd>prev.h+0.04){dir='up';dc=' up';}
else if(type==='1h'&&odd<prev.h-0.04){dir='dn';dc=' dn';}
if(type==='1x'&&odd>prev.d+0.04){dir='up';dc=' up';}
else if(type==='1x'&&odd<prev.d-0.04){dir='dn';dc=' dn';}
if(type==='1a'&&odd>prev.a+0.04){dir='up';dc=' up';}
else if(type==='1a'&&odd<prev.a-0.04){dir='dn';dc=' dn';}
}
return'<div class="ob'+(sel?' sel':'')+dc+'" data-mid="'+esc(mid)+'" data-t="'+esc(type)+'" data-lbl="'+esc(lbl)+'" data-odd="'+odd+'">'
+(dir?'<span class="oa '+dir+'">'+(dir==='up'?'▲':'▼')+'</span>':'')
+'<span class="ol">'+esc(lbl)+'</span>'
+'<span class="ov">'+fo(odd)+'</span>'
+'</div>';
}
function mcardH(m){
var live=m.status==='live',fin=m.status==='fin';
var o=m.odds||{};
var cfg=SCFG[m.sport]||{};
var timeH=live
?'<span class="mc-time live"><span class="ldot"></span>'+esc(m.min||'LIVE')+'</span>'
:fin
?'<span class="mc-time fin">'+esc(m.min||'FT')+'</span>'
:'<span class="mc-time upcoming">'+esc(m.start||'--:--')+'</span>';
var scH=live||fin
?'<div class="sc"><span class="sc-n">'+m.hs+'</span><span class="sc-sep">-</span><span class="sc-n">'+m.as+'</span></div>'
:'<div class="sc ns">VS</div>';
var odds3=cfg.draw!==false
?'<div class="odds-row">'+obH(m.id,'1h','1',o.h,false,m)+obH(m.id,'1x','X',o.d,false,m)+obH(m.id,'1a','2',o.a,false,m)+'</div>'
:'<div class="odds-row c2">'+obH(m.id,'1h','1',o.h,false,m)+obH(m.id,'1a','2',o.a,false,m)+'</div>';
var mktBtn=!fin?'<button class="mkt-btn" data-openmkt="'+esc(m.id)+'"><i class="fas fa-chart-line"></i>Tous les marchés<span style="background:rgba(41,121,255,.2);padding:1px 6px;border-radius:6px;font-size:10px">30+</span></button>':'';
return'<div class="mc'+(live?' live':'')+'" data-mid="'+esc(m.id)+'">'
+'<div class="mc-top">'+timeH+'<span class="mc-lg">'+esc(m.lg&&typeof m.lg==='object'?m.lg.n:(m.lg||m.lgId||''))+'</span></div>'
+'<div class="mc-teams"><div class="tc">'+logoH(m.hl,m.home)+'<span class="tn">'+esc(m.home)+'</span></div>'+scH+'<div class="tc r"><span class="tn">'+esc(m.away)+'</span>'+logoH(m.al,m.away)+'</div></div>'
+odds3+mktBtn+'</div>';
}
function renderVirtList(area){
var ms=S.cache['virtual']?S.cache['virtual'].ms:[];
if(!ms.length){area.innerHTML='<div class="empty"><i class="fas fa-gamepad"></i><p>Init...</p></div>';initVirt();return;}
var flt=ms.filter(function(m){return m.status===(S.tab==='live'?'live':S.tab==='upcoming'?'upcoming':'fin');});
var html='<div style="background:linear-gradient(135deg,rgba(155,48,255,.08),rgba(41,121,255,.05));border:1px solid rgba(155,48,255,.15);border-radius:var(--r);padding:9px 12px;margin-bottom:8px;font-size:11px;color:#BB86FC;font-weight:600">🎮 Jeux Virtuels — Résultats aléatoires cryptographiques • Cotes en temps réel</div>';
if(!flt.length){html+='<div class="empty"><i class="fas fa-hourglass-half"></i><p>Aucun match ici</p></div>';area.innerHTML=html;return;}
var byT={};flt.forEach(function(m){if(!byT[m.tname])byT[m.tname]=[];byT[m.tname].push(m);});
Object.keys(byT).forEach(function(t){
html+='<div style="display:flex;align-items:center;gap:5px;padding:7px 3px 4px;font-size:11px;font-weight:600;color:var(--text2)">'+byT[t][0].icon+' '+esc(t)+'</div>';
byT[t].forEach(function(m){html+=virtCardH(m);});
});
area.innerHTML=html;
}
function virtCardH(m){
var live=m.status==='live',fin=m.status==='fin';
var o=m.odds||{};
var pct=live?Math.round(m.el/m.dur*100):(fin?100:0);
var timeH=live?'<span class="mc-time live"><span class="ldot"></span>'+esc(m.min)+'</span>':fin?'<span class="mc-time fin">Terminé</span>':'<span class="mc-time upcoming">En attente</span>';
var scH=live||fin?'<div class="sc"><span class="sc-n">'+m.hs+'</span><span class="sc-sep">-</span><span class="sc-n">'+m.as+'</span></div>':'<div class="sc ns">VS</div>';
var gls=m.goals&&m.goals.length?'<div style="margin-top:4px">'+m.goals.slice(-3).map(function(g){return'<span class="gevt">⚽ '+(g.sc==='home'?m.home:m.away)+' '+fmm(g.t)+'</span>';}).join('')+'</div>':'';
var mktBtn=!fin?'<button class="mkt-btn" data-openmkt="'+esc(m.id)+'"><i class="fas fa-chart-line"></i>Marchés</button>':'';
return'<div class="vc'+(live?' live':'')+'" data-mid="'+esc(m.id)+'">'+'<div class="mc-top">'+timeH+'<span class="vbdg">VIRTUEL</span></div>'+'<div class="mc-teams"><div class="tc"><span class="tn">'+esc(m.home)+'</span></div>'+scH+'<div class="tc r"><span class="tn">'+esc(m.away)+'</span></div></div>'+'<div class="prog"><div class="progb" style="width:'+pct+'%"></div></div>'+gls+'<div class="odds-row">'+obH(m.id,'1h','1',o.h,false,m)+obH(m.id,'1x','X',o.d,false,m)+obH(m.id,'1a','2',o.a,false,m)+'</div>'+mktBtn+'</div>';
}
function renderFifaList(area){
var all=S.cache['fifa_virtual']?S.cache['fifa_virtual'].ms:[];
if(!all.length){area.innerHTML='<div class="empty"><i class="fas fa-futbol"></i><p>Init...</p></div>';initFifa();return;}
var html='';
html+='<div class="lg-pills">';
FIFA_LGS.forEach(function(lid){
var lg=FIFA[lid];
var cnt=all.filter(function(m){return m.lgId===lid&&m.status==='live';}).length;
html+='<button class="lgp'+(S.fifaLg===lid?' on':'')+'" data-fifalgid="'+lid+'">'+lg.flag+' '+esc(lg.name)+(cnt?'<span class="scnt">'+cnt+'</span>':'')+'</button>';
});
html+='</div>';
html+='<div style="display:flex;gap:3px;margin-bottom:8px">'
+'<button style="flex:1;padding:6px;border-radius:var(--r2);border:1px solid var(--bdr);background:'+(S.fifaView==='classement'?'var(--bg2)':'rgba(255,87,34,.12)')+';color:'+(S.fifaView==='classement'?'var(--text3)':'#FF7043')+';font-family:var(--fb);font-size:12px;font-weight:600;cursor:pointer" data-fifaview="matchs">⚽ Matchs</button>'
+'<button style="flex:1;padding:6px;border-radius:var(--r2);border:1px solid var(--bdr);background:'+(S.fifaView==='classement'?'rgba(255,87,34,.12)':'var(--bg2)')+';color:'+(S.fifaView==='classement'?'#FF7043':'var(--text3)')+';font-family:var(--fb);font-size:12px;font-weight:600;cursor:pointer" data-fifaview="classement">🏆 Classement</button>'
+'</div>';
if(S.fifaView==='classement'){
html+=renderFifaStandings(S.fifaLg);
}else{
var jn=S.fifaSaison?S.fifaSaison.journee:1;
html+='<div style="background:linear-gradient(135deg,rgba(255,87,34,.1),rgba(255,179,0,.06));border:1px solid rgba(255,87,34,.15);border-radius:var(--r);padding:8px 12px;margin-bottom:8px;display:flex;align-items:center;justify-content:space-between">'
+'<span style="font-family:var(--fh);font-size:15px;letter-spacing:1px;color:#FF7043">JOURNÉE '+jn+'</span>'
+'<span style="font-size:10px;color:var(--text3)">Saison 2024-25</span></div>';
var ms=all.filter(function(m){
return m.lgId===S.fifaLg&&m.status===(S.tab==='live'?'live':S.tab==='upcoming'?'upcoming':'fin');
});
if(!ms.length){html+='<div class="empty"><i class="fas fa-futbol" style="opacity:.15"></i><p>Aucun match ici</p></div>';area.innerHTML=html;bindFifaLg();return;}
ms.forEach(function(m){html+=fifaCardH(m);});
}
area.innerHTML=html;
bindFifaLg();
document.querySelectorAll('[data-fifaview]').forEach(function(b){
b.addEventListener('click',function(e){e.stopPropagation();S.fifaView=b.dataset.fifaview;renderList();});
});
}
function renderFifaStandings(lgId){
var st=S.fifaSaison&&S.fifaSaison.standings&&S.fifaSaison.standings[lgId];
if(!st)return'<div class="empty"><p>Classement indisponible</p></div>';
var sorted=sortStandings(st);
var html='<div style="background:var(--bg2);border:1px solid var(--bdr);border-radius:var(--r);overflow:hidden">'
+'<div style="display:grid;grid-template-columns:24px 1fr 28px 28px 28px 28px 36px;gap:0;padding:6px 10px;font-size:9px;font-weight:700;color:var(--text3);text-transform:uppercase;border-bottom:1px solid var(--bdr)">'
+'<span>#</span><span>Équipe</span><span style="text-align:center">J</span><span style="text-align:center">G</span><span style="text-align:center">N</span><span style="text-align:center">P</span><span style="text-align:center;color:var(--acc)">Pts</span></div>';
sorted.forEach(function(t,i){
var pos=i+1;
var posColor=pos<=4?'var(--acc)':pos<=6?'var(--gold)':pos>sorted.length-3?'var(--red)':'var(--text3)';
var highlight=pos<=4?'rgba(0,230,118,.03)':pos>sorted.length-3?'rgba(255,23,68,.03)':'transparent';
html+='<div style="display:grid;grid-template-columns:24px 1fr 28px 28px 28px 28px 36px;gap:0;padding:7px 10px;align-items:center;border-bottom:1px solid var(--bdr);background:'+highlight+'">'
+'<span style="font-size:11px;font-weight:700;color:'+posColor+'">'+pos+'</span>'
+'<div style="display:flex;align-items:center;gap:5px;min-width:0"><img src="'+esc(t.logo||'')+'" style="width:16px;height:16px;object-fit:contain" onerror="this.style.display=\'none\'"><span style="font-size:11px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">'+esc(t.n)+'</span></div>'
+'<span style="text-align:center;font-size:11px;color:var(--text3)">'+t.played+'</span>'
+'<span style="text-align:center;font-size:11px;color:var(--acc)">'+t.w+'</span>'
+'<span style="text-align:center;font-size:11px;color:var(--text3)">'+t.d+'</span>'
+'<span style="text-align:center;font-size:11px;color:var(--red)">'+t.l+'</span>'
+'<span style="text-align:center;font-size:13px;font-weight:800;color:var(--text)">'+t.pts+'</span>'
+'</div>';
});
html+='<div style="padding:5px 10px;font-size:9px;color:var(--text3);display:flex;gap:10px">'
+'<span style="color:var(--acc)">■ Ligue des Champions</span>'
+'<span style="color:var(--gold)">■ Europa Lge</span>'
+'<span style="color:var(--red)">■ Relégation</span></div>'
+'</div>';
return html;
}
function bindFifaLg(){
document.querySelectorAll('[data-fifalgid]').forEach(function(b){
b.addEventListener('click',function(e){e.stopPropagation();S.fifaLg=b.dataset.fifalgid;renderList();});
});
}
function fifaCardH(m){
var live=m.status==='live',fin=m.status==='fin';
var o=m.odds||{};
var pct=live?Math.round(m.gmin/90*100):(fin?100:0);
var stCtx='';
if(S.fifaSaison&&S.fifaSaison.standings[m.lgId]){
var st=S.fifaSaison.standings[m.lgId];
var hSt=st[m.homeId],aSt=st[m.awayId];
if(hSt&&aSt)stCtx='<span style="font-size:9px;color:var(--text3)">'+hSt.pts+'pts vs '+aSt.pts+'pts</span>';
}
var timeH=live?'<span class="mc-time live"><span class="ldot"></span>'+esc(m.min)+'</span>':fin?'<span class="mc-time fin">90\'</span>':'<span class="mc-time upcoming">'+esc(m.start||'--:--')+'</span>';
var scH=live||fin?'<div class="sc"><span class="sc-n">'+m.hs+'</span><span class="sc-sep">-</span><span class="sc-n">'+m.as+'</span></div>':'<div class="sc ns">VS</div>';
var gls=m.goals&&m.goals.length?'<div style="margin-top:4px">'+m.goals.map(function(g){return'<span class="gevt">⚽ '+(g.sc==='home'?m.home:m.away)+' '+g.gm+"'</span>";}).join('')+'</div>':'';
var mktBtn=!fin?'<button class="mkt-btn" data-openmkt="'+esc(m.id)+'"><i class="fas fa-chart-line"></i>Marchés<span style="font-size:10px;opacity:.7">30+</span></button>':'';
var liveBtn=live?'<button class="mkt-btn" data-flpmid="'+esc(m.id)+'" style="background:rgba(239,68,68,.12);border-color:rgba(239,68,68,.3);color:#f87171;margin-left:6px"><span style="display:inline-block;width:7px;height:7px;background:#ef4444;border-radius:50%;margin-right:5px;animation:flpPulse 1.2s infinite"></span>LIVE</button>':'';
var coteBadge='';
if(live&&Math.abs(m.hs-m.as)>=2){
var leader=m.hs>m.as?m.home:m.away;var lcote=m.hs>m.as?o.h:o.a;
coteBadge='<span style="background:rgba(0,230,118,.15);color:var(--acc);font-size:9px;font-weight:700;padding:1px 5px;border-radius:5px;margin-left:4px">'+esc(leader)+' @ '+fo(lcote)+'</span>';
}
return'<div class="fc'+(live?' live':'')+'" data-mid="'+esc(m.id)+'">'
+'<div class="mc-top">'+timeH+'<span class="fbdg">'+esc(m.lg)+'</span>'+stCtx+coteBadge+'</div>'
+'<div class="mc-teams"><div class="tc">'+logoH(m.hl,m.home,24)+'<span class="tn">'+esc(m.home)+'</span></div>'+scH+'<div class="tc r"><span class="tn">'+esc(m.away)+'</span>'+logoH(m.al,m.away,24)+'</div></div>'
+(live?'<div class="prog"><div class="progb" style="width:'+pct+'%"></div></div>':'')
+gls
+'<div class="odds-row">'+obH(m.id,'1h','1',o.h,false,m)+obH(m.id,'1x','X',o.d,false,m)+obH(m.id,'1a','2',o.a,false,m)+'</div>'
+'<div style="display:flex;gap:6px;margin-top:6px">'+mktBtn+liveBtn+'</div>'
+'</div>';
}
function renderMyBets(area){
if(!S.hist.length){area.innerHTML='<div class="empty"><i class="fas fa-ticket-alt"></i><p>Aucun pari</p></div>';return;}
var pend =S.hist.filter(function(b){return b.status==='pending';});
var done =S.hist.filter(function(b){return b.status!=='pending';});
var html ='';
if(pend.length){
html+='<div style="font-size:12px;font-weight:600;color:var(--text2);margin-bottom:7px;display:flex;align-items:center;gap:5px">'
+'<i class="fas fa-clock" style="color:var(--gold)"></i>En cours('+pend.length+')'
+'</div>';
pend.forEach(function(b){html+=betCardH(b);});
}
if(done.length){
html+='<div style="font-size:12px;font-weight:600;color:var(--text2);margin:10px 0 7px;display:flex;align-items:center;gap:5px">'
+'<i class="fas fa-flag-checkered" style="color:var(--text3)"></i>Terminés('+done.length+')'
+'</div>';
done.forEach(function(b){html+=betCardH(b);});
}
area.innerHTML=html;
}
function betCardH(b){
var isCashout=b.status==='cashout';
var wcls=b.status==='won'?'w':b.status==='lost'?'l':isCashout?'co':'p';
var stxt=b.status==='pending'?'⏳ En attente'
:b.status==='won'    ?'✅ Gagné'
:isCashout           ?'💰 Cashout'
:                       '❌ Perdu';
var numH=b.betNum?'<div class="bet-num-tag"><i class="fas fa-receipt"></i>'+b.betNum+'</div>':'';
var accH=b.acc
?'<span style="font-size:9px;padding:1px 5px;border-radius:5px;margin-left:4px;background:'
+(b.acc==='real'?'rgba(41,121,255,.15)':'rgba(0,230,118,.1)')
+';color:'+(b.acc==='real'?'var(--blue)':'var(--acc)')+';">'
+(b.acc==='real'?'💳 Réel':'🎮 Virtuel')+'</span>'
:'';
var sels=b.sels.map(function(sel){
var m  =findM(sel.mid);
var mst=m?m.status:'?';
var msc=m?(m.hs+'-'+m.as):'?';
var info=mst==='live'?'🔴 '+esc(sel.ml)+'('+msc+')'
:mst==='fin' ?esc(sel.ml)+' • '+(sel.score||msc)
:               esc(sel.ml);
var res=sel.settled
?'<div class="bsel-r '+(sel.won?'ok':'no')+'">'+(sel.won?'✅':'❌')+' '+esc(sel.reason||'')+'</div>'
:'';
var statsH='';
if(m&&m.status==='live'&&m.stats){
var st=m.stats;
statsH='<div class="mstats">'
+'<div class="mstat-row">'
+'<span>'+st.possession_home+'%</span>'
+'<span class="mstat-lbl">Possession</span>'
+'<span>'+st.possession_away+'%</span>'
+'</div>'
+'<div class="mstat-row">'
+'<span>'+st.shots_home+'</span>'
+'<span class="mstat-lbl">Tirs</span>'
+'<span>'+st.shots_away+'</span>'
+'</div>'
+'<div class="mstat-row">'
+'<span>'+st.corners_home+'</span>'
+'<span class="mstat-lbl">Corners</span>'
+'<span>'+st.corners_away+'</span>'
+'</div>'
+'<div class="mstat-row">'
+'<span>'+st.fouls_home+'</span>'
+'<span class="mstat-lbl">Fautes</span>'
+'<span>'+st.fouls_away+'</span>'
+'</div>'
+'</div>';
}
return '<div class="bsel"><div class="bsel-m">'+info+'</div>'
+'<div class="bsel-p"><span>'+esc(sel.lbl)+'</span><span style="color:var(--acc)">@ '+fo(sel.odd)+'</span></div>'
+res+statsH+'</div>';
}).join('');
var gc  =b.status==='won'   ?'pos'
:b.status==='lost'  ?'neg'
:isCashout          ?'co'
:                      'pend';
var gtxt=b.status==='won'   ?'+$'+fo(b.gain)
:b.status==='lost'  ?'-$'+fo(b.stake)
:isCashout          ?'💰 $'+fo(b.cashout)
:                      '$'+fo(b.gain)+' pot.';
var cashoutBtn='';
if(b.status==='pending'){
var coVal=calcCashoutValue(b);
var coAvail=coVal>0.01;
cashoutBtn='<div class="co-row">'
+'<div class="co-info">'
+'<span class="co-lbl">💰 Cashout disponible</span>'
+(coAvail?'<span class="co-val">$'+fo(coVal)+'</span>':'<span class="co-na">—</span>')
+'</div>'
+(coAvail
?'<button class="co-btn" data-cashout="'+esc(b.id||b.betNum)+'">Encaisser</button>'
:'<button class="co-btn" disabled style="opacity:.35">Indisponible</button>'
)
+'</div>';
}
var extraFooter=isCashout&&b.cashoutAt
?'<span style="font-size:9px;color:var(--text3)">Encaissé le '+esc(b.cashoutAt)+'</span>'
:'';
return '<div class="bet-card '+wcls+'">'
+numH
+'<div class="bc-head">'
+'<div style="display:flex;align-items:center">'
+'<span class="btag '+(b.btype==='combi'?'c':'s')+'">'+(b.btype==='combi'?'Combiné':'Simple')+'</span>'
+accH
+'</div>'
+'<span class="bstag '+wcls+'">'+stxt+'</span>'
+'</div>'
+sels
+cashoutBtn
+'<div class="bc-foot">'
+'<div>'
+'<span class="bc-stake">$'+fo(b.stake)+' • '+esc(b.date)+'</span>'
+(extraFooter?'<br>'+extraFooter:'')
+'</div>'
+'<span class="bc-gain '+gc+'">'+gtxt+'</span>'
+'</div>'
+'</div>';
}
var MKT_CATS_FOOTBALL=[
{id:'result',lbl:'🏆 Résultat'},{id:'ou',lbl:'⚽ Plus/Moins'},
{id:'btts',lbl:'🎯 BTTS'},{id:'halftime',lbl:'⏱ Mi-temps'},
{id:'dc',lbl:'🛡 Double Chance'},{id:'hcp',lbl:'⚖ Handicap'},
{id:'score',lbl:'🔢 Score Exact'},{id:'corners',lbl:'🚩 Corners'},
{id:'shots',lbl:'👟 Tirs'},{id:'fouls',lbl:'🟨 Fautes'},
{id:'hgoals',lbl:'⚽1 Buts Dom.'},{id:'agoals',lbl:'⚽2 Buts Ext.'}
];
var MKT_CATS_BASKET=[
{id:'result',lbl:'🏆 Vainqueur'},{id:'ou',lbl:'📊 Total Points'},
{id:'hcp',lbl:'⚖ Spread'},{id:'halftime',lbl:'⏱ Mi-temps'}
];
var MKT_CATS_TENNIS=[
{id:'result',lbl:'🏆 Vainqueur'},{id:'score',lbl:'🎾 Score Sets'},
{id:'ou',lbl:'📊 Total Jeux'}
];
var MKT_CATS_RUGBY=[
{id:'result',lbl:'🏆 Résultat'},{id:'ou',lbl:'📊 Total Points'},
{id:'hcp',lbl:'⚖ Spread'},{id:'halftime',lbl:'⏱ Mi-temps'}
];
var MKT_CATS=MKT_CATS_FOOTBALL;
function openMkt(mid){
var m=findM(mid);if(!m)return;
S.openMktId=mid;
var sp=m.sport||'football';
if(sp==='basketball')MKT_CATS=MKT_CATS_BASKET;
else if(sp==='tennis')MKT_CATS=MKT_CATS_TENNIS;
else if(sp==='rugby')MKT_CATS=MKT_CATS_RUGBY;
else MKT_CATS=MKT_CATS_FOOTBALL;
S.openMktCat='result';
document.getElementById('moTitle').textContent=m.home+' vs '+m.away;
renderMktBar(m);renderMktCats();renderMktBody(m);
document.getElementById('mktMo').classList.add('open');
}
function renderMktBar(m){
var live=m.status==='live',fin=m.status==='fin';
var sc=live||fin?(m.hs+'-'+m.as):'VS';
var t=live?'🔴 '+esc(m.min||'LIVE'):(fin?'✅ Terminé':'⏰ '+esc(m.start||''));
var hl=m.hl?'<img src="'+esc(m.hl)+'" style="width:26px;height:26px;object-fit:contain" onerror="this.style.display=\'none\'">':'';
var al=m.al?'<img src="'+esc(m.al)+'" style="width:26px;height:26px;object-fit:contain" onerror="this.style.display=\'none\'">':'';
document.getElementById('moBar').innerHTML='<div style="text-align:center">'+hl+'<div class="mo-team">'+esc(m.home)+'</div></div><div style="text-align:center"><div class="mo-sc">'+esc(sc)+'</div><div class="mo-time">'+t+'</div></div><div style="text-align:center">'+al+'<div class="mo-team">'+esc(m.away)+'</div></div>';
}
function renderMktCats(){
document.getElementById('moCats').innerHTML=MKT_CATS.map(function(c){
return'<button class="mcat'+(S.openMktCat===c.id?' on':'')+'" data-mcat="'+c.id+'">'+c.lbl+'</button>';
}).join('');
}
function renderMktBody(m){
var sp=m.sport||'football';
var html='';
if(sp==='basketball'){
html=renderMktBodyBasket(m,S.openMktCat);
}else if(sp==='tennis'){
html=renderMktBodyTennis(m,S.openMktCat);
}else if(sp==='rugby'){
html=renderMktBodyRugby(m,S.openMktCat);
}else{
_renderMktBodyFootball(m);
return;
}
document.getElementById('moBody').innerHTML=html||'<div class="empty" style="padding:30px"><i class="fas fa-chart-pie"></i><p>Marchés à venir</p></div>';
}
function _renderMktBodyFootball(m){
var o=m.odds||{};
var live=m.status==='live',fin=m.status==='fin';
var cat=S.openMktCat;
var html='';
if(live)html+='<div class="mkt-live-bar"><i class="fas fa-chart-line" style="animation:pulse .8s infinite"></i>Cotes en temps réel • Verrouillées si événement réalisé</div>';
function mob2(mid,t,lbl,odd,lk,reason){
if(fin)return'<div class="mob dis"><span class="mol">'+esc(lbl)+'</span><span class="mov">'+fo(odd)+'</span></div>';
if(lk)return'<div class="mob lk" title="'+esc(reason||'Verrouillé')+'"><span class="mol">'+esc(lbl)+'</span><span class="mov">'+fo(odd)+'</span></div>';
var sel=S.slip.some(function(b){return b.mid===mid&&b.t===t;});
var prev=o._prev;var dir='',dc='';
if(prev){if(t==='1h'){if(odd>prev.h+0.04){dir='up';dc=' up';}else if(odd<prev.h-0.04){dir='dn';dc=' dn';}}if(t==='1a'){if(odd>prev.a+0.04){dir='up';dc=' up';}else if(odd<prev.a-0.04){dir='dn';dc=' dn';}}}
return'<div class="mob'+(sel?' sel':'')+dc+'" data-dmid="'+esc(mid)+'" data-dt="'+esc(t)+'" data-dlbl="'+esc(lbl)+'" data-dodd="'+odd+'">'+(dir?'<span class="m-arr '+dir+'">'+(dir==='up'?'▲':'▼')+'</span>':'')+'<span class="mol">'+esc(lbl)+'</span><span class="mov">'+fo(odd)+'</span></div>';
}
function sec(title,bodyHtml,lkTag){return'<div class="mkt-sec"><div class="mkt-sec-ttl">'+esc(title)+(lkTag?'<span class="lk-tag">'+lkTag+'</span>':'')+'</div>'+bodyHtml+'</div>';}
if(cat==='result'){
var gminCur=m.gmin||0;
var diffCur=m.hs-m.as;
var liveWarning='';
if(live&&gminCur>=70&&Math.abs(diffCur)>0){
liveWarning='⚡ '+gminCur+'e min — Cotes en accélération vers 1.00';
}else if(live&&gminCur<70&&Math.abs(diffCur)>0){
liveWarning='⏳ '+gminCur+'e min — Accélération à partir de la 70e';
}
html+=sec('Résultat Final(1X2)',
'<div class="mgrid c3">'
+mob2(m.id,'1h',m.home, o.h,o.hLk,o.hLk?'Marché fermé':'')
+mob2(m.id,'1x','Nul',  o.d,o.dLk,o.dLk?'Marché fermé':'')
+mob2(m.id,'1a',m.away, o.a,o.aLk,o.aLk?'Marché fermé':'')
+'</div>',
liveWarning
);
}
if(cat==='ou'){
var ouParts='';
var ouTot=m.hs+m.as;
Object.entries(o.ou||{}).forEach(function(e){
var k=e[0];if(k.startsWith('l'))return;
var isO=k.startsWith('o'),th=k.slice(1).replace('_','.');
var lk=isO?o.ou['lo'+k.slice(1)]:o.ou['lu'+k.slice(1)];
var reason=lk?(isO?'Déjà '+ouTot+' buts(seuil '+th+')':'Seuil '+th+' atteint'):'';
ouParts+=mob2(m.id,'ou_'+k,(isO?'Plus de ':'Moins de ')+th+' buts',e[1],lk,reason);
});
var ouTotStr=live?'Score:'+m.hs+'-'+m.as+'('+(m.hs+m.as)+' buts)':'';
html+=sec('Plus/Moins de Buts(Total Match)','<div class="mgrid">'+ouParts+'</div>',ouTotStr);
}
if(cat==='btts'){
html+=sec('Les 2 Équipes Marquent','<div class="mgrid">'+mob2(m.id,'btts_y','Oui',o.bttsY,o.bttsLk,o.bttsLk?'Déjà réalisé':'')+mob2(m.id,'btts_n','Non',o.bttsN,o.bttsNLk,o.bttsNLk?'Impossible':'')+'</div>');
}
if(cat==='halftime'){
var htlk=o.htLk||(live&&(m.gmin||0)>=45);
html+=sec('Résultat Mi-Temps','<div class="mgrid c3">'+mob2(m.id,'ht1',m.home,o.htH,htlk,'MT terminée')+mob2(m.id,'htX','Nul',o.htX,htlk,'MT terminée')+mob2(m.id,'ht2',m.away,o.htA,htlk,'MT terminée')+'</div>',htlk?'🔒 Mi-temps passée':'');
html+=sec('1er But(Mi-temps)','<div class="mgrid">'+mob2(m.id,'ftg_h','Dom. marque 1er',+(1.5+rnd(0,.6)).toFixed(2),htlk,'')+mob2(m.id,'ftg_a','Ext. marque 1er',+(1.7+rnd(0,.8)).toFixed(2),htlk,'')+'</div>');
}
if(cat==='dc'){
var dcContext='';
if(live){
var diff2=m.hs-m.as;
var gmin2=m.gmin||0;
if(diff2>0)dcContext='🟢 '+esc(m.home)+' mène — DC domicile(1X)se referme';
else if(diff2<0)dcContext='🔴 '+esc(m.away)+' mène — DC extérieur(X2)se referme';
else dcContext='⚖️ Match nul — DC 1X et X2 descendent,1-2 monte';
if(gmin2>=70)dcContext+=' • ⚡ Phase critique('+gmin2+'\')';
}
html+=sec('Double Chance',
'<div class="mgrid c3">'
+mob2(m.id,'dc1x','1X — Dom ou Nul',o.dc1x,o.dc1xLk,o.dc1xLk?'Marché fermé(cote 1.00)':'')
+mob2(m.id,'dc12','1-2 — Pas de nul',o.dc12,o.dc12Lk,o.dc12Lk?'Marché fermé':'')
+mob2(m.id,'dcx2','X2 — Ext ou Nul',o.dcx2,o.dcx2Lk,o.dcx2Lk?'Marché fermé(cote 1.00)':'')
+'</div>',
dcContext
);
}
if(cat==='hcp'){
html+=sec('Handicap-1.5','<div class="mgrid">'+mob2(m.id,'hcpH',m.home+'-1.5',o.hcpH)+mob2(m.id,'hcpA',m.away+'+1.5',o.hcpA)+'</div>');
html+=sec('Handicap Asiatique-0.5','<div class="mgrid">'+mob2(m.id,'hcpH05',m.home+'-0.5',+(1.6+rnd(0,.5)).toFixed(2))+mob2(m.id,'hcpA05',m.away+'+0.5',+(1.8+rnd(0,.6)).toFixed(2))+'</div>');
}
if(cat==='score'){
var scTot=m.hs+m.as;
html+=sec('Score Exact','<div class="mgrid">'+Object.entries(o.sc||{}).filter(function(e){return!e[0].startsWith('l_');}).slice(0,8).map(function(e){var pts=e[0].split('_');var sh=parseInt(pts[1]),sa=parseInt(pts[2]);var lk=o.sc['l_'+e[0]]||(live&&(sh<m.hs||sa<m.as));return mob2(m.id,e[0],sh+'-'+sa,e[1],lk,lk?'Score '+sh+'-'+sa+' impossible':'');}).join('')+'</div>',live?'Score actuel:'+m.hs+'-'+m.as:'');
}
if(cat==='corners'){
var cTot=(m.hcorn||0)+(m.acorn||0);
var cpH='';Object.entries(o.cornOu||{}).forEach(function(e){
var k=e[0];if(k.startsWith('l'))return;
var isO=k.startsWith('co'),th=k.replace('co','').replace('cu','').replace('_','.');
var lkk=isO?o.cornOu['lco'+k.slice(2)]:o.cornOu['lcu'+k.slice(2)];
cpH+=mob2(m.id,'cn_'+k,(isO?'+':'−')+th+' corners',e[1],lkk,'');
});
html+=sec('Total Corners(Match)','<div class="mgrid">'+cpH+'</div>',live?'Corners:Dom '+m.hcorn+' — Ext '+m.acorn:'');
html+=sec('Corners Équipe 1 vs 2','<div class="mgrid">'+mob2(m.id,'corn_h',m.home+' plus de corners',o.hcorn||+(1.7+rnd(0,.6)).toFixed(2))+mob2(m.id,'corn_a',m.away+' plus de corners',o.acorn||+(1.9+rnd(0,.7)).toFixed(2))+'</div>');
html+=sec('Corners 1ère mi-temps','<div class="mgrid">'+mob2(m.id,'cn_ht_o','Plus de 4.5',+(1.7+rnd(0,.5)).toFixed(2),o.htLk,'')+mob2(m.id,'cn_ht_u','Moins de 4.5',+(1.9+rnd(0,.6)).toFixed(2),o.htLk,'')+'</div>');
}
if(cat==='shots'){
var sh='';(o.sot_ou||[]).forEach(function(s){sh+=mob2(m.id,'sh_o_'+s.th,'Plus de '+s.th+' tirs',s.o)+mob2(m.id,'sh_u_'+s.th,'Moins de '+s.th+' tirs',s.u);});
html+=sec('Total Tirs(Match)','<div class="mgrid">'+sh+'</div>');
html+=sec('Tirs Cadrés','<div class="mgrid">'+mob2(m.id,'soc_h',m.home+' plus cadrés',o.shotH||+(1.6+rnd(0,.5)).toFixed(2))+mob2(m.id,'soc_a',m.away+' plus cadrés',o.shotA||+(1.8+rnd(0,.6)).toFixed(2))+'</div>');
html+=sec('Tirs Globaux','<div class="mgrid c3">'+mob2(m.id,'sg_o12','Plus de 12.5',+(1.6+rnd(0,.4)).toFixed(2))+mob2(m.id,'sg_o15','Plus de 15.5',+(2.0+rnd(0,.6)).toFixed(2))+mob2(m.id,'sg_o18','Plus de 18.5',+(2.8+rnd(0,.8)).toFixed(2))+'</div>');
}
if(cat==='fouls'){
var fh='';(o.faul_ou||[]).forEach(function(s){fh+=mob2(m.id,'fl_o_'+s.th,'Plus de '+s.th+' fautes',s.o)+mob2(m.id,'fl_u_'+s.th,'Moins de '+s.th+' fautes',s.u);});
html+=sec('Total Fautes(Match)','<div class="mgrid">'+fh+'</div>');
html+=sec('Fautes Équipe','<div class="mgrid">'+mob2(m.id,'fl_h',m.home+' plus de fautes',+(1.7+rnd(0,.5)).toFixed(2))+mob2(m.id,'fl_a',m.away+' plus de fautes',+(1.9+rnd(0,.7)).toFixed(2))+'</div>');
html+=sec('Cartons Jaunes','<div class="mgrid">'+mob2(m.id,'yc_o_2','Plus de 2.5',+(1.7+rnd(0,.5)).toFixed(2))+mob2(m.id,'yc_u_2','Moins de 2.5',+(1.9+rnd(0,.6)).toFixed(2))+mob2(m.id,'yc_o_3','Plus de 3.5',+(2.2+rnd(0,.7)).toFixed(2))+mob2(m.id,'yc_u_3','Moins de 3.5',+(1.6+rnd(0,.5)).toFixed(2))+'</div>');
}
if(cat==='hgoals'){
var hgH='';(o.hGoalP||[]).forEach(function(s){hgH+=mob2(m.id,'hg_o'+s.th,'Plus de '+s.th,s.o,s.lko,s.lko?m.hs+' buts dom déjà':'')+mob2(m.id,'hg_u'+s.th,'Moins de '+s.th,s.u,s.lku,s.lku?'Impossible':'');});
html+=sec('Total Buts Équipe 1('+m.home+')','<div class="mgrid">'+hgH+'</div>',live?'Buts actuels:'+m.hs:'');
html+=sec('Équipe 1 Marque?','<div class="mgrid">'+mob2(m.id,'h_score_y',m.home+' marque',+(1.3+rnd(0,.5)).toFixed(2),live&&m.hs>0,'Déjà marqué')+mob2(m.id,'h_score_n',m.home+' ne marque pas',+(2.5+rnd(0,.9)).toFixed(2),live&&m.hs>0,'Impossible')+'</div>');
}
if(cat==='agoals'){
var agH='';(o.aGoalP||[]).forEach(function(s){agH+=mob2(m.id,'ag_o'+s.th,'Plus de '+s.th,s.o,s.lko,s.lko?m.as+' buts ext déjà':'')+mob2(m.id,'ag_u'+s.th,'Moins de '+s.th,s.u,s.lku,s.lku?'Impossible':'');});
html+=sec('Total Buts Équipe 2('+m.away+')','<div class="mgrid">'+agH+'</div>',live?'Buts actuels:'+m.as:'');
html+=sec('Équipe 2 Marque?','<div class="mgrid">'+mob2(m.id,'a_score_y',m.away+' marque',+(1.4+rnd(0,.5)).toFixed(2),live&&m.as>0,'Déjà marqué')+mob2(m.id,'a_score_n',m.away+' ne marque pas',+(2.3+rnd(0,.9)).toFixed(2),live&&m.as>0,'Impossible')+'</div>');
}
document.getElementById('moBody').innerHTML=html||'<div class="empty" style="padding:30px"><i class="fas fa-chart-pie"></i><p>Marchés à venir</p></div>';
}
function renderMktBodyBasket(m,cat){
var bo=calcBasketballOdds(m);
var live=m.status==='live',fin=m.status==='fin';
var html='';
if(live)html+='<div class="mkt-live-bar"><i class="fas fa-chart-line" style="animation:pulse .8s infinite"></i>Cotes live · Poisson+distribution normale</div>';
function mob3(t,lbl,odd){
var sel=S.slip.some(function(b){return b.mid===m.id&&b.t===t;});
if(fin)return'<div class="mob dis"><span class="mol">'+esc(lbl)+'</span><span class="mov">'+fo(odd)+'</span></div>';
return'<div class="mob'+(sel?' sel':'')+'" data-dmid="'+m.id+'" data-dt="'+t+'" data-dlbl="'+esc(lbl)+'" data-dodd="'+odd+'"><span class="mol">'+esc(lbl)+'</span><span class="mov">'+fo(odd)+'</span></div>';
}
function sec2(ttl,body){return'<div class="mkt-sec"><div class="mkt-sec-ttl">'+ttl+'</div>'+body+'</div>';}
if(cat==='result'){
html+=sec2('Vainqueur(Moneyline)',
'<div class="mgrid">'
+mob3('ml_h',m.home+' 🏠',bo.ML.A)
+mob3('ml_a',m.away+' ✈',bo.ML.B)
+'</div>'
+'<div style="text-align:center;font-size:10px;color:var(--text3);margin-top:4px">Dom. '+bo.ML.pA+'% · Ext. '+bo.ML.pB+'%</div>'
);
if(live){
html+=sec2('Score Actuel','<div style="text-align:center;font-size:22px;font-weight:900;color:var(--acc);padding:10px">'+m.hs+' – '+m.as+'</div>');
}
}
if(cat==='ou'){
html+=sec2('Total Points — '+bo.OU.line,
'<div class="mgrid">'
+mob3('ou_bo','Plus de '+bo.OU.line,bo.OU.O)
+mob3('ou_bu','Moins de '+bo.OU.line,bo.OU.U)
+'</div>'
);
html+=sec2('Pronostic Points','<div style="font-size:11px;color:var(--text2);padding:8px;text-align:center">Dom. ~'+bo.ptA+' pts · Ext. ~'+bo.ptB+' pts · Total ~'+(bo.ptA+bo.ptB)+' pts</div>');
}
if(cat==='hcp'){
var spH='';
Object.entries(bo.Spread||{}).forEach(function(e){
var hdp=e[0],v=e[1];
var lbl1=m.home+'('+hdp+')';
var lbl2=m.away+'('+(parseFloat(hdp)>0?'−'+hdp:'+'+Math.abs(parseFloat(hdp)))+')';
spH+=mob3('sp_h_'+hdp,lbl1,v.A)+mob3('sp_a_'+hdp,lbl2,v.B);
});
html+=sec2('Spread(Handicap)', '<div class="mgrid">'+spH+'</div>');
}
if(cat==='halftime'){
html+=sec2('Mi-temps Vainqueur','<div class="mgrid">'+mob3('ht_bh',m.home+' mène à la MT',+(1.7+rnd(0,.5)).toFixed(2))+mob3('ht_ba',m.away+' mène à la MT',+(2.0+rnd(0,.6)).toFixed(2))+'</div>');
html+=sec2('Total Points 1ère MT','<div class="mgrid">'+mob3('ht_o','Plus de '+(Math.round(bo.OU.line/2)-0.5),+(1.8+rnd(0,.3)).toFixed(2))+mob3('ht_u','Moins de '+(Math.round(bo.OU.line/2)-0.5),+(1.8+rnd(0,.3)).toFixed(2))+'</div>');
}
return html;
}
