-radius:7px}.bstag.p{background:var(--gold2);color:var(--gold);animation:glowGold 2s ease-in-out infinite}.bstag.w{background:var(--acc2);color:var(--acc)}.bstag.l{background:var(--red2);color:var(--red)}.bsel{padding:5px 0;border-bottom:1px solid var(--bdr)}.bsel:last-of-type{border-bottom:none}.bsel-m{font-size:11px;color:var(--text3);margin-bottom:1px}.bsel-p{font-size:12px;font-weight:600;display:flex;justify-content:space-between}.bsel-r{font-size:10px;margin-top:1px;font-weight:600}.bsel-r.ok{color:var(--acc)}.bsel-r.no{color:var(--red)}.bc-foot{display:flex;justify-content:space-between;align-items:center;margin-top:8px;padding-top:8px;border-top:1px solid var(--bdr)}.bc-stake{font-size:11px;color:var(--text3)}.bc-gain{font-size:13px;font-weight:700}.bc-gain.pos{color:var(--acc)}.bc-gain.neg{color:var(--red)}.bc-gain.pend{color:var(--gold)}.bc-gain.co{color:#FF9800}.bet-card.co{border-left:3px solid #FF9800}.bstag.co{background:rgba(255,152,0,.15);color:#FF9800}.co-row{display:flex;align-items:center;justify-content:space-between;background:rgba(255,152,0,.07);border:1px solid rgba(255,152,0,.2);border-radius:var(--r2);padding:7px 10px;margin:7px 0 4px;gap:8px}.co-info{display:flex;flex-direction:column;gap:1px}.co-lbl{font-size:10px;color:var(--text3);font-weight:600}.co-val{font-size:14px;font-weight:800;color:#FF9800}.co-na{font-size:12px;color:var(--text3)}.co-btn{padding:6px 14px;border:none;border-radius:var(--r2);background:linear-gradient(135deg,#FF9800,#F57C00);color:#000;font-family:var(--fb);font-size:12px;font-weight:800;cursor:pointer;transition:all .3s var(--el);white-space:nowrap}.co-btn:hover{transform:scale(1.05);box-shadow:0 4px 14px rgba(255,152,0,.4)}.co-btn:disabled{opacity:.35;cursor:not-allowed;transform:none}.mstats{background:rgba(255,255,255,.03);border-radius:var(--r2);padding:6px 8px;margin-top:5px;display:flex;flex-direction:column;gap:3px}.mstat-row{display:flex;align-items:center;font-size:10px;font-weight:600}.mstat-row span:first-child{width:28px;text-align:left;color:var(--acc)}.mstat-row span:last-child{width:28px;text-align:right;color:var(--text2)}.mstat-lbl{flex:1;text-align:center;color:var(--text3);font-weight:400;font-size:9px;text-transform:uppercase;letter-spacing:.4px}.flp-ov{position:absolute;inset:0;background:rgba(0,0,0,.7);z-index:490;opacity:0;pointer-events:none;transition:.3s;backdrop-filter:blur(4px)}.flp-ov.open{opacity:1;pointer-events:auto}.flp{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(180deg,#0a1628,#0d1f3c);border-radius:20px 20px 0 0;z-index:491;transform:translateY(100%);transition:transform .45s var(--elf);padding:0 0 24px;box-shadow:0 -12px 48px rgba(0,0,0,.7),0 0 0 1px rgba(59,130,246,.15)}.flp.open{transform:none}.flp-drag{width:40px;height:4px;background:rgba(255,255,255,.15);border-radius:2px;margin:12px auto 0}.flp-head{display:flex;align-items:center;justify-content:space-between;padding:12px 16px 8px}.flp-live-dot{width:8px;height:8px;border-radius:50%;background:#ef4444;box-shadow:0 0 0 0 rgba(239,68,68,.4);animation:flpPulse 1.2s ease-in-out infinite}@keyframes flpPulse{0%,100%{box-shadow:0 0 0 0 rgba(239,68,68,.4)}50%{box-shadow:0 0 0 6px rgba(239,68,68,0)}}.flp-title{font-family:var(--fh);font-size:14px;font-weight:700;color:#fff;letter-spacing:1px}.flp-min{font-size:12px;font-weight:700;color:#38bdf8;background:rgba(56,189,248,.12);padding:2px 8px;border-radius:8px}.flp-close{background:none;border:none;color:var(--text3);font-size:16px;cursor:pointer;padding:4px}.flp-score-wrap{display:flex;align-items:center;justify-content:space-between;padding:16px 20px 12px;gap:8px}.flp-team{display:flex;flex-direction:column;align-items:center;gap:6px;flex:1}.flp-team.r{align-items:center}.flp-logo{width:40px;height:40px;object-fit:contain}.flp-tname{font-size:12px;font-weight:700;color:#fff;text-align:center;line-height:1.2}.flp-score-box{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:14px;padding:12px 20px}.flp-sc{font-family:var(--fh);font-size:32px;font-weight:900;color:#fff;min-width:24px;text-align:center;transition:transform .2s var(--el)}.flp-sc.goal{animation:flpGoal .5s var(--el)}@keyframes flpGoal{0%{transform:scale(1)}50%{transform:scale(1.5);color:var(--acc)}100%{transform:scale(1)}}.flp-sc-sep{font-size:20px;color:var(--text3);font-weight:300}.flp-prog-wrap{padding:0 20px 10px}.flp-prog-bg{height:6px;background:rgba(255,255,255,.08);border-radius:3px;overflow:hidden}.flp-prog-fill{height:100%;background:linear-gradient(90deg,#38bdf8,#22c55e);border-radius:3px;transition:width .5s linear}.flp-events{max-height:120px;overflow-y:auto;padding:4px 16px;display:flex;flex-direction:column;gap:4px}.flp-evt{font-size:11px;padding:4px 10px;border-radius:8px;display:flex;align-items:center;gap:6px;animation:fadeUp .3s var(--els) both}.flp-evt.goal{background:rgba(34,197,94,.12);border:1px solid rgba(34,197,94,.2);color:#4ade80}.flp-evt.ko{background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.15);color:#f87171}.flp-evt.info{background:rgba(56,189,248,.08);border:1px solid rgba(56,189,248,.1);color:#7dd3fc}.flp-stake-info{margin:8px 16px 0;padding:10px 14px;background:rgba(56,189,248,.06);border:1px solid rgba(56,189,248,.12);border-radius:10px;font-size:11px;color:var(--text2);line-height:1.6}.flp-result{margin:12px 16px 0;padding:14px;border-radius:12px;text-align:center;font-size:14px;font-weight:700}.flp-result.win{background:rgba(34,197,94,.15);border:1px solid rgba(34,197,94,.3);color:#4ade80}.flp-result.loss{background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.2);color:#f87171}.flp-result.draw{background:rgba(251,191,36,.1);border:1px solid rgba(251,191,36,.2);color:#fbbf24}.sk{background:linear-gradient(90deg,var(--bg4) 0%,var(--bg3) 50%,var(--bg4) 100%);background-size:400%;animation:shimmer 2s infinite;border-radius:5px}.skc{background:linear-gradient(145deg,var(--bg2),rgba(26,35,64,.7));border:1px solid var(--bdr);border-radius:var(--r);padding:13px;margin-bottom:9px}.tc-wrap{position:absolute;top:14px;right:14px;z-index:600;display:flex;flex-direction:column;gap:7px;pointer-events:none;max-width:280px}.tst{padding:11px 16px;border-radius:var(--r2);font-size:12px;font-weight:600;animation:toastIn .5s var(--el) both;box-shadow:0 8px 30px rgba(0,0,0,.5);display:flex;align-items:center;gap:8px;border:1px solid rgba(255,255,255,.1);backdrop-filter:blur(8px)}.tst.ok{background:linear-gradient(135deg,rgba(0,200,83,.95),rgba(0,230,118,.9));color:#000;border-color:rgba(0,230,118,.3)}.tst.err{background:linear-gradient(135deg,rgba(255,23,68,.95),rgba(200,0,50,.9));color:#fff;border-color:rgba(255,23,68,.3)}.tst.inf{background:linear-gradient(135deg,rgba(41,121,255,.95),rgba(21,101,192,.9));color:#fff;border-color:rgba(41,121,255,.3)}.goal-overlay{position:fixed;inset:0;z-index:900;pointer-events:none;display:flex;align-items:center;justify-content:center}.goal-popup{background:linear-gradient(135deg,rgba(255,179,0,.95),rgba(255,87,34,.9));border-radius:16px;padding:20px 36px;text-align:center;animation:pop .5s var(--el) both;box-shadow:0 0 60px rgba(255,179,0,.4)}.goal-popup .goal-emoji{font-size:48px;display:block;animation:goalBurst 1s var(--el) infinite}.goal-popup .goal-txt{font-family:var(--fh);font-size:30px;letter-spacing:2px;color:#000;display:block}.goal-popup .goal-sub{font-size:13px;color:rgba(0,0,0,.7);display:block;margin-top:4px}.confetti-piece{position:absolute;width:8px;height:8px;border-radius:2px;animation:confetti 1.2s var(--elf) forwards}.empty{text-align:center;padding:48px 16px;color:var(--text3)}.empty i{font-size:48px;opacity:.15;display:block;margin-bottom:14px;animation:float 3s ease-in-out infinite}.retry-btn{margin-top:14px;padding:10px 28px;border:1px solid var(--acc);border-radius:var(--r);background:var(--acc4);color:var(--acc);font-family:var(--fb);font-size:12px;font-weight:600;cursor:pointer;transition:all .3s var(--el)}.retry-btn:hover{background:var(--acc2);transform:scale(1.06)}.acc-sw{display:flex;align-items:center;gap:3px;background:var(--bg2);border:1px solid var(--bdr);border-radius:22px;padding:3px;flex-shrink:0}.acc-btn{display:flex;align-items:center;gap:4px;padding:4px 10px;border-radius:18px;border:none;background:transparent;color:var(--text3);font-family:var(--fb);font-size:11px;font-weight:600;cursor:pointer;transition:all .3s var(--el);white-space:nowrap}.acc-btn:hover{background:var(--bg4);color:var(--text2);transform:scale(1.04)}.acc-btn.on.virt{background:var(--acc2);color:var(--acc);box-shadow:0 0 10px rgba(0,230,118,.1)}.acc-btn.on.real{background:var(--blue2);color:var(--blue)}.acc-btn i{font-size:10px}.bal-pill{display:flex;align-items:center;gap:5px;padding:5px 11px;border-radius:18px;flex-shrink:0;transition:all .3s}.bal-pill.virt{background:var(--acc2);border:1px solid rgba(0,230,118,.2)}.bal-pill.real{background:var(--blue2);border:1px solid rgba(41,121,255,.2)}.bal-pill i{font-size:11px}.bal-pill.virt i{color:var(--gold)}.bal-pill.real i{color:var(--blue)}.bal-amt{font-weight:700;font-size:13px;font-variant-numeric:tabular-nums;transition:all .4s}.bal-amt.bump{animation:countUp .3s var(--el)}.bal-pill.virt .bal-amt{color:var(--acc)}.bal-pill.real .bal-amt{color:var(--blue)}.bal-cur{font-size:9px;color:var(--text3);font-weight:600;margin-left:1px}.broke-ov{position:absolute;inset:0;background:rgba(0,0,0,.94);z-index:800;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:24px;text-align:center;backdrop-filter:blur(6px)}.broke-icon{font-size:64px;margin-bottom:18px;animation:float 3s ease-in-out infinite}.broke-title{font-family:var(--fh);font-size:30px;letter-spacing:2px;color:var(--red);margin-bottom:9px;text-shadow:0 0 20px rgba(255,23,68,.4)}.broke-sub{font-size:13px;color:var(--text2);line-height:1.7;margin-bottom:26px}.broke-btn{padding:14px 36px;border:none;border-radius:var(--r);background:linear-gradient(135deg,var(--blue),#1565C0);color:#fff;font-family:var(--fb);font-size:14px;font-weight:700;cursor:pointer;transition:all .3s var(--el);box-shadow:0 6px 24px rgba(41,121,255,.3)}.broke-btn:hover{transform:scale(1.07) translateY(-2px);box-shadow:0 10px 32px rgba(41,121,255,.4)}.dep-real-inp{width:100%;padding:13px 14px;border:1.5px solid rgba(41,121,255,.3);border-radius:var(--r2);background:var(--bg4);color:var(--text);font-family:var(--fb);font-size:16px;font-weight:700;outline:none;margin:8px 0;text-align:center;transition:all .3s var(--el)}.dep-real-inp:focus{border-color:var(--blue);box-shadow:0 0 0 3px var(--blue2);background:var(--bg3)}.dep-real-btn{width:100%;padding:13px;border:none;border-radius:var(--r);background:linear-gradient(135deg,var(--blue),#1565C0);color:#fff;font-family:var(--fb);font-size:14px;font-weight:700;cursor:pointer;transition:all .3s var(--el)}.dep-real-btn:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(41,121,255,.3)}.cap-bar{height:5px;background:var(--bg4);border-radius:3px;margin-top:3px;overflow:hidden}.cap-fill{height:100%;border-radius:3px;transition:width .6s var(--elf);background:linear-gradient(90deg,var(--acc),var(--gold))}.dep-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;margin:9px 0}.dep-btn{padding:13px 6px;border:1px solid var(--bdr);border-radius:var(--r2);background:linear-gradient(145deg,var(--bg2),var(--bg3));color:var(--text);font-family:var(--fb);font-size:13px;font-weight:700;cursor:pointer;text-align:center;transition:all .3s var(--el)}.dep-btn:hover{transform:scale(1.07) translateY(-2px);border-color:rgba(0,230,118,.4);color:var(--acc)}.cfm-ov{position:absolute;inset:0;background:rgba(0,0,0,.8);z-index:500;display:flex;align-items:center;justify-content:center;padding:14px;backdrop-filter:blur(4px)}.cfm-box{background:linear-gradient(145deg,var(--bg1),var(--bg2));border:1px solid var(--bdr);border-radius:16px;padding:24px;max-width:340px;width:100%;text-align:center;animation:pop .4s var(--el) both;box-shadow:0 20px 60px rgba(0,0,0,.5)}.cfm-msg{font-size:14px;line-height:1.7;margin-bottom:20px;color:var(--text2)}.cfm-acts{display:flex;gap:8px;justify-content:center}.cfm-acts button{padding:10px 26px;border-radius:var(--r2);font-family:var(--fb);font-size:13px;font-weight:700;cursor:pointer;border:none;transition:all .3s var(--el)}.cfm-no{background:var(--bg4);color:var(--text2)}.cfm-no:hover{background:var(--bg3)}.cfm-yes{background:linear-gradient(135deg,var(--acc),#00C853);color:#000}.cfm-yes:hover{transform:scale(1.06)}.src-bar{display:flex;align-items:center;justify-content:space-between;padding:5px 10px;background:linear-gradient(135deg,var(--bg2),rgba(26,35,64,.6));border:1px solid var(--bdr);border-radius:var(--r2);margin-bottom:8px;font-size:10px;flex-wrap:wrap;gap:4px}.src-time{color:var(--text3)}#authScreen{position:absolute;inset:0;z-index:999;background:var(--bg0);display:flex;flex-direction:column;overflow-y:auto;overscroll-behavior:contain}.a-hero{padding:36px 22px 20px;text-align:center;flex-shrink:0}.a-logo{font-family:var(--fh);font-size:46px;letter-spacing:5px;background:linear-gradient(135deg,var(--acc),#69F0AE,var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:popIn .6s var(--el) both}.a-tag{font-size:11px;color:var(--text3);letter-spacing:1px;text-transform:uppercase;margin-top:4px}.a-bonus{display:inline-flex;align-items:center;gap:6px;background:linear-gradient(135deg,rgba(0,230,118,.12),rgba(255,179,0,.08));border:1px solid rgba(0,230,118,.25);border-radius:22px;padding:7px 18px;margin-top:14px;font-size:12px;font-weight:700;color:var(--acc);animation:glow 3s ease-in-out infinite}.a-card{margin:0 14px 12px;background:linear-gradient(145deg,var(--bg1),var(--bg2));border:1px solid var(--bdr);border-radius:18px;padding:22px;animation:fadeUp .45s var(--els) both}.a-tabs{display:flex;gap:3px;background:var(--bg2);border-radius:10px;padding:3px;margin-bottom:20px}.a-tab{flex:1;padding:9px;border:none;border-radius:8px;background:transparent;color:var(--text3);font-family:var(--fb);font-size:13px;font-weight:600;cursor:pointer;transition:all .3s var(--el)}.a-tab:hover{color:var(--text2)}.a-tab.on{background:var(--bg4);color:var(--text);box-shadow:0 2px 8px rgba(0,0,0,.3)}.a-field{margin-bottom:13px}.a-lbl{font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:5px}.a-inp{width:100%;padding:12px 14px;border:1.5px solid var(--bdr);border-radius:var(--r2);background:var(--bg2);color:var(--text);font-family:var(--fb);font-size:14px;outline:none;transition:all .3s var(--el)}.a-inp:focus{border-color:var(--acc);box-shadow:0 0 0 3px var(--acc2);background:var(--bg3)}.a-inp.err{border-color:var(--red)!important;box-shadow:0 0 0 3px rgba(255,23,68,.1)!important}.a-err{font-size:11px;color:var(--red);margin-top:3px;display:none;animation:slideDown .25s var(--el)}.a-err.show{display:block}.a-btn{width:100%;padding:14px;border:none;border-radius:var(--r);font-family:var(--fb);font-size:14px;font-weight:700;cursor:pointer;transition:all .35s var(--el);text-transform:uppercase;letter-spacing:.5px;display:flex;align-items:center;justify-content:center;gap:8px;margin-top:4px;position:relative;overflow:hidden}.a-btn.prim{background:linear-gradient(135deg,var(--acc),#00C853);color:#000}.a-btn.prim:hover{transform:translateY(-3px);box-shadow:0 8px 28px var(--acc3)}.a-footer{text-align:center;padding:10px 20px 28px;font-size:10px;color:var(--text3);line-height:1.6}#welcomeOv{position:absolute;inset:0;z-index:1000;background:rgba(0,0,0,.9);display:none;align-items:center;justify-content:center;padding:16px;backdrop-filter:blur(6px)}.w-box{background:linear-gradient(145deg,var(--bg1),var(--bg2));border:1px solid rgba(0,230,118,.25);border-radius:22px;padding:30px 24px;width:100%;max-width:360px;text-align:center;animation:pop .6s var(--el) both;box-shadow:0 0 60px rgba(0,230,118,.08),0 20px 60px rgba(0,0,0,.6)}.w-icon{font-size:58px;display:block;margin-bottom:12px;animation:float 3s ease-in-out infinite}.w-title{font-family:var(--fh);font-size:30px;letter-spacing:2px;background:linear-gradient(135deg,var(--acc),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:5px}.w-info{background:var(--bg2);border:1px solid var(--bdr);border-radius:var(--r);padding:14px;margin:14px 0;text-align:left}.w-row{display:flex;justify-content:space-between;align-items:center;padding:4px 0;font-size:12px}.w-key{color:var(--text3)}.w-val{font-weight:700;font-family:monospace;color:var(--text);letter-spacing:.3px}.w-bonus{background:linear-gradient(135deg,rgba(0,230,118,.1),rgba(255,179,0,.07));border:1px solid rgba(0,230,118,.2);border-radius:var(--r);padding:18px;margin-bottom:18px;animation:glow 3s ease-in-out infinite}.w-amt{font-family:var(--fh);font-size:44px;background:linear-gradient(135deg,var(--acc),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:2px}.w-lbl{font-size:11px;color:var(--text2);margin-top:4px}.u-badge{display:flex;align-items:center;gap:5px;background:var(--bg2);border:1px solid var(--bdr);border-radius:18px;padding:3px 10px 3px 4px;cursor:pointer;transition:all .3s var(--el);flex-shrink:0}.u-badge:hover{background:var(--bg3);border-color:rgba(0,230,118,.2);box-shadow:0 0 12px rgba(0,230,118,.05)}.u-av{width:24px;height:24px;border-radius:50%;background:linear-gradient(135deg,var(--acc),var(--gold));display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;color:#000;flex-shrink:0;box-shadow:0 0 10px rgba(0,230,118,.25)}.u-name{font-size:11px;font-weight:600;color:var(--text);max-width:68px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.mo-prof{background:linear-gradient(180deg,var(--bg1),var(--bg0));border-radius:18px 18px 0 0;margin-top:auto;max-height:88%;overflow-y:auto}.bet-num-tag{font-size:9px;color:var(--text3);font-family:monospace;letter-spacing:.3px;margin-bottom:5px;display:flex;align-items:center;gap:3px}.odds-change-badge{position:absolute;top:-8px;right:-2px;background:var(--acc);color:#000;font-size:8px;font-weight:800;padding:1px 4px;border-radius:5px;animation:popIn .3s var(--el) both;pointer-events:none;white-space:nowrap;z-index:10}.odds-change-badge.dn{background:var(--red);color:#fff}.live-widget{display:flex;align-items:center;gap:6px;margin:6px 0 8px;padding:6px 8px;background:linear-gradient(135deg,rgba(255,23,68,.06),rgba(255,23,68,.02));border:1px solid rgba(255,23,68,.1);border-radius:var(--r2);font-size:10px;color:var(--text2)}.live-widget .lw-score{font-family:var(--fh);font-size:18px;color:var(--text);letter-spacing:2px}.live-widget .lw-min{color:var(--red);font-weight:700}.promo-bar{display:flex;align-items:center;gap:10px;padding:9px 14px;background:linear-gradient(135deg,rgba(255,179,0,.1),rgba(255,87,34,.07));border-bottom:1px solid rgba(255,179,0,.15);flex-shrink:0;cursor:pointer;position:relative;overflow:hidden}.promo-bar::before{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,179,0,.05),transparent);animation:neonSweep 3s ease-in-out infinite;background-size:200%}.promo-bar-icon{font-size:18px;flex-shrink:0;animation:pulseScale 2s ease-in-out infinite}.promo-bar-txt{font-size:11px;font-weight:700;color:var(--gold)}.promo-bar-sub{font-size:10px;color:var(--text3);margin-top:1px}.promo-bar-arrow{margin-left:auto;color:var(--gold);opacity:.7;font-size:12px;transition:transform .3s var(--el)}.promo-bar:hover .promo-bar-arrow{transform:translateX(4px)}@media(max-width:480px){.hdr{padding:7px 10px;gap:5px}.bal-amt{font-size:11px}.hbtn{width:28px;height:28px;font-size:10px}.stab{padding:5px 9px;font-size:11px}.mlist{padding:7px}}.a-inp:focus{border-color:var(--acc);box-shadow:0 0 0 3px var(--acc2);background:var(--bg3)}</style></head><body><!-- ══ LOGIN MODAL (popup quand pari sans compte) ═════════════ --><div id="loginModal" style="display:none;position:absolute;inset:0;z-index:999;background:rgba(0,0,0,.85);align-items:center;justify-content:center;padding:16px"><div style="background:var(--bg1);border:1px solid rgba(0,230,118,.2);border-radius:20px;width:100%;max-width:360px;overflow:hidden;animation:pop .4s var(--el) both"><div style="background:linear-gradient(135deg,var(--bg2),var(--bg3));padding:20px;text-align:center;border-bottom:1px solid var(--bdr)"><div style="font-family:var(--fh);font-size:28px;letter-spacing:3px;background:linear-gradient(135deg,var(--acc),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">BETZONE</div><div style="font-size:11px;color:var(--text3);margin-top:3px">Connectez-vous pour placer vos paris</div></div><div style="padding:20px"><div class="a-tabs" style="margin-bottom:16px"><button class="a-tab on" id="mTabLogin">Connexion</button><button class="a-tab" id="mTabRegister">Inscription</button></div><!-- LOGIN --><div id="mLoginForm"><div class="a-field"><div class="a-lbl">N° de compte ou email</div><input class="a-inp" id="mLoginId" placeholder="00000001 ou email" autocomplete="username"><div class="a-err" id="mLoginIdErr">Champ requis</div></div><div class="a-field"><div class="a-lbl">Mot de passe</div><input class="a-inp" id="mLoginPwd" type="password" placeholder="••••••••" autocomplete="current-password"><div class="a-err" id="mLoginPwdErr">Identifiants incorrects</div></div><button class="a-btn prim" id="mLoginBtn"><i class="fas fa-sign-in-alt"></i> Se connecter</button></div><!-- REGISTER --><div id="mRegisterForm" style="display:none"><div style="display:grid;grid-template-columns:1fr 1fr;gap:8px"><div class="a-field"><div class="a-lbl">Prénom</div><input class="a-inp" id="mRegFirst" placeholder="Prénom" autocomplete="given-name"><div class="a-err" id="mRegFirstErr">Requis</div></div><div class="a-field"><div class="a-lbl">Nom</div><input class="a-inp" id="mRegLast" placeholder="Nom" autocomplete="family-name"><div class="a-err" id="mRegLastErr">Requis</div></div></div><div class="a-field"><div class="a-lbl">Email</div><input class="a-inp" id="mRegEmail" type="email" placeholder="exemple@email.com" autocomplete="email"><div class="a-err" id="mRegEmailErr">Email invalide</div></div><div class="a-field"><div class="a-lbl">Téléphone (optionnel)</div><input class="a-inp" id="mRegPhone" type="tel" placeholder="+1 514 000 0000" autocomplete="tel"></div><div class="a-field"><div class="a-lbl">Mot de passe</div><input class="a-inp" id="mRegPwd" type="password" placeholder="Min. 6 caractères" autocomplete="new-password"><div class="a-err" id="mRegPwdErr">Minimum 6 caractères</div></div><div class="a-field"><div class="a-lbl">Confirmer mot de passe</div><input class="a-inp" id="mRegPwd2" type="password" placeholder="Répéter" autocomplete="new-password"><div class="a-err" id="mRegPwd2Err">Ne correspond pas</div></div><div class="a-field" style="flex-direction:row;align-items:flex-start;gap:8px;background:rgba(255,179,0,.06);border:1px solid rgba(255,179,0,.15);border-radius:var(--r2);padding:10px"><input type="checkbox" id="mRegAge" style="margin-top:2px;accent-color:var(--acc);width:16px;height:16px;flex-shrink:0;cursor:pointer"><label for="mRegAge" style="font-size:11px;color:var(--text2);cursor:pointer;line-height:1.4">J'ai <strong style="color:var(--acc)">18 ans ou plus</strong> et j'accepte les <span style="color:var(--acc);text-decoration:underline">Conditions d'utilisation</span>. Le jeu peut créer une dépendance — jouez de manière responsable.</label></div><div class="a-err" id="mRegAgeErr">Vous devez avoir 18 ans et accepter les conditions</div><button class="a-btn prim" id="mRegisterBtn"><i class="fas fa-user-plus"></i> Créer mon compte</button></div><button id="mCloseBtn" style="width:100%;margin-top:8px;padding:9px;border:1px solid var(--bdr);border-radius:var(--r2);background:transparent;color:var(--text3);font-family:var(--fb);font-size:12px;cursor:pointer">Continuer sans compte</button></div></div></div><!-- ══ WELCOME MODAL ═════════════════════════════════════════ --><div id="welcomeOv"><div class="w-box"><span class="w-icon">🎉</span><div class="w-title" id="wTitle">Bienvenue!</div><div id="wSub" style="font-size:13px;color:var(--text2);margin-bottom:12px">Compte créé avec succès</div><div class="w-info" id="wInfo"></div><div class="w-bonus" id="wBonus"><div class="w-amt">$200</div><div class="w-lbl">🎮 $200 de mise virtuelle pour vous entraîner (gratuit)</div></div><button class="a-btn prim" id="welcomeBtn" style="margin-top:0"><i class="fas fa-play"></i> Accéder à mon compte</button></div></div><div id="app" style="display:flex"><header class="hdr"><div class="logo" id="logoBtn">BETZONE</div><!-- Auth buttons (shown when not logged in) --><div id="authBtns" style="display:flex;align-items:center;gap:5px;margin-left:auto;flex-shrink:0"><button id="hLoginBtn" style="padding:5px 12px;border:1px solid rgba(0,230,118,.3);border-radius:16px;background:transparent;color:var(--acc);font-family:var(--fb);font-size:11px;font-weight:600;cursor:pointer;white-space:nowrap">Connexion</button><button id="hRegBtn" style="padding:5px 12px;border:none;border-radius:16px;background:linear-gradient(135deg,var(--acc),#00C853);color:#000;font-family:var(--fb);font-size:11px;font-weight:700;cursor:pointer;white-space:nowrap">Inscription</button></div><!-- User badge (shown when logged in) --><div id="uBadge" class="u-badge" style="display:none;margin-left:auto"></div><!-- Balance --><div id="balBox" style="display:flex;align-items:center;gap:4px;flex-shrink:0"></div><button class="hbtn" id="depBtn" title="Dépôt" style="display:none"><i class="fas fa-plus"></i></button><button class="hbtn" id="refBtn" title="Actualiser"><i class="fas fa-sync-alt"></i></button></header><!-- PROMO BANNER --><div class="promo-bar" id="promoBanner"><span class="promo-bar-icon">🎁</span><div><div class="promo-bar-txt">BONUS BIENVENUE — $200 VIRTUEL OFFERT</div><div class="promo-bar-sub">Inscrivez-vous et pariez gratuitement dès maintenant</div></div><i class="fas fa-chevron-right promo-bar-arrow"></i></div><!-- LIVE TICKER --><div class="ticker-wrap" id="tickerWrap"><div class="ticker" id="ticker"></div></div><!-- Account tab switcher --><div id="accSwitcher" style="display:flex;gap:3px;padding:6px 10px;background:var(--bg1);border-bottom:1px solid var(--bdr);flex-shrink:0"></div><nav class="snav" id="snav"></nav><div class="subtabs" id="subtabs"></div><div class="mwrap"><div class="mlist" id="mlist"></div></div><button class="bfab" id="bfab"><i class="fas fa-receipt"></i><span class="bdg" id="bbdg" style="display:none">0</span></button><!-- Betslip sheet --><div class="bsheet-ov" id="bov"></div><div class="bsheet" id="bsheet"><div class="bsh"></div><div id="bslip-inner"></div></div><!-- FIFA Live Panel — s'ouvre automatiquement après un pari FIFA --><div class="flp-ov" id="flpOv"></div><div class="flp" id="flpPanel"><div class="flp-drag"></div><div class="flp-head"><div style="display:flex;align-items:center;gap:8px"><span class="flp-live-dot"></span><span class="flp-title">LIVE FIFA</span><span class="flp-min" id="flpMin">0'</span></div><button class="flp-close" id="flpClose"><i class="fas fa-times"></i></button></div><!-- Score board --><div class="flp-score-wrap"><div class="flp-team"><img class="flp-logo" id="flpHL" src="" onerror="this.style.display='none'"><span class="flp-tname" id="flpHN">—</span></div><div class="flp-score-box"><span class="flp-sc" id="flpHS">0</span><span class="flp-sc-sep">-</span><span class="flp-sc" id="flpAS">0</span></div><div class="flp-team r"><span class="flp-tname" id="flpAN">—</span><img class="flp-logo" id="flpAL" src="" onerror="this.style.display='none'"></div></div><!-- Progress bar --><div class="flp-prog-wrap"><div class="flp-prog-bg"><div class="flp-prog-fill" id="flpProg" style="width:0%"></div></div><div style="display:flex;justify-content:space-between;font-size:9px;color:var(--text3);margin-top:2px"><span>0'</span><span>45'</span><span>90'</span></div></div><!-- Events feed --><div class="flp-events" id="flpEvents"></div><!-- Mise en jeu info --><div class="flp-stake-info" id="flpStakeInfo"></div><!-- Résultat final --><div class="flp-result" id="flpResult" style="display:none"></div></div><!-- Market modal --><div class="mo" id="mktMo"><div class="mo-inner"><div class="mo-head"><span class="mo-title" id="moTitle">Marchés</span><button class="mo-close" id="moClose"><i class="fas fa-times"></i></button></div><div class="mo-mbar" id="moBar"></div><div class="mkt-cats" id="moCats"></div><div class="mkt-body" id="moBody"></div></div></div><!-- Deposit modal --><div class="mo" id="depMo"><div class="mo-inner" style="max-height:70%;margin-top:auto"><div class="mo-head"><span class="mo-title" id="depTitle">Dépôt</span><button class="mo-close" id="depClose"><i class="fas fa-times"></i></button></div><div class="mkt-body" id="depBody"></div></div></div><!-- Profile modal --><div class="mo" id="profileMo"><div class="mo-prof"><div class="mo-head"><span class="mo-title">Mon Profil</span><button class="mo-close" id="profileClose"><i class="fas fa-times"></i></button></div><div class="mkt-body" id="profileBody"></div></div></div><div class="tc-wrap" id="tc"></div><!-- Responsible gambling footer --><div style="background:rgba(255,179,0,.05);border-top:1px solid rgba(255,179,0,.1);padding:4px 10px;display:flex;align-items:center;justify-content:center;gap:6px;flex-shrink:0"><span style="font-size:9px;color:rgba(255,179,0,.6);font-weight:600">🔞 18+</span><span style="font-size:9px;color:var(--text3)">Jouez de manière responsable • Le jeu peut créer une dépendance</span></div></div><script>'use strict';

/* ══════════════════════════════════════════════════════════════
   MOTEUR IA — PROBABILITÉS, COTES & MODÈLE POISSON
   (traduit du module Python)
══════════════════════════════════════════════════════════════ */

// Listes d'équipes par sport
var BZ_TEAMS_FOOT = ["Arsenal","Chelsea","Barcelona","Real Madrid","Bayern","Dortmund","PSG","Marseille","Juventus","Inter","Milan","Napoli"];
var BZ_TEAMS_NBA  = ["Lakers","Celtics","Warriors","Heat","Bulls","Nets","Bucks","Suns","76ers","Clippers","Nuggets","Mavs"];
var BZ_TEAMS_NFL  = ["Chiefs","Eagles","Cowboys","Patriots","49ers","Packers","Ravens","Bills","Bengals","Dolphins","Bears","Giants"];

// ── Génération de probabilités home/draw/away ──────────────────
function bzGenerateProbability() {
  var home = 0.35 + Math.random() * 0.20; // 0.35–0.55
  var draw = 0.20 + Math.random() * 0.10; // 0.20–0.30
  var away = 1 - (home + draw);
  if (away < 0.05) away = 0.05;
  return { home: home, draw: draw, away: away };
}

// ── Conversion probabilité → cote (avec marge bookmaker 8%) ────
function bzProbToOdds(prob) {
  var margin = 1.08;
  return Math.round((1 / prob) * margin * 100) / 100;
}

// ── Value bet : vaut-il le coup ? ──────────────────────────────
function bzValueBet(prob, odd) {
  return prob * odd > 1;
}

// ── Profit bookmaker simulé ────────────────────────────────────
function bzBookmakerProfit(betHome, betDraw, betAway, oddHome, oddDraw, oddAway, result) {
  var total = betHome + betDraw + betAway;
  var payout = 0;
  if (result === 'home') payout = betHome * oddHome;
  else if (result === 'draw') payout = betDraw * oddDraw;
  else payout = betAway * oddAway;
  return Math.round((total - payout) * 100) / 100;
}

// ── Modèle de Poisson (prédiction du score) ────────────────────
function bzPoisson(lambda, k) {
  var e = Math.exp(-lambda);
  var fact = 1; for (var i = 1; i <= k; i++) fact *= i;
  return (Math.pow(lambda, k) * e) / fact;
}

function bzPredictScore(avg1, avg2) {
  var matrix = [];
  for (var i = 0; i < 5; i++) {
    var row = [];
    for (var j = 0; j < 5; j++) {
      row.push(bzPoisson(avg1, i) * bzPoisson(avg2, j));
    }
    matrix.push(row);
  }
  return matrix;
}

// Trouve le score le plus probable via la matrice de Poisson
function bzMostLikelyScore(avg1, avg2) {
  var matrix = bzPredictScore(avg1, avg2);
  var bestP = -1, bestI = 0, bestJ = 0;
  for (var i = 0; i < 5; i++) {
    for (var j = 0; j < 5; j++) {
      if (matrix[i][j] > bestP) { bestP = matrix[i][j]; bestI = i; bestJ = j; }
    }
  }
  return { home: bestI, away: bestJ, prob: Math.round(bestP * 100) };
}

// ── Ajustement dynamique de cote selon le volume de paris ─────
function bzAdjustOdds(prob, totalBets) {
  var betFactor = totalBets / 10000;
  var newProb = prob - betFactor;
  if (newProb < 0.05) newProb = 0.05;
  return Math.round((1 / newProb) * 100) / 100;
}

// ── Génération complète d'un match simulé ──────────────────────
function bzSimulateMatch(teamList) {
  teamList = teamList || BZ_TEAMS_FOOT;
  var t1 = teamList[Math.floor(Math.random() * teamList.length)];
  var t2; do { t2 = teamList[Math.floor(Math.random() * teamList.length)]; } while (t2 === t1);
  var probs = bzGenerateProbability();
  var betsH = 1000 + Math.floor(Math.random() * 4000);
  var betsD = 500  + Math.floor(Math.random() * 2500);
  var betsA = 1000 + Math.floor(Math.random() * 4000);
  var oddH  = bzAdjustOdds(probs.home, betsH);
  var oddD  = bzAdjustOdds(probs.draw, betsD);
  var oddA  = bzAdjustOdds(probs.away, betsA);
  var avg1  = 1.2 + Math.random() * 0.8;
  var avg2  = 1.0 + Math.random() * 0.8;
  var score = bzMostLikelyScore(avg1, avg2);
  return {
    home: t1, away: t2,
    probs: probs,
    odds: { home: oddH, draw: oddD, away: oddA },
    bets:  { home: betsH, draw: betsD, away: betsA },
    score: score,
    valueHome: bzValueBet(probs.home, oddH),
    valueDraw: bzValueBet(probs.draw, oddD),
    valueAway: bzValueBet(probs.away, oddA)
  };
}

// ── Génère des cotes IA pour n'importe quel match ──────────────
// Retourne { home, draw, away, scoreHome, scoreAway, isValue }
function bzGetMatchOdds(team1, team2) {
  var probs = bzGenerateProbability();
  var bets  = { home: 1000 + Math.floor(Math.random()*4000), draw: 500+Math.floor(Math.random()*2500), away: 1000+Math.floor(Math.random()*4000) };
  var avg1  = 1.0 + Math.random() * 1.0;
  var avg2  = 1.0 + Math.random() * 1.0;
  var score = bzMostLikelyScore(avg1, avg2);
  return {
    home:  bzAdjustOdds(probs.home, bets.home),
    draw:  bzAdjustOdds(probs.draw, bets.draw),
    away:  bzAdjustOdds(probs.away, bets.away),
    probHome: probs.home, probDraw: probs.draw, probAway: probs.away,
    scoreHome: score.home, scoreAway: score.away,
    isValueHome: bzValueBet(probs.home, bzAdjustOdds(probs.home, bets.home)),
    isValueAway: bzValueBet(probs.away, bzAdjustOdds(probs.away, bets.away))
  };
}

/* ── Mini-panneau IA accessible depuis le profil ─────────────── */
function bzOpenAIPanel() {
  var existing = document.getElementById('bzAiPanel');
  if (existing) { existing.remove(); return; }
  var sport = (typeof S !== 'undefined' && S.sport) ? S.sport : 'football';
  var teamList = sport === 'nba' ? BZ_TEAMS_NBA : sport === 'nfl' ? BZ_TEAMS_NFL : BZ_TEAMS_FOOT;
  var simulations = [];
  for (var i = 0; i < 5; i++) simulations.push(bzSimulateMatch(teamList));

  var rows = simulations.map(function(m) {
    var vh = m.valueHome ? '<span style="color:var(--acc);font-size:9px;font-weight:800">⚡</span>' : '';
    var va = m.valueAway ? '<span style="color:var(--acc);font-size:9px;font-weight:800">⚡</span>' : '';
    var pct = Math.round(m.probs.home * 100) + '/' + Math.round(m.probs.draw * 100) + '/' + Math.round(m.probs.away * 100);
    return '<div style="background:var(--bg3);border:1px solid var(--bdr);border-radius:8px;padding:10px;margin-bottom:6px">'
      + '<div style="display:flex;justify-content:space-between;margin-bottom:6px">'
      +   '<span style="font-size:12px;font-weight:700">' + m.home + ' vs ' + m.away + '</span>'
      +   '<span style="font-size:9px;color:var(--text3)">' + pct + '%</span>'
      + '</div>'
      + '<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:4px">'
      +   '<div style="text-align:center;background:var(--bg4);border-radius:6px;padding:6px">'
      +     vh + '<div style="font-size:11px;color:var(--text3)">1</div>'
      +     '<div style="font-size:14px;font-weight:800;color:var(--acc)">' + m.odds.home + '</div>'
      +   '</div>'
      +   '<div style="text-align:center;background:var(--bg4);border-radius:6px;padding:6px">'
      +     '<div style="font-size:11px;color:var(--text3)">X</div>'
      +     '<div style="font-size:14px;font-weight:800;color:var(--text2)">' + m.odds.draw + '</div>'
      +   '</div>'
      +   '<div style="text-align:center;background:var(--bg4);border-radius:6px;padding:6px">'
      +     va + '<div style="font-size:11px;color:var(--text3)">2</div>'
      +     '<div style="font-size:14px;font-weight:800;color:var(--acc)">' + m.odds.away + '</div>'
      +   '</div>'
      + '</div>'
      + '<div style="font-size:10px;color:var(--text3);margin-top:5px">Score prédit: <strong style="color:var(--gold)">' + m.score.home + '-' + m.score.away + '</strong> (' + m.score.prob + '%)</div>'
      + '</div>';
  }).join('');

  var panel = document.createElement('div');
  panel.id = 'bzAiPanel';
  panel.style.cssText = 'position:absolute;inset:0;z-index:850;background:rgba(0,0,0,.9);backdrop-filter:blur(6px);display:flex;flex-direction:column;overflow:hidden';
  panel.innerHTML = '<div style="background:linear-gradient(135deg,var(--bg1),var(--bg2));border-bottom:1px solid var(--bdr);padding:13px 16px;display:flex;align-items:center;gap:8px;flex-shrink:0">'
    + '<span style="font-family:var(--fh);font-size:20px;letter-spacing:1px;flex:1;color:var(--acc)">🤖 MOTEUR IA — COTES</span>'
    + '<button onclick="document.getElementById(\'bzAiPanel\').remove()" style="background:none;border:none;color:var(--text2);font-size:18px;cursor:pointer;padding:6px;border-radius:50%">✕</button>'
    + '</div>'
    + '<div style="flex:1;overflow-y:auto;padding:12px">'
    + '<div style="font-size:10px;color:var(--text3);margin-bottom:10px;background:var(--acc4);border:1px solid rgba(0,230,118,.15);border-radius:8px;padding:8px 10px">⚡ = Value Bet détecté &nbsp;|&nbsp; Modèle Poisson + ajustement par volume &nbsp;|&nbsp; Marge bookmaker 8%</div>'
    + rows
    + '<button onclick="document.getElementById(\'bzAiPanel\').remove();setTimeout(bzOpenAIPanel,50)" style="width:100%;padding:11px;border:1px solid rgba(0,230,118,.3);border-radius:10px;background:var(--acc4);color:var(--acc);font-family:var(--fb);font-size:12px;font-weight:700;cursor:pointer;margin-top:4px"><i class="fas fa-sync-alt"></i> Nouvelles simulations</button>'
    + '</div>';
  var app = document.getElementById('app');
  if (app) app.appendChild(panel);
}

/* ── Bouton IA dans le header (injecté après chargement DOM) ── */
document.addEventListener('DOMContentLoaded', function() {
  var refBtn = document.getElementById('refBtn');
  if (refBtn) {
    var aiBtn = document.createElement('button');
    aiBtn.className = 'hbtn';
    aiBtn.title = 'Moteur IA — Cotes & Prédictions';
    aiBtn.innerHTML = '<i class="fas fa-robot"></i>';
    aiBtn.onclick = bzOpenAIPanel;
    refBtn.parentNode.insertBefore(aiBtn, refBtn);
  }
});

/* ══════════════════════════════════════════════════════════════ */

var _MEM={};
function lsGet(k){try{return localStorage.getItem(k);}catch(e){return _MEM[k]!=null?_MEM[k]:null;}}
function lsSet(k,v){try{localStorage.setItem(k,v);}catch(e){_MEM[k]=v;}}
function lsDel(k){try{localStorage.removeItem(k);}catch(e){delete _MEM[k];}}
function authDb(){try{return JSON.parse(lsGet('bz_users')||'{}');}catch(e){return{};}}
function saveDb(db){lsSet('bz_users',JSON.stringify(db));}
function getStoredUser(){var id=lsGet('bz_cur');if(!id)return null;var db=authDb();return db[id]||null;}
function genAccNum(){
var db=authDb();
var nums=Object.keys(db).map(function(k){return parseInt(k)||0;}).filter(function(n){return n>0;});
var next=(nums.length>0?Math.max.apply(null,nums):0)+1;
return String(next).padStart(8,'0');
}
function genBetNum(){
var d=new Date();
var dt=d.getFullYear()+('0'+(d.getMonth()+1)).slice(-2)+('0'+d.getDate()).slice(-2);
var todayBets=S.hist.filter(function(b){return b.betNum&&b.betNum.startsWith(dt);}).length;
var seq=String(todayBets+1).padStart(6,'0');
return dt+'-'+seq;
}
var AUTH={user:null};
function authSaveUser(u){
var db=authDb();db[u.accountNum]=u;saveDb(db);lsSet('bz_cur',u.accountNum);
}
function authPersist(){
if(!AUTH.user)return;
AUTH.user.virtBal=S.virtBal;AUTH.user.realBal=S.realBal;
AUTH.user.activeAcc=S.activeAcc;AUTH.user.hist=JSON.parse(JSON.stringify(S.hist));
authSaveUser(AUTH.user);
}
function openLoginModal(startTab){
var m=document.getElementById('loginModal');
m.style.display='flex';
switchModalTab(startTab||'login');
}
function closeLoginModal(){
document.getElementById('loginModal').style.display='none';
}
function switchModalTab(t){
var isL=t==='login';
document.getElementById('mTabLogin').classList.toggle('on',isL);
document.getElementById('mTabRegister').classList.toggle('on',!isL);
document.getElementById('mLoginForm').style.display=isL?'':'none';
document.getElementById('mRegisterForm').style.display=isL?'none':'';
document.querySelectorAll('#loginModal .a-err').forEach(function(e){e.classList.remove('show');});
document.querySelectorAll('#loginModal .a-inp').forEach(function(e){e.classList.remove('err');});
}
function showAuthScreen(){}
function showAppScreen(){}
function switchTab(t){}
function fErr(iid,eid,msg,show){
var i=document.getElementById(iid),e=document.getElementById(eid);
if(i)i.classList.toggle('err',show);
if(e){e.classList.toggle('show',show);if(show&&msg)e.textContent=msg;}
}
function doModalLogin(){
var id=(document.getElementById('mLoginId').value||'').trim();
var pw=document.getElementById('mLoginPwd').value||'';
if(!id){fErr('mLoginId','mLoginIdErr','Champ requis',true);return;}else{fErr('mLoginId','mLoginIdErr','',false);}
if(!pw){fErr('mLoginPwd','mLoginPwdErr','Champ requis',true);return;}else{fErr('mLoginPwd','mLoginPwdErr','',false);}
var db=authDb();
var u=db[id]||Object.values(db).find(function(x){return x.email&&x.email.toLowerCase()===id.toLowerCase();});
if(!u||u.password!==pw){fErr('mLoginPwd','mLoginPwdErr','Identifiants incorrects',true);return;}
closeLoginModal();
AUTH.user=u;
S.virtBal=typeof u.virtBal==='number'?u.virtBal:VIRT_START;
S.realBal=typeof u.realBal==='number'?u.realBal:0;
S.activeAcc=u.activeAcc||'virt';
S.hist=Array.isArray(u.hist)?u.hist:[];
lsSet('bz_cur',u.accountNum);
updateHeaderAuth();
showWelcome(u,false);
trackEvent('login',{});
}
function doModalRegister(){
var first=(document.getElementById('mRegFirst').value||'').trim();
var last=(document.getElementById('mRegLast').value||'').trim();
var email=(document.getElementById('mRegEmail').value||'').trim();
var phone=(document.getElementById('mRegPhone').value||'').trim();
var pw=document.getElementById('mRegPwd').value||'';
var pw2=document.getElementById('mRegPwd2').value||'';
var ok=true,db=authDb();
if(first.length<2){fErr('mRegFirst','mRegFirstErr','Minimum 2 caractères',true);ok=false;}else{fErr('mRegFirst','mRegFirstErr','',false);}
if(last.length<2){fErr('mRegLast','mRegLastErr','Minimum 2 caractères',true);ok=false;}else{fErr('mRegLast','mRegLastErr','',false);}
var eRe=/^[^\s@]+@[^\s@]+\.[^\s@]+$/;
var eUsed=Object.values(db).some(function(x){return x.email&&x.email.toLowerCase()===email.toLowerCase();});
if(!eRe.test(email)){fErr('mRegEmail','mRegEmailErr','Email invalide',true);ok=false;}
else if(eUsed){fErr('mRegEmail','mRegEmailErr','Email déjà utilisé',true);ok=false;}
else{fErr('mRegEmail','mRegEmailErr','',false);}
if(pw.length<6){fErr('mRegPwd','mRegPwdErr','Minimum 6 caractères',true);ok=false;}else{fErr('mRegPwd','mRegPwdErr','',false);}
if(pw!==pw2){fErr('mRegPwd2','mRegPwd2Err','Ne correspond pas',true);ok=false;}else{fErr('mRegPwd2','mRegPwd2Err','',false);}
var ageEl=document.getElementById('mRegAge');
if(!ageEl||!ageEl.checked){fErr('mRegAge','mRegAgeErr','Vous devez avoir 18 ans et accepter les conditions',true);ok=false;}
else{fErr('mRegAge','mRegAgeErr','',false);}
if(!ok)return;
var accNum=genAccNum();
var u={accountNum:accNum,first:first,last:last,email:email,phone:phone,password:pw,
createdAt:new Date().toLocaleDateString('fr-FR'),virtBal:VIRT_START,realBal:0,activeAcc:'virt',hist:[]};
db[accNum]=u;saveDb(db);
closeLoginModal();
showWelcome(u,true);
AUTH.user=u;S.virtBal=VIRT_START;S.realBal=0;S.activeAcc='virt';S.hist=[];
lsSet('bz_cur',accNum);
updateHeaderAuth();
trackEvent('register',{bonus:200});
}
function showWelcome(u,isNew){
document.getElementById('wInfo').innerHTML=
'<div class="w-row"><span class="w-key">N° de compte</span><span class="w-val" style="color:var(--acc);font-size:14px;font-family:monospace">'+u.accountNum+'</span></div>'
+'<div class="w-row"><span class="w-key">Titulaire</span><span class="w-val">'+esc(u.first+' '+u.last)+'</span></div>'
+'<div class="w-row"><span class="w-key">Email</span><span class="w-val" style="font-family:var(--fb);font-size:11px">'+esc(u.email)+'</span></div>'
+(u.phone?'<div class="w-row"><span class="w-key">Téléphone</span><span class="w-val" style="font-family:var(--fb)">'+esc(u.phone)+'</span></div>':'')
+'<div class="w-row"><span class="w-key">Membre depuis</span><span class="w-val" style="font-family:var(--fb)">'+esc(u.createdAt)+'</span></div>';
var bv=document.getElementById('wBonus');
if(bv)bv.style.display=isNew?'':'none';
var wt=document.getElementById('wTitle');if(wt)wt.textContent=isNew?'Bienvenue!':'Connexion réussie';
var ws=document.getElementById('wSub');if(ws)ws.textContent=isNew?'Compte créé avec succès':'Bon retour sur BETZONE';
document.getElementById('welcomeOv').style.display='flex';
}
function bootWithUser(u){
AUTH.user=u;
S.virtBal=typeof u.virtBal==='number'?u.virtBal:VIRT_START;
S.realBal=typeof u.realBal==='number'?u.realBal:0;
S.activeAcc=u.activeAcc||'virt';
S.hist=Array.isArray(u.hist)?u.hist:[];
lsSet('bz_cur',u.accountNum);
updateHeaderAuth();
renderAll();
checkBroke();
setTimeout(function(){fetchSport(S.sport);},100);
setTimeout(function(){initVirt();initFifa();},600);
}
function updateHeaderAuth(){
var isLogged=!!AUTH.user;
var ab=document.getElementById('authBtns');
var ub=document.getElementById('uBadge');
var db=document.getElementById('depBtn');
if(ab)ab.style.display=isLogged?'none':'flex';
if(db)db.style.display=isLogged?'':'none';
if(ub){
if(isLogged){
var ini=((AUTH.user.first||'?')[0]+(AUTH.user.last||'?')[0]).toUpperCase();
ub.innerHTML='<div class="u-av">'+ini+'</div><span class="u-name">'+esc(AUTH.user.first)+'</span>';
ub.style.display='flex';
}else{
ub.style.display='none';
}
}
}
function renderUBadge(){updateHeaderAuth();}
function openProfile(){
if(!AUTH.user)return;
var u=AUTH.user;
var pend=S.hist.filter(function(b){return b.status==='pending';}).length;
var won=S.hist.filter(function(b){return b.status==='won';}).length;
var lost=S.hist.filter(function(b){return b.status==='lost';}).length;
document.getElementById('profileBody').innerHTML=
'<div style="text-align:center;padding:8px 0 16px">'
+'<div style="width:54px;height:54px;border-radius:50%;background:linear-gradient(135deg,var(--acc),var(--gold));display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:800;color:#000;margin:0 auto 10px">'+((u.first||'?')[0]+(u.last||'?')[0]).toUpperCase()+'</div>'
+'<div style="font-size:17px;font-weight:700">'+esc(u.first+' '+u.last)+'</div>'
+'<div style="font-size:11px;color:var(--text3)">'+esc(u.email)+'</div></div>'
+'<div style="background:var(--bg2);border:1px solid var(--bdr);border-radius:var(--r);padding:13px;margin-bottom:12px">'
+'<div class="w-row"><span class="w-key">N° de compte</span><span style="font-weight:700;font-family:monospace;color:var(--acc);font-size:12px">'+u.accountNum+'</span></div>'
+(u.phone?'<div class="w-row"><span class="w-key">Téléphone</span><span class="w-val" style="font-family:var(--fb)">'+esc(u.phone)+'</span></div>':'')
+'<div class="w-row"><span class="w-key">Membre depuis</span><span class="w-val" style="font-family:var(--fb)">'+esc(u.createdAt)+'</span></div></div>'
+'<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:7px;margin-bottom:14px">'
+'<div style="background:var(--gold2);border:1px solid rgba(255,179,0,.15);border-radius:var(--r2);padding:10px;text-align:center"><div style="font-size:20px;font-weight:800;color:var(--gold)">'+pend+'</div><div style="font-size:10px;color:var(--text3)">En cours</div></div>'
+'<div style="background:var(--acc2);border:1px solid rgba(0,230,118,.15);border-radius:var(--r2);padding:10px;text-align:center"><div style="font-size:20px;font-weight:800;color:var(--acc)">'+won+'</div><div style="font-size:10px;color:var(--text3)">Gagnés</div></div>'
+'<div style="background:var(--red2);border:1px solid rgba(255,23,68,.15);border-radius:var(--r2);padding:10px;text-align:center"><div style="font-size:20px;font-weight:800;color:var(--red)">'+lost+'</div><div style="font-size:10px;color:var(--text3)">Perdus</div></div></div>'
+'<div style="font-size:11px;color:var(--text3);text-align:center;margin-bottom:12px">Virtuel:<strong style="color:var(--acc)">$'+fo(S.virtBal)+'</strong>&nbsp;|&nbsp;Réel:<strong style="color:var(--blue)">$'+fo(S.realBal)+'</strong></div>'
+(S.realBal>=30?'<button id="wdBtn" style="width:100%;padding:11px;border:none;border-radius:var(--r);background:linear-gradient(135deg,var(--gold),#E65100);color:#000;font-family:var(--fb);font-size:13px;font-weight:700;cursor:pointer;margin-bottom:8px"><i class="fas fa-money-bill-wave"></i>Retirer des fonds($'+fo(S.realBal)+')</button>':'')
+'<button id="depRealBtn" style="width:100%;padding:11px;border:none;border-radius:var(--r);background:linear-gradient(135deg,var(--blue),#1565C0);color:#fff;font-family:var(--fb);font-size:13px;font-weight:700;cursor:pointer;margin-bottom:8px"><i class="fas fa-plus-circle"></i>Déposer des fonds</button>'
+'<button id="logoutBtn" style="width:100%;padding:11px;border:1px solid var(--bdr);border-radius:var(--r);background:transparent;color:var(--text2);font-family:var(--fb);font-size:13px;font-weight:600;cursor:pointer"><i class="fas fa-sign-out-alt"></i>Se déconnecter</button>';
document.getElementById('profileMo').classList.add('open');
var wdB=document.getElementById('wdBtn');
if(wdB)wdB.onclick=function(){document.getElementById('profileMo').classList.remove('open');openWithdraw();};
var depRB=document.getElementById('depRealBtn');
if(depRB)depRB.onclick=function(){S.activeAcc='real';document.getElementById('profileMo').classList.remove('open');openDeposit();};
document.getElementById('logoutBtn').onclick=function(){
showCfm('Se déconnecter?',function(){
authPersist();
trackEvent('logout',{});
lsDel('bz_cur');
AUTH.user=null;S.hist=[];S.slip=[];S.virtBal=VIRT_START;S.realBal=0;S.activeAcc='virt';
S.cache={};S.vmatches={};S.fmatches={};S.fifaSaison=null;
var bov=document.getElementById('brokeOv');if(bov)bov.remove();
document.getElementById('profileMo').classList.remove('open');
updateHeaderAuth();
updBal();renderAll();
setTimeout(function(){fetchSport(S.sport);},100);
setTimeout(function(){initVirt();initFifa();},600);
});
};
}
document.getElementById('mTabLogin').addEventListener('click',function(){switchModalTab('login');});
document.getElementById('mTabRegister').addEventListener('click',function(){switchModalTab('register');});
document.getElementById('mLoginBtn').addEventListener('click',doModalLogin);
document.getElementById('mRegisterBtn').addEventListener('click',doModalRegister);
document.getElementById('mCloseBtn').addEventListener('click',closeLoginModal);
['mLoginId','mLoginPwd'].forEach(function(id){
document.getElementById(id).addEventListener('keydown',function(e){if(e.key==='Enter')doModalLogin();});
});
['mRegFirst','mRegLast','mRegEmail','mRegPhone','mRegPwd','mRegPwd2'].forEach(function(id){
document.getElementById(id).addEventListener('keydown',function(e){if(e.key==='Enter')doModalRegister();});
});
document.getElementById('hLoginBtn').addEventListener('click',function(){openLoginModal('login');});
document.getElementById('hRegBtn').addEventListener('click',function(){openLoginModal('register');});
document.getElementById('welcomeBtn').addEventListener('click',function(){
document.getElementById('welcomeOv').style.display='none';
renderAll();checkBroke();
setTimeout(function(){fetchSport(S.sport);},100);
setTimeout(function(){initVirt();initFifa();},600);
if(AUTH.user)pingServer('login');
});
document.getElementById('profileClose').addEventListener('click',function(){document.getElementById('profileMo').classList.remove('open');});
var SERVER_URL='';
var _SESSION_ID='sess-'+(Date.now().toString(36))+(Math.random().toString(36).slice(2));
var _serverAvailable=false;
function trackEvent(event,data){
if(!SERVER_URL)return;
try{
fetch(SERVER_URL+'/api/track',{
method:'POST',
headers:{'Content-Type':'application/json'},
body:JSON.stringify({
event:event,
sessionId:_SESSION_ID,
userId:AUTH.user?AUTH.user.accountNum:null,
data:data||{}
})
}).catch(function(){_serverAvailable=false;});
}catch(e){}
}
function pingServer(evt){trackEvent(evt||'ping',{});}
setInterval(function(){pingServer('ping');},2*60*1000);
setTimeout(function(){pingServer('ping');},2000);
(function(){if(window.matchMedia('(prefers-color-scheme:light)').matches)document.documentElement.classList.add('light');})();
var VIRT_START=200;
var S={
virtBal:VIRT_START,realBal:0,activeAcc:'virt',
sport:'football',tab:'live',
cache:{},slip:[],hist:[],
mode:'single',stake:0,slipOpen:false,
loading:{},errors:{},
vmatches:{},fmatches:{},
fifaLg:'eng.1',fifaView:'matchs',fifaSaison:null,
tick:0,
openMktId:null,openMktCat:null
};
function getActiveBal(){return S.activeAcc==='real'?S.realBal:S.virtBal;}
function setActiveBal(v){if(S.activeAcc==='real')S.realBal=v;else S.virtBal=v;}
function deductBal(v){setActiveBal(Math.max(0,getActiveBal()-v));}
function addBal(v){
v=Math.round(v*100)/100;
if(S.activeAcc==='virt'){
S.virtBal=Math.round((S.virtBal+v)*100)/100;
}else{
S.realBal=Math.round((S.realBal+v)*100)/100;
}
authPersist();
}
