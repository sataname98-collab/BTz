function fmt(n){return Math.round(n).toLocaleString('fr-FR');}
function fo(n){return Number(n).toFixed(2);}
function rng(){var a=new Uint32Array(1);try{crypto.getRandomValues(a);}catch(e){a[0]=Math.floor(Math.random()*4294967295);}return a[0]/4294967295;}
function rnd(a,b){return rng()*(b-a)+a;}
function ri(a,b){return Math.floor(rng()*(b-a+1))+a;}
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function shuf(a){var b=a.slice();for(var i=b.length-1;i>0;i--){var j=ri(0,i);var t=b[i];b[i]=b[j];b[j]=t;}return b;}
function fmm(e,d){var m=Math.floor(e/60),s=e%60;return m+':'+(s<10?'0':'')+s;}
function clamp(v,a,b){return Math.max(a,Math.min(b,v));}
function dbOpen(){return new Promise(function(r,j){var req=indexedDB.open('bz5',1);req.onupgradeneeded=function(e){e.target.result.createObjectStore('s');};req.onsuccess=function(){r(req.result);};req.onerror=function(){j(req.error);};});}
function dbSave(){setTimeout(function(){dbOpen().then(function(db){var tx=db.transaction('s','readwrite'),st=tx.objectStore('s');st.put(S.virtBal,'virtBal');st.put(S.realBal,'realBal');st.put(S.activeAcc,'activeAcc');st.put(JSON.parse(JSON.stringify(S.hist)),'hist');tx.oncomplete=function(){db.close();};});},300);}
function dbLoad(){return dbOpen().then(function(db){return new Promise(function(r){var tx=db.transaction('s','readonly'),st=tx.objectStore('s');var a=st.get('virtBal'),b=st.get('realBal'),c=st.get('activeAcc'),d=st.get('hist');tx.oncomplete=function(){if(typeof a.result==='number')S.virtBal=a.result;if(typeof b.result==='number')S.realBal=b.result;if(a.result===null||a.result===undefined)S.virtBal=VIRT_START;if(c.result)S.activeAcc=c.result;if(Array.isArray(d.result))S.hist=d.result;db.close();r();};tx.onerror=function(){db.close();r();};});}).catch(function(){});}
function dbClear(){dbOpen().then(function(db){var tx=db.transaction('s','readwrite');tx.objectStore('s').clear();tx.oncomplete=function(){db.close();};}).catch(function(){});}
function _fact(n){return n<=1?1:n*_fact(n-1);}
function _pois(l,k){var lc=Math.max(l,0.001);return(Math.pow(lc,k)*Math.exp(-lc))/_fact(Math.min(k,15));}
function _clampP(p){return Math.max(0.005,Math.min(0.995,p));}
function _vig(p,m){return+Math.max(1.01,1/(_clampP(p)*(1+m))).toFixed(2);}
function _erfA(z){var t=1/(1+0.3275911*Math.abs(z)),p=t*(0.254829592+t*(-0.284496736+t*(1.421413741+t*(-1.453152027+t*1.061405429)))),v=1-p*Math.exp(-z*z);return z>=0?v:-v;}
function _normCDF(x,mu,sg){return 0.5*(1+_erfA((x-mu)/(sg*Math.SQRT2)));}
function _scoreMatrix(la,lb,max){
max=max||9;
return Array.from({length:max},function(_,i){return Array.from({length:max},function(_,j){return _pois(la,i)*_pois(lb,j);});});
}
function _calcBasketball(fA,fB,marg){
marg=marg||0.055;
var tot=fA+fB,pA=fA/tot;
var avgP=215,ptA=pA*avgP,ptB=(1-pA)*avgP;
var line=Math.round(ptA+ptB);
var pO=1-_normCDF(line,ptA+ptB,17);
var spread=function(hdp){
var adj=_clampP(pA+(hdp/avgP)*0.6);
return{A:_vig(adj,marg),B:_vig(1-adj,marg)};
};
return{
ML:{A:_vig(pA,marg),B:_vig(1-pA,marg),pA:+(pA*100).toFixed(1),pB:+((1-pA)*100).toFixed(1)},
OU:{line:line,O:_vig(pO,marg),U:_vig(1-pO,marg)},
Spread:{'-5.5':spread(-5.5),'-3.5':spread(-3.5),'-1.5':spread(-1.5),'+1.5':spread(1.5),'+3.5':spread(3.5),'+5.5':spread(5.5)},
ptA:Math.round(ptA),ptB:Math.round(ptB),pA:pA
};
}
function _calcTennis(fA,fB,bo,marg){
bo=bo||3;marg=marg||0.06;
var tot=fA+fB,pA=_clampP(fA/tot),need=Math.ceil(bo/2);
var pwA=0;
for(var w=need;w<=bo;w++){
var l=w-need;if(l<0)continue;
var comb=_fact(w-1)/(_fact(need-1)*_fact(l));
pwA+=comb*Math.pow(pA,need)*Math.pow(1-pA,l);
}
pwA=_clampP(pwA);
var sc={};
if(bo===3){
sc['2-0']={A:_vig(pA*pA,marg),B:_vig((1-pA)*(1-pA),marg)};
sc['2-1']={A:_vig(2*pA*pA*(1-pA),marg),B:_vig(2*(1-pA)*(1-pA)*pA,marg)};
}else{
sc['3-0']={A:_vig(Math.pow(pA,3),marg),B:_vig(Math.pow(1-pA,3),marg)};
sc['3-1']={A:_vig(3*Math.pow(pA,3)*(1-pA),marg),B:_vig(3*Math.pow(1-pA,3)*pA,marg)};
sc['3-2']={A:_vig(6*Math.pow(pA,3)*Math.pow(1-pA,2),marg),B:_vig(6*Math.pow(1-pA,3)*Math.pow(pA,2),marg)};
}
return{
Winner:{A:_vig(pwA,marg),B:_vig(1-pwA,marg),pA:+(pwA*100).toFixed(1),pB:+((1-pwA)*100).toFixed(1)},
Scores:sc,
TotalGames:{line:Math.round((fA+fB)/3.1),O:_vig(0.5,marg),U:_vig(0.5,marg)},
pA:pwA
};
}
function _calcRugby(fA,fB,marg){
marg=marg||0.065;
var tot=fA+fB,eq=1-Math.abs(fA-fB)/tot;
var pN=Math.min(0.12,0.02+0.10*eq);
var pA=(fA/tot)*(1-pN),pB=(fB/tot)*(1-pN);
var avgP=48,ptA=(fA/tot)*avgP,ptB=(fB/tot)*avgP,line=Math.round(ptA+ptB);
var pO=1-_normCDF(line,ptA+ptB,13);
var spread=function(hdp){
var adj=_clampP(pA+(hdp/avgP)*0.7);
return{A:_vig(adj,marg),B:_vig(1-adj,marg)};
};
return{
'1X2':{A:_vig(pA,marg),N:_vig(pN,marg),B:_vig(pB,marg),pA:+(pA*100).toFixed(1),pN:+(pN*100).toFixed(1),pB:+(pB*100).toFixed(1)},
OU:{line:line,O:_vig(pO,marg),U:_vig(1-pO,marg)},
Spread:{'-12':spread(-12),'-7':spread(-7),'-3.5':spread(-3.5),'+3.5':spread(3.5),'+7':spread(7),'+12':spread(12)},
HT:{A:_vig(pA*1.08,marg),N:_vig(pN*2,marg),B:_vig(pB*1.08,marg)},
pA:pA,pN:pN,pB:pB,ptA:Math.round(ptA),ptB:Math.round(ptB)
};
}
function poisCDF(k,lam){
if(lam<=0)return k>=0?1:0;
var s=0,t=Math.exp(-lam);
for(var i=0;i<=k;i++){s+=t;t*=lam/(i+1);}
return Math.min(1,s);
}
function _calcFootballPre(fA,fB,marg){
marg=marg||0.07;
var tot=fA+fB,eq=1-Math.abs(fA-fB)/tot;
var la=(fA/tot)*2.65*1.12,lb=(fB/tot)*2.65/1.12;
var pN=Math.min(0.32,0.08+0.22*eq);
var pA=(fA/tot)*(1-pN),pB=(fB/tot)*(1-pN);
var M=_scoreMatrix(la,lb);
var rho=-0.10;
[[0,0,1-la*lb*rho],[1,0,1+lb*rho],[0,1,1+la*rho],[1,1,1-rho]].forEach(function(r){
if(M[r[0]]&&M[r[0]][r[1]]!==undefined)M[r[0]][r[1]]*=r[2];
});
var S=function(fn){return M.reduce(function(s,r,i){return s+r.reduce(function(s2,v,j){return s2+fn(i,j,v);},0);},0);};
var pU15=S(function(i,j,v){return i+j<=1?v:0;});
var pU25=S(function(i,j,v){return i+j<=2?v:0;});
var pU35=S(function(i,j,v){return i+j<=3?v:0;});
var pBTTS=(1-_pois(la,0))*(1-_pois(lb,0));
return{la:la,lb:lb,pA:pA,pN:pN,pB:pB,
pU15:pU15,pU25:pU25,pU35:pU35,pBTTS:pBTTS,M:M,marg:marg};
}
function _calcFootballLive(base,stats,events,sH,sA,min,marg){
marg=marg||0.07;
var la=base.la,lb=base.lb;
var tf=Math.max(0,90-min)/90;
try{var xH=parseFloat((stats&&stats.xG&&stats.xG.home)||la);
var xA=parseFloat((stats&&stats.xG&&stats.xG.away)||lb);
la=(la*0.35+xH*0.65)*tf;lb=(lb*0.35+xA*0.65)*tf;}
catch(e){la*=tf;lb*=tf;}
try{var tH=parseFloat((stats&&stats.shots_on_target&&stats.shots_on_target.home)||0);
var tA=parseFloat((stats&&stats.shots_on_target&&stats.shots_on_target.away)||0);
var tc=tH+tA||1;la*=1+(tH/tc-0.5)*0.22;lb*=1+(tA/tc-0.5)*0.22;}catch(e){}
events=events||[];
var rH=events.filter(function(e){return e.type==='RED'&&e.team==='H';}).length;
var rA=events.filter(function(e){return e.type==='RED'&&e.team==='A';}).length;
la*=Math.max(0.4,1-rH*0.20);lb*=Math.max(0.4,1-rA*0.20);
var rec=events.filter(function(e){return(e.min||0)>=min-15;});
la*=1+rec.filter(function(e){return e.type==='CK'&&e.team==='H';}).length*0.03;
lb*=1+rec.filter(function(e){return e.type==='CK'&&e.team==='A';}).length*0.03;
la=Math.max(la,0.01);lb=Math.max(lb,0.01);
var M=_scoreMatrix(la,lb);
var pH=0,pD=0,pAw=0;
M.forEach(function(r,i){r.forEach(function(v,j){
var th=sH+i,ta=sA+j;
if(th>ta)pH+=v;else if(th<ta)pAw+=v;else pD+=v;
});});
var tot2=pH+pD+pAw||1;pH/=tot2;pD/=tot2;pAw/=tot2;
var ou=function(need){
if(need<=0)return 0.97;
return M.reduce(function(s,r,i){return s+r.reduce(function(s2,v,j){return s2+(i+j>=need?v:0);},0);},0);
};
var mH=sH>0,mA=sA>0,pvH=1-_pois(la,0),pvA=1-_pois(lb,0);
var pBTTS=mH&&mA?0.985:mH?pvA:mA?pvH:pvH*pvA;
var alerts=[];
if(pH>0.82)alerts.push({lvl:'warn',msg:'🏠 HOME domine '+Math.round(pH*100)+'% — cote 1 basse'});
if(pAw>0.82)alerts.push({lvl:'warn',msg:'✈ AWAY domine '+Math.round(pAw*100)+'% — cote 2 basse'});
if(rH)alerts.push({lvl:'danger',msg:'🟥 HOME à '+(11-rH)+' joueurs'});
if(rA)alerts.push({lvl:'danger',msg:'🟥 AWAY à '+(11-rA)+' joueurs'});
if(min>=75&&Math.abs(sH-sA)>=2)alerts.push({lvl:'close',msg:'⏱ Match plié — 1X2 verrouillé bientôt'});
return{pH:pH,pD:pD,pAw:pAw,pBTTS:pBTTS,alerts:alerts,la:la,lb:lb,
ou15:ou(Math.max(0,2-sH-sA)),ou25:ou(Math.max(0,3-sH-sA)),ou35:ou(Math.max(0,4-sH-sA))};
}
function calcOdds(m){
var hs=m.hs||0,as_=m.as||0,tot=hs+as_;
var live=m.status==='live';
var gmin=m.gmin||0;
var margin=0.07+rnd(0,0.008);
var fA=m.fA||70,fB=m.fB||65;
var base=_calcFootballPre(fA,fB,margin);
var pA=base.pA,pN=base.pN,pB=base.pB;
var h,d,a;
if(live&&gmin>0){
var stats=m.stats||{};
var events=m.events||m.goals||[];
var liveR=_calcFootballLive(base,stats,events,hs,as_,gmin,margin);
pA=liveR.pH;pN=liveR.pD;pB=liveR.pAw;
var timeDecay;
if(gmin<=70)timeDecay=(gmin/70)*0.50;
else timeDecay=0.50+((gmin-70)/20)*0.50;
timeDecay=Math.min(1,timeDecay);
var timeSq=timeDecay*timeDecay;
var timeCube=timeSq*timeDecay;
var absDiff=Math.abs(hs-as_);
if(absDiff===0){
var si=1+timeDecay*1.2,di=1+timeDecay*0.8;
var hPd=_clampP(pA/si),aPd=_clampP(pB/si),dPd=_clampP(1-hPd-aPd);
h=_clampP(margin/hPd);h=Math.max(1.30/margin,h);
d=_clampP(margin/dPd);d=Math.max(2.40/margin,d);
a=_clampP(margin/aPd);a=Math.max(1.30/margin,a);
}else{
var leadFactor=Math.min(absDiff,4)/4;
var pressure=leadFactor*timeCube;
var diff=hs-as_;
var winBase=diff>0?pA:pB;
var winP=_clampP(winBase+pressure*(0.999-winBase));
var drawP=_clampP(pN*(1-pressure*0.95));
var loseP=Math.max(0.005,1-winP-drawP);
var winCote=Math.max(1.01,margin/winP);
var drawCote=Math.max(2.20,margin/Math.max(0.005,drawP));
var loseCote=Math.max(1.01,margin/Math.max(0.005,loseP));
if(gmin<=70){
if(absDiff>=3)winCote=Math.max(winCote,1.08);
else if(absDiff===2)winCote=Math.max(winCote,1.15);
else winCote=Math.max(winCote,1.22);
}else{
var p70=(gmin-70)/20;
if(absDiff>=3)winCote=Math.max(winCote,1.00);
else if(absDiff===2)winCote=Math.max(winCote,Math.max(1.00,1.04-p70*0.04));
else winCote=Math.max(winCote,Math.max(1.00,1.10-p70*0.10));
}
if(diff>0){h=winCote;d=drawCote;a=loseCote;}
else{a=winCote;d=drawCote;h=loseCote;}
}
if(liveR.alerts&&liveR.alerts.length)m._alerts=liveR.alerts;
}else{
h=margin/pA;d=margin/pN;a=margin/pB;
}
h=+Math.max(1.01,Math.min(h,15)).toFixed(2);
d=+Math.max(2.20,Math.min(d,20)).toFixed(2);
a=+Math.max(1.01,Math.min(a,15)).toFixed(2);
var hLocked=live&&h<=1.01;
var aLocked=live&&a<=1.01;
var dLocked=live&&(d<=1.01||(Math.abs(hs-as_)>=2&&gmin>=80));
var dc1x,dc12,dcx2,dc1xLk,dc12Lk,dcx2Lk;
var absDiff2=Math.abs(hs-as_);
var diff2=hs-as_;
if(live&&gmin>0){
var timeDecay2;
if(gmin<=70)timeDecay2=(gmin/70)*0.50;
else timeDecay2=0.50+((gmin-70)/20)*0.50;
timeDecay2=Math.min(1,timeDecay2);
var tSq=timeDecay2*timeDecay2;
if(absDiff2===0){
var dcD=Math.min(timeDecay2*0.85,0.85);
dc1x=Math.max(1.02,(margin/(pA+pN))*(1-dcD));
dcx2=Math.max(1.02,(margin/(pN+pB))*(1-dcD));
dc12=Math.min(5.50,(margin/(pA+pB))*(1+timeDecay2*1.5));
}else{
var dcBW=Math.max(0.20,1-tSq*0.80);
var dcBL=Math.min(2.50,1+tSq*1.50);
if(diff2>0){
dc1x=Math.max(1.00,(margin/(pA+pN))*dcBW);
dcx2=Math.min(6.00,(margin/(pN+pB))*dcBL);
dc12=margin/(pA+pB);
if(gmin>70&&absDiff2>=2)dc1x=Math.max(dc1x,1.00);
}else{
dcx2=Math.max(1.00,(margin/(pN+pB))*dcBW);
dc1x=Math.min(6.00,(margin/(pA+pN))*dcBL);
dc12=margin/(pA+pB);
if(gmin>70&&absDiff2>=2)dcx2=Math.max(dcx2,1.00);
}
}
}else{
dc1x=margin/(pA+pN);dc12=margin/(pA+pB);dcx2=margin/(pN+pB);
}
dc1x=+Math.max(1.01,dc1x).toFixed(2);
dc12=+Math.max(1.01,dc12).toFixed(2);
dcx2=+Math.max(1.01,dcx2).toFixed(2);
dc1xLk=live&&dc1x<=1.01;dc12Lk=live&&dc12<=1.01;dcx2Lk=live&&dcx2<=1.01;
var timeLeft;
if(m.dur)timeLeft=Math.max(0,m.dur-(m.el||0))/60;
else timeLeft=Math.max(0,90-gmin);
var avgRate=2.7/90;
var ou={};
[0.5,1.5,2.5,3.5,4.5].forEach(function(th){
var lam=avgRate*Math.max(0,timeLeft);
var pO=1-poisCDF(Math.max(0,Math.ceil(th-tot)-1),lam);
pO=_clampP(pO);
var k=String(th).replace('.','_');
ou['o'+k]=+Math.max(1.05,Math.min(margin/pO,18)).toFixed(2);
ou['u'+k]=+Math.max(1.05,Math.min(margin/(1-pO),18)).toFixed(2);
ou['lo'+k]=live&&tot>th;ou['lu'+k]=live&&tot>=th;
});
var pBY,pBN,bttsLk,bttsNLk;
if(live){
if(hs>0&&as_>0){pBY=0.99;pBN=0.01;}
else{var pS=1-Math.exp(-avgRate*Math.max(0,timeLeft)/2);pBY=pS;pBN=1-pS;}
}else{pBY=_clampP(base.pBTTS);pBN=1-pBY;}
bttsLk=live&&hs>0&&as_>0;bttsNLk=bttsLk;
var bttsY=+Math.max(1.05,Math.min(margin/Math.max(0.03,pBY),8)).toFixed(2);
var bttsN=+Math.max(1.05,Math.min(margin/Math.max(0.03,pBN),8)).toFixed(2);
var htH=+(1.8+rnd(0,1.1)).toFixed(2);
var htX=+(2.2+rnd(0,0.9)).toFixed(2);
var htA=+(2.8+rnd(0,1.8)).toFixed(2);
var htLk=live&&gmin>=45;
var sc={};
[[hs,as_],[hs+1,as_],[hs,as_+1],[hs+1,as_+1],[hs+2,as_],[hs,as_+2],
[hs+2,as_+1],[hs+1,as_+2],[hs+2,as_+2],[hs+3,as_],[hs,as_+3]].forEach(function(s){
var diff3=Math.abs(s[0]-hs)+Math.abs(s[1]-as_);
var p=Math.pow(0.4,diff3)*(0.13+rnd(0,0.08));
var k='sc_'+s[0]+'_'+s[1];
sc[k]=+_clampP(margin/p*5).toFixed(2);
if(sc[k]<1.05)sc[k]=1.05;
