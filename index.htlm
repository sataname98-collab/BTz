var FIFA_LGS=Object.keys(FIFA);
var VTEAMS=['Lions FC','Tigers SC','Eagles FC','Panthers SC','Wolves FC','Bears Utd','Storm City','Thunder FC','Falcons SC','Sharks FC','Dragons FC','Phoenix SC','Cobras SC','Bulls FC','Vipers FC','Aces Utd','Hawks FC','Rams SC','Owls FC','Foxes SC'];
var VTYPES=[
