function driftOdds(prev,m){
var nx=calcOdds(m);
var gmin=m.gmin||0;
var f=gmin<70?0.20:0.45;
var diff=m.hs-m.as,absDiff=Math.abs(diff);
var hMn,hMx,aMn,aMx,dMn,dMx;
if(m.status==='live'){
if(absDiff===0){hMn=1.30;hMx=9.0;aMn=1.30;aMx=9.0;dMn=2.40;dMx=7.5;}
else if(gmin>70){
if(diff>0){hMn=1.00;hMx=2.50;aMn=1.30;aMx=60;dMn=2.20;dMx=35;}
else{aMn=1.00;aMx=2.50;hMn=1.30;hMx=60;dMn=2.20;dMx=35;}
}else{
if(diff>0){hMn=1.10;hMx=3.50;aMn=1.30;aMx=25;dMn=2.50;dMx=15;}
else{aMn=1.10;aMx=3.50;hMn=1.30;hMx=25;dMn=2.50;dMx=15;}
}
}else{hMn=1.20;hMx=6.0;aMn=1.20;aMx=6.0;dMn=2.60;dMx=5.5;}
function blend(a,b,mn,mx){return+Math.max(mn,Math.min(mx,a*(1-f)+b*f+rnd(-0.003,0.003))).toFixed(2);}
return Object.assign({},nx,{
h:blend(prev.h,nx.h,hMn,hMx),
d:blend(prev.d,nx.d,dMn,dMx),
a:blend(prev.a,nx.a,aMn,aMx),
hLk:nx.hLk,aLk:nx.aLk,dLk:nx.dLk,
dc1xLk:nx.dc1xLk,dc12Lk:nx.dc12Lk,dcx2Lk:nx.dcx2Lk,
