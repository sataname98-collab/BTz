<!DOCTYPE html><html lang="fr"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no"><title>BETZONE — Paris Sportifs en Ligne</title><meta name="description" content="BETZONE — Plateforme de paris sportifs professionnelle. Football, Basketball, NFL, NHL, Jeux Virtuels. Cotes en temps réel."><meta name="theme-color" content="#06090F"><link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎯</text></svg>"><link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet"><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"><style> *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}:root{--bg0:#06090F;--bg1:#0C1220;--bg2:#111827;--bg3:#1A2340;--bg4:#1E2A48;--acc:#00E676;--acc2:rgba(0,230,118,.15);--acc3:rgba(0,230,118,.40);--acc4:rgba(0,230,118,.06);--gold:#FFB300;--gold2:rgba(255,179,0,.15);--gold3:rgba(255,179,0,.08);--red:#FF1744;--red2:rgba(255,23,68,.12);--blue:#2979FF;--blue2:rgba(41,121,255,.12);--purple:#BB86FC;--purple2:rgba(187,134,252,.12);--text:#F0F4FF;--text2:#8A94B2;--text3:#586280;--bdr:rgba(255,255,255,.06);--bdr2:rgba(255,255,255,.1);--r:12px;--r2:8px;--r3:20px;--sh:0 4px 24px rgba(0,0,0,.5);--sh2:0 8px 40px rgba(0,0,0,.7);--fh:'Bebas Neue',sans-serif;--fb:'Outfit',sans-serif;--el:cubic-bezier(0.34,1.56,0.64,1);--els:cubic-bezier(0.25,1.2,0.5,1);--elf:cubic-bezier(0.16,1,0.3,1)}html,body{height:100%;overflow:hidden;background:var(--bg0);font-family:var(--fb);color:var(--text);font-size:15px;-webkit-font-smoothing:antialiased;display:flex;align-items:center;justify-content:center}#app{width:100%;max-width:412px;height:100%;max-height:915px;background:var(--bg0);position:relative;overflow:hidden;display:flex;flex-direction:column}@media(min-width:500px){#app{border-radius:32px;border:1.5px solid rgba(255,255,255,.08);box-shadow:0 0 0 1px rgba(0,230,118,.05),0 0 80px rgba(0,230,118,.06),0 24px 80px rgba(0,0,0,.7);height:min(915px,98vh)}body{padding:12px;background:radial-gradient(ellipse at 30% 20%,rgba(0,230,118,.04) 0%,transparent 60%),radial-gradient(ellipse at 70% 80%,rgba(41,121,255,.04) 0%,transparent 60%),var(--bg0)}}@media(max-width:499px){#app{max-width:100%;max-height:100%;border-radius:0}}::-webkit-scrollbar{width:3px}::-webkit-scrollbar-thumb{background:linear-gradient(var(--acc),var(--blue));border-radius:4px}::-webkit-scrollbar-track{background:transparent}@keyframes fadeUp{from{opacity:0;transform:translateY(18px) scale(.93)}to{opacity:1;transform:none}}@keyframes fadeIn{from{opacity:0}to{opacity:1}}@keyframes slideIn{from{opacity:0;transform:translateX(32px)}to{opacity:1;transform:none}}@keyframes slideUp{from{opacity:0;transform:translateY(100%)}to{opacity:1;transform:translateY(0)}}@keyframes slideDown{from{opacity:0;transform:translateY(-20px)}to{opacity:1;transform:none}}@keyframes pop{0%{transform:scale(.4);opacity:0}60%{transform:scale(1.12)}82%{transform:scale(.96)}to{transform:scale(1);opacity:1}}@keyframes popIn{0%{transform:scale(.7) translateY(10px);opacity:0}70%{transform:scale(1.04)}to{transform:scale(1);opacity:1}}@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}@keyframes pulseScale{0%,100%{transform:scale(1)}50%{transform:scale(1.08)}}@keyframes pulseBorder{0%,100%{box-shadow:0 0 0 0 rgba(255,23,68,.5)}50%{box-shadow:0 0 0 4px rgba(255,23,68,0)}}@keyframes spin{to{transform:rotate(360deg)}}@keyframes spinSlow{to{transform:rotate(360deg)}}@keyframes bounce{0%{transform:scale(1)}28%{transform:scale(.85)}58%{transform:scale(1.1)}80%{transform:scale(.97)}to{transform:scale(1)}}@keyframes shimmer{0%{background-position:200% 0}to{background-position:-200% 0}}@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}@keyframes glow{0%,100%{box-shadow:0 0 10px var(--acc3)}50%{box-shadow:0 0 28px var(--acc3),0 0 50px rgba(0,230,118,.15)}}@keyframes glowRed{0%,100%{box-shadow:0 0 8px rgba(255,23,68,.3)}50%{box-shadow:0 0 22px rgba(255,23,68,.6)}}@keyframes glowGold{0%,100%{box-shadow:0 0 8px rgba(255,179,0,.3)}50%{box-shadow:0 0 22px rgba(255,179,0,.6)}}@keyframes liveRing{0%{transform:scale(.8);opacity:1}100%{transform:scale(2.2);opacity:0}}@keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}@keyframes flip{0%{transform:rotateY(0)}100%{transform:rotateY(360deg)}}@keyframes oddsUp{0%{background:rgba(0,230,118,.35);transform:scale(1.06)}40%{background:rgba(0,230,118,.2)}100%{background:transparent;transform:scale(1)}}@keyframes oddsDown{0%{background:rgba(255,23,68,.35);transform:scale(1.06)}40%{background:rgba(255,23,68,.18)}100%{background:transparent;transform:scale(1)}}@keyframes oddsPulse{0%,100%{opacity:1}50%{opacity:.5}}@keyframes countUp{0%{transform:translateY(8px);opacity:0}100%{transform:none;opacity:1}}@keyframes goalBurst{0%{transform:scale(1)}20%{transform:scale(1.15)}40%{transform:scale(.95)}60%{transform:scale(1.07)}80%{transform:scale(.98)}100%{transform:scale(1)}}@keyframes goalFlash{0%{background:rgba(255,179,0,.25);box-shadow:0 0 0 3px rgba(255,179,0,.4)}50%{background:rgba(255,179,0,.12);box-shadow:0 0 0 6px rgba(255,179,0,0)}100%{background:transparent;box-shadow:none}}@keyframes goalScore{0%{transform:translateY(-20px) scale(1.4);opacity:0;color:var(--gold)}50%{transform:translateY(4px) scale(1.1);opacity:1}100%{transform:none;opacity:1}}@keyframes confetti{0%{transform:translateY(-10px) rotate(0deg);opacity:1}100%{transform:translateY(60px) rotate(720deg);opacity:0}}@keyframes toastIn{0%{opacity:0;transform:translateX(60px) scale(.8)}60%{transform:translateX(-5px) scale(1.03)}100%{opacity:1;transform:none}}@keyframes toastOut{to{opacity:0;transform:translateX(60px) scale(.8)}}@keyframes ripple{0%{transform:scale(0);opacity:.6}100%{transform:scale(4);opacity:0}}@keyframes neonSweep{0%,100%{background-position:0% 50%}50%{background-position:100% 50%}}@keyframes scoreTick{0%{transform:translateY(0)}50%{transform:translateY(-100%)}51%{transform:translateY(100%)}100%{transform:translateY(0)}}.hdr{position:sticky;top:0;z-index:50;background:linear-gradient(180deg,rgba(12,18,32,.98) 0%,rgba(10,16,28,.96) 100%);border-bottom:1px solid rgba(255,255,255,.06);padding:10px 14px;display:flex;align-items:center;gap:8px;backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px)}.hdr::after{content:'';position:absolute;bottom:0;left:10%;right:10%;height:1px;background:linear-gradient(90deg,transparent,rgba(0,230,118,.15),transparent)}.logo{font-family:var(--fh);font-size:24px;letter-spacing:3px;background:linear-gradient(135deg,#00E676 0%,#69F0AE 40%,#FFB300 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;cursor:pointer;flex-shrink:0;transition:filter .3s;position:relative}.logo:hover{filter:brightness(1.25)}.logo::after{content:'';position:absolute;bottom:-2px;left:0;right:0;height:1.5px;background:linear-gradient(90deg,var(--acc),var(--gold));transform:scaleX(0);transition:transform .4s var(--el);transform-origin:left}.logo:hover::after{transform:scaleX(1)}.hbtn{width:32px;height:32px;border-radius:50%;border:1px solid var(--bdr);background:var(--bg2);color:var(--text2);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:12px;transition:all .3s var(--el);flex-shrink:0;position:relative;overflow:hidden}.hbtn:hover{background:var(--bg4);color:var(--acc);transform:scale(1.12);border-color:rgba(0,230,118,.3)}.hbtn::before{content:'';position:absolute;inset:0;border-radius:50%;background:radial-gradient(circle,rgba(0,230,118,.2),transparent);opacity:0;transition:opacity .3s}.hbtn:hover::before{opacity:1}.hbtn.spin i{animation:spin .7s linear infinite}.ldot{display:inline-block;width:7px;height:7px;background:var(--red);border-radius:50%;margin-right:4px;animation:pulse 1.2s ease-in-out infinite;vertical-align:middle;position:relative}.ldot::after{content:'';position:absolute;inset:-3px;border-radius:50%;border:1.5px solid var(--red);animation:liveRing 1.4s ease-out infinite}.ticker-wrap{background:linear-gradient(135deg,rgba(0,230,118,.08),rgba(41,121,255,.05));border-bottom:1px solid rgba(0,230,118,.1);padding:5px 0;overflow:hidden;flex-shrink:0;position:relative}.ticker-wrap::before,.ticker-wrap::after{content:'';position:absolute;top:0;bottom:0;width:28px;z-index:2}.ticker-wrap::before{left:0;background:linear-gradient(90deg,var(--bg0),transparent)}.ticker-wrap::after{right:0;background:linear-gradient(-90deg,var(--bg0),transparent)}.ticker{display:flex;gap:0;white-space:nowrap;animation:marquee 28s linear infinite}.ticker:hover{animation-play-state:paused}.tick-item{display:inline-flex;align-items:center;gap:6px;padding:0 18px;font-size:11px;font-weight:600;color:var(--text2)}.tick-item .tick-teams{color:var(--text);font-weight:700}.tick-item .tick-odd{color:var(--acc);font-size:12px;font-weight:800;background:var(--acc4);padding:1px 5px;border-radius:5px}.tick-item .tick-live{color:var(--red);font-size:10px;font-weight:700;display:flex;align-items:center;gap:2px}.tick-sep{color:var(--text3);opacity:.4;margin:0 6px}.snav{display:flex;gap:2px;padding:7px 10px;background:var(--bg1);border-bottom:1px solid var(--bdr);overflow-x:auto;scrollbar-width:none;position:relative}.snav::-webkit-scrollbar{display:none}.stab{display:flex;align-items:center;gap:5px;padding:6px 13px;border-radius:22px;border:none;background:transparent;color:var(--text2);font-family:var(--fb);font-size:12px;font-weight:500;cursor:pointer;white-space:nowrap;transition:all .3s var(--el);flex-shrink:0;position:relative;overflow:hidden}.stab::before{content:'';position:absolute;inset:0;border-radius:22px;background:var(--acc2);opacity:0;transform:scale(.7);transition:all .35s var(--el)}.stab:hover::before{opacity:.6;transform:scale(1)}.stab:hover{color:var(--text);transform:scale(1.06)}.stab.on{background:var(--acc2);color:var(--acc);font-weight:700;box-shadow:0 0 12px rgba(0,230,118,.15)}.stab.on::after{content:'';position:absolute;bottom:0;left:20%;right:20%;height:2px;background:var(--acc);border-radius:2px 2px 0 0}.stab.virt.on{background:var(--purple2);color:var(--purple);box-shadow:0 0 12px rgba(187,134,252,.15)}.stab.virt.on::after{background:var(--purple)}.stab.fv.on{background:rgba(255,87,34,.12);color:#FF7043;box-shadow:0 0 12px rgba(255,87,34,.15)}.stab.fv.on::after{background:#FF7043}.scnt{background:var(--bg4);color:var(--text3);font-size:10px;padding:1px 5px;border-radius:8px;font-weight:600;transition:all .3s}.stab.on .scnt{background:var(--acc);color:#000;animation:popIn .4s var(--el)}.subtabs{display:flex;gap:2px;padding:5px 10px;background:var(--bg1);border-bottom:1px solid var(--bdr)}.sub{flex:1;padding:7px 4px;border:none;background:transparent;color:var(--text3);font-family:var(--fb);font-size:12px;font-weight:500;cursor:pointer;border-radius:var(--r2);transition:all .3s var(--el);text-align:center;position:relative}.sub::after{content:'';position:absolute;bottom:0;left:20%;right:20%;height:2px;background:var(--acc);border-radius:2px;transform:scaleX(0);transition:transform .35s var(--el)}.sub:hover{color:var(--text2);background:var(--bg2);transform:scale(1.04)}.sub.on{color:var(--text);font-weight:600}.sub.on::after{transform:scaleX(1)}.bbdg{background:var(--gold);color:#000;font-size:10px;padding:1px 4px;border-radius:7px;font-weight:700;margin-left:3px;animation:pulseScale 1.5s ease-in-out infinite}.mwrap{flex:1;display:flex;overflow:hidden}.mlist{flex:1;overflow-y:auto;padding:10px;padding-bottom:90px;scroll-behavior:smooth}.mc{background:linear-gradient(145deg,var(--bg2),rgba(26,35,64,.8));border:1px solid var(--bdr);border-radius:var(--r);padding:12px;margin-bottom:8px;cursor:pointer;transition:all .35s var(--elf);animation:fadeUp .5s var(--els) both;position:relative;overflow:hidden}.mc::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.02),transparent);pointer-events:none}.mc::after{content:'';position:absolute;top:0;left:-100%;width:40%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.04),transparent);transition:left .6s;pointer-events:none}.mc:hover{background:linear-gradient(145deg,var(--bg3),rgba(30,42,72,.9));border-color:rgba(0,230,118,.18);transform:translateY(-2px) scale(1.008);box-shadow:0 8px 28px rgba(0,0,0,.4),0 0 0 1px rgba(0,230,118,.08)}.mc:hover::after{left:200%}.mc.live{border-left:3px solid var(--red);animation:fadeUp .5s var(--els) both}.mc.live::before{background:linear-gradient(135deg,rgba(255,23,68,.04),transparent)}.mc-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}.mc-time.live{color:var(--red);font-size:11px;font-weight:700;display:flex;align-items:center;gap:3px}.mc-time.upcoming{color:var(--text3);font-size:11px}.mc-time.fin{color:var(--blue);font-size:11px;font-weight:600}.mc-lg{font-size:10px;color:var(--text3);max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:flex;align-items:center;gap:3px}.mc-teams{display:flex;align-items:center;gap:8px;margin-bottom:10px}.tc{flex:1;min-width:0;display:flex;align-items:center;gap:6px}.tc.r{justify-content:flex-end;flex-direction:row-reverse}.tlogo{width:22px;height:22px;object-fit:contain;flex-shrink:0;transition:transform .3s var(--el)}.mc:hover .tlogo{transform:scale(1.12)}.tph{width:22px;height:22px;background:linear-gradient(135deg,var(--bg3),var(--bg4));border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:8px;color:var(--text3);font-weight:700;border:1px solid var(--bdr)}.tn{font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;transition:color .2s}.mc:hover .tn{color:var(--acc)}.sc{display:flex;align-items:center;gap:4px;font-family:var(--fh);font-size:26px;letter-spacing:3px;flex-shrink:0;position:relative}.sc.ns{font-size:13px;color:var(--text3);font-family:var(--fb);letter-spacing:0}.sc-sep{color:var(--text3);font-size:20px}.sc-n{min-width:22px;text-align:center;transition:all .3s;display:inline-block}.sc-n.scored{animation:goalScore .5s var(--el)}.odds-row{display:grid;grid-template-columns:repeat(3,1fr);gap:5px;margin-top:2px}.odds-row.c2{grid-template-columns:repeat(2,1fr)}.ob{padding:8px 4px;border:1px solid var(--bdr);border-radius:var(--r2);background:linear-gradient(145deg,var(--bg4),var(--bg3));text-align:center;cursor:pointer;transition:all .3s var(--el);position:relative;overflow:hidden;user-select:none}.ob::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.04),transparent);pointer-events:none;border-radius:var(--r2)}.ob:hover{border-color:rgba(0,230,118,.5);background:linear-gradient(145deg,rgba(0,230,118,.12),rgba(0,230,118,.06));transform:scale(1.07) translateY(-1px);box-shadow:0 4px 16px rgba(0,230,118,.15)}.ob:active{transform:scale(.88);transition-duration:.1s}.ob-ripple{position:absolute;border-radius:50%;background:rgba(0,230,118,.35);transform:scale(0);animation:ripple .5s linear;pointer-events:none}.ob.sel{background:linear-gradient(135deg,var(--acc),#00C853);border-color:var(--acc);animation:bounce .45s var(--el);box-shadow:0 0 18px var(--acc3),0 4px 12px rgba(0,230,118,.3)}.ob.sel .ol,.ob.sel .ov{color:#000}.ob.sel::after{content:'✓';position:absolute;top:2px;right:3px;font-size:8px;color:rgba(0,0,0,.5);font-weight:900}.ob.dis{opacity:.35;cursor:default;pointer-events:none}.ob.lk{opacity:.45;cursor:default;pointer-events:none;border-color:rgba(255,23,68,.25)!important;background:linear-gradient(145deg,rgba(255,23,68,.06),var(--bg3))!important}.ob.lk::after{content:'🔒';position:absolute;top:2px;right:3px;font-size:8px}.ob.up{animation:oddsUp .8s var(--elf);border-color:rgba(0,230,118,.4)}.ob.dn{animation:oddsDown .8s var(--elf);border-color:rgba(255,23,68,.3)}.ol{font-size:9px;color:var(--text3);di