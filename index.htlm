function parseESPN(ev,lg,sp,cfg){
var comp=ev.competitions&&ev.competitions[0];if(!comp)return null;
var hC=comp.competitors&&comp.competitors.find(function(c){return c.homeAway==='home';})||comp.competitors[0];
var aC=comp.competitors&&comp.competitors.find(function(c){return c.homeAway==='away';})||comp.competitors[1];
if(!hC||!aC)return null;
var st=comp.status,status='upcoming';
if(st&&st.type){if(st.type.state==='in')status='live';else if(st.type.state==='post')status='fin';}
var hs=parseInt(hC.score)||0,as=parseInt(aC.score)||0;
var gmin=0;if(st&&st.displayClock){gmin=parseInt(st.displayClock)||0;}
return{id:ev.id,lg:lg.n,lgId:lg.id,sport:sp,src:'ESPN',
home:hC.team?hC.team.displayName:'Home',away:aC.team?aC.team.displayName:'Away',
hl:hC.team&&hC.team.logo,al:aC.team&&aC.team.logo,
hs:hs,as:as,gmin:gmin,
min:st&&st.type?(st.type.shortDetail||''):'',
start:ev.date?new Date(ev.date).toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'}):'--:--',
status:status,
hcorn:0,acorn:0,hshots:0,ashots:0,hfouls:0,afouls:0};
}
var _vt=null;
function initVirt(){
if(!Object.keys(S.vmatches).length)genVirt();
syncV();
if(!_vt)_vt=setInterval(tickV,1000);
}
function genVirt(){
S.vmatches={};
VTYPES.forEach(function(tp,ti){
for(var i=0;i<2;i++){
var teams=shuf(VTEAMS);
var id='v_'+tp.id+'_'+i;
var el=i===0?ri(20,tp.dur-10):0;
var st=i===0?'live':'upcoming';
var hs=st==='live'?ri(0,3):0,as=st==='live'?ri(0,3):0;
var m={id:id,sport:'virtual',type:tp.id,tname:tp.n,icon:tp.icon,virtual:true,
dur:tp.dur,el:el,lg:tp.n,lgId:tp.id,
home:teams[0],away:teams[1],hs:hs,as:as,status:st,goals:[],
min:st==='live'?fmm(el):st==='fin'?'Terminé':'',
start:st==='upcoming'?'--:--':'LIVE',
hcorn:0,acorn:0,hshots:0,ashots:0,hfouls:0,afouls:0};
m.odds=calcOdds(m);
S.vmatches[id]=m;
}
});
}
function syncV(){S.cache['virtual']={ms:Object.values(S.vmatches),ts:Date.now(),src:['Virtuel']};}
function tickV(){
S.tick++;var ch=false;
Object.values(S.vmatches).forEach(function(m){
if(m.status==='live'){
m.el++;m.min=fmm(m.el,m.dur);
if(rng()<2.5/m.dur){
var sc=rng()<0.52?'home':'away';
if(sc==='home')m.hs++;else m.as++;
m.goals.push({t:m.el,sc:sc});
m.odds=calcOdds(m);ch=true;
}else if(S.tick%3===0){m.odds=driftOdds(m.odds,m);}
if(rng()<10/m.dur){if(rng()<0.55)m.hcorn++;else m.acorn++;}
if(rng()<12/m.dur){if(rng()<0.55)m.hshots++;else m.ashots++;}
if(m.el>=m.dur){m.status='fin';m.min='Terminé';m.odds=calcOdds(m);ch=true;settleBets();setTimeout(function(){restartV(m);},ri(12000,22000));}
}
if(m.status==='upcoming'&&rng()<0.003){m.status='live';m.el=0;ch=true;}
});
if(ch||S.tick%5===0){syncV();if(S.sport==='virtual')renderList();}
}
function restartV(m){
var teams=shuf(VTEAMS);m.home=teams[0];m.away=teams[1];
m.hs=0;m.as=0;m.el=0;m.goals=[];m.hcorn=0;m.acorn=0;m.hshots=0;m.ashots=0;
m.status='upcoming';m.min='';
m.odds=calcOdds(m);syncV();if(S.sport==='virtual')renderList();
setTimeout(function(){m.status='live';m.el=0;m.min='0:00';m.odds=calcOdds(m);syncV();if(S.sport==='virtual')renderList();},ri(6000,16000));
}
