setInterval(function(){
if(document.getElementById('mktMo').classList.contains('open')&&S.openMktId){
var m=findM(S.openMktId);
if(m&&m.status==='live'){renderMktBar(m);renderMktBody(m);}
}
},4000);
var SLIP_CFG={
MAX_SEL       :20,
MIN_ODD       :1.01,
MAX_ODD       :1000.0,
MIN_STAKE     :0.50,
MAX_STAKE_REAL:5000
};
function genTicketId(){
var now=new Date();
var pad=function(n,l){return String(n).padStart(l||2,'0');};
var dt =now.getFullYear()
+pad(now.getMonth()+1)
+pad(now.getDate())
+'-'
+pad(now.getHours())
+pad(now.getMinutes())
+pad(now.getSeconds());
var suffix=pad(Math.floor(Math.random()*1000),3);
return 'BET-'+dt+'-'+suffix;
}
function validateOdd(odd){
if(typeof odd !=='number'||isNaN(odd)){
toast('Cote invalide','err');return false;
}
if(odd<=0){
toast('Cote invalide(<=0)','err');return false;
}
if(odd>SLIP_CFG.MAX_ODD){
toast('Cote trop haute(max '+SLIP_CFG.MAX_ODD+')','err');return false;
}
return true;
}
function validateStake(stake,balance){
if(!stake||stake<=0){
toast('Entrez une mise','err');return false;
}
if(stake<SLIP_CFG.MIN_STAKE){
toast('Mise minimum:$'+SLIP_CFG.MIN_STAKE,'err');return false;
}
if(S.activeAcc==='real'&&stake>SLIP_CFG.MAX_STAKE_REAL){
toast('Mise maximum(réel):$'+SLIP_CFG.MAX_STAKE_REAL,'err');return false;
}
if(stake>balance){
toast('Solde insuffisant($'+fo(balance)+')','err');return false;
}
return true;
}
function totalOdds(){
if(!S.slip.length)return 0;
return Math.round(S.slip.reduce(function(a,b){return a*b.odd;},1)*100)/100;
}
function potentialWin(stake){
if(S.mode==='single'){
return Math.round(S.slip.reduce(function(a,b){return a+stake*b.odd;},0)*100)/100;
}
return Math.round(totalOdds()*stake*100)/100;
}
function netProfit(stake){
if(S.mode==='single'){
var totalStaked=stake*S.slip.length;
return Math.round((potentialWin(stake)-totalStaked)*100)/100;
}
return Math.round((potentialWin(stake)-stake)*100)/100;
}
function singlesSummary(stakePerBet){
return S.slip.map(function(s){
var gain  =Math.round(s.odd*stakePerBet*100)/100;
var profit=Math.round((s.odd-1)*stakePerBet*100)/100;
return{sel:s,gain:gain,profit:profit,mise:stakePerBet};
});
}
function renderSlip(){
var el=document.getElementById('bslip-inner');if(!el)return;
var sl=S.slip;
var stake=parseFloat(S.stake)||0;
var curBal=getActiveBal();
var tOdds =totalOdds();
var pGain =stake>0?potentialWin(stake):0;
var pProfit=stake>0?netProfit(stake):0;
var head='<div class="shead">'
+'<span class="sttl">COUPON</span>'
+(sl.length?'<span class="sbdg">'+sl.length+'</span>':'')
+'<span style="font-size:10px;color:var(--text3);margin-left:auto;margin-right:6px">max '+SLIP_CFG.MAX_SEL+'</span>'
+'</div>';
var mode=sl.length>1
?'<div class="smode">'
+'<button class="smbtn'+(S.mode==='single'?' on':'')+'" data-bm="single">⚽ Simple</button>'
+'<button class="smbtn'+(S.mode==='combi'?' on':'')+'" data-bm="combi">🔗 Combiné</button>'
+'</div>'
:'';
var items;
if(!sl.length){
items='<div class="sempty"><i class="fas fa-ticket-alt"></i><p>Aucune sélection</p><p style="font-size:11px;margin-top:4px">Cliquez sur une cote pour l\'ajouter</p></div>';
}else{
var showSingleGains=S.mode==='single'&&stake>0;
var summ=showSingleGains?singlesSummary(stake):null;
items='<div class="sitems">'
+sl.map(function(b,i){
var indGain=summ?summ[i]:null;
return '<div class="si" style="animation-delay:'+i*0.04+'s">'
+'<div class="si-top">'
+'<div style="flex:1;min-width:0">'
+'<div class="si-m">'+esc(b.ml)+'</div>'
+(b.addedAt?'<div style="font-size:9px;color:var(--text3);margin-top:1px">'+esc(new Date(b.addedAt).toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'}))+'</div>':'')
+'</div>'
+'<button class="si-rm" data-rm="'+i+'"><i class="fas fa-times"></i></button>'
+'</div>'
+'<span class="si-sel">'+esc(b.lbl)+'</span>'
+'<div style="display:flex;justify-content:space-between;align-items:center;margin-top:3px">'
+'<span class="si-odd">@ '+fo(b.odd)+'</span>'
+(indGain?'<span style="font-size:11px;font-weight:700;color:var(--gold)">→ $'+fo(indGain.gain)+'</span>':'')
+'</div>'
+'</div>';
}).join('')
+'</div>';
}
var foot='';
if(sl.length){
var qstakesBtns=[5,10,25,50,100].map(function(v){
return '<button class="qs" data-qs="'+v+'">$'+v+'</button>';
}).join('');
var extraStakes=''
+'<button class="qs" style="background:rgba(0,230,118,.1);border-color:rgba(0,230,118,.3);color:var(--acc)" data-qs-frac="1">MAX</button>'
+'<button class="qs" data-qs-frac="0.5">½</button>'
+'<button class="qs" data-qs-frac="0.25">¼</button>';
var gainBlock;
if(S.mode==='combi'&&sl.length>1){
gainBlock='<div class="gain-row">'
+'<div>'
+'<span class="gain-lbl">Gain potentiel</span>'
+'<br><span class="ptot">Cote combinée:<strong style="color:var(--acc)">'+fo(tOdds)+'</strong></span>'
+'</div>'
+'<div style="text-align:right">'
+'<span class="gain-val'+(stake>0?' active':'')+'">$'+fo(Math.round(pGain))+'</span>'
+(stake>0?'<br><span style="font-size:10px;color:var(--acc);font-weight:600">+$'+fo(Math.round(pProfit))+' profit</span>':'')
+'</div>'
+'</div>';
}else if(S.mode==='single'&&sl.length>1){
var totalMise=stake*sl.length;
gainBlock='<div class="gain-row">'
+'<div>'
+'<span class="gain-lbl">Si tout gagne</span>'
+(stake>0?'<br><span class="ptot">Mise totale:$'+fo(totalMise)+'</span>':'')
+'</div>'
+'<div style="text-align:right">'
+'<span class="gain-val'+(stake>0?' active':'')+'">$'+fo(Math.round(pGain))+'</span>'
+(stake>0&&pProfit>0?'<br><span style="font-size:10px;color:var(--acc);font-weight:600">+$'+fo(Math.round(pProfit))+' profit</span>':'')
+'</div>'
+'</div>';
}else{
gainBlock='<div class="gain-row">'
+'<div>'
+'<span class="gain-lbl">Gain potentiel</span>'
+(stake>0?'<br><span class="ptot">Profit net:+$'+fo(Math.round(pProfit))+'</span>':'')
+'</div>'
+'<span class="gain-val'+(stake>0?' active':'')+'">$'+fo(Math.round(pGain))+'</span>'
+'</div>';
}
var stakeOk  =stake>=SLIP_CFG.MIN_STAKE;
var balanceOk=stake<=curBal;
var maxOk    =S.activeAcc==='real'?stake<=SLIP_CFG.MAX_STAKE_REAL:true;
var canPlace =stakeOk&&balanceOk&&maxOk&&sl.length>0;
var hintMsg='';
if(!AUTH.user)         hintMsg='⚠ Connectez-vous pour parier';
else if(!sl.length)    hintMsg='⚠ Ajoutez des sélections';
else if(stake<=0)    hintMsg='⚠ Entrez une mise';
else if(!stakeOk)      hintMsg='⚠ Mise min:$'+SLIP_CFG.MIN_STAKE;
else if(!balanceOk)    hintMsg='⚠ Solde insuffisant($'+fo(curBal)+')';
else if(!maxOk)        hintMsg='⚠ Max $'+SLIP_CFG.MAX_STAKE_REAL+'(réel)';
foot='<div class="sfoot">'
+'<div class="stake-row">'
+'<span class="stake-lbl">Mise<span style="color:var(--acc);font-weight:700">$'+fmt(curBal)+'</span></span>'
+'<input class="stake-inp" id="stkinp" type="number" min="'+SLIP_CFG.MIN_STAKE+'" step="0.5" value="'+(stake||'')+'" placeholder="0.50">'
+'</div>'
+'<div class="qstakes">'+qstakesBtns+extraStakes+'</div>'
+gainBlock
+(hintMsg?'<div style="font-size:11px;color:var(--red);text-align:center;margin-bottom:6px;font-weight:600">'+hintMsg+'</div>':'')
+'<button class="pbtn" style="'+(canPlace?'':'opacity:.5')+'" onclick="placeBet()">🎯 Placer le pari</button>'
+'<button class="cbtn" onclick="clearSlip()">🗑 Vider le coupon</button>'
+'</div>';
}
el.innerHTML=head+mode+items+foot;
}
function renderAllSlips(){
renderSlip();
var b=document.getElementById('bbdg');
if(b){b.textContent=S.slip.length;b.style.display=S.slip.length?'flex':'none';}
}
function toggleBet(mid,t,lbl,odd){
if(!validateOdd(odd))return;
var m=findM(mid);
if(!m)return;
var existingIdx=S.slip.findIndex(function(b){return b.mid===mid;});
if(existingIdx>=0){
var existing=S.slip[existingIdx];
if(existing.t===t){
S.slip.splice(existingIdx,1);
if(S.slip.length<2)S.mode='single';
renderList();
renderAllSlips();
return;
}
toast(
'⛔ '+esc(existing.ml)+'\n'+
'"'+esc(existing.lbl)+'" est déjà dans ton coupon.',
'err'
);
return;
}
if(S.slip.length>=SLIP_CFG.MAX_SEL){
toast('Maximum '+SLIP_CFG.MAX_SEL+' sélections atteint','err');
return;
}
S.slip.push({
mid    :mid,
t      :t,
lbl    :lbl,
odd    :parseFloat(odd),
ml     :m.home+' vs '+m.away,
sport  :m.sport,
addedAt:Date.now()
});
renderList();
renderAllSlips();
}
function rmBet(i){
S.slip.splice(i,1);
if(S.slip.length<2)S.mode='single';
renderList();
renderAllSlips();
}
function clearSlip(){
S.slip =[];
S.stake=0;
S.mode ='single';
renderList();
renderAllSlips();
}
function setStake(v){
S.stake=parseFloat(v)||0;
renderAllSlips();
}
function setStakeFrac(frac){
var bal =getActiveBal();
var maxS=S.activeAcc==='real'?Math.min(bal,SLIP_CFG.MAX_STAKE_REAL):bal;
var raw =maxS*frac;
S.stake =Math.round(raw*100)/100;
var inp =document.getElementById('stkinp');
if(inp)inp.value=S.stake;
renderAllSlips();
}
function setMode(m){
S.mode=m;
renderAllSlips();
}
function placeBet(){
if(!AUTH.user){
var guest={accountNum:'GUEST-'+Date.now(),first:'Joueur',last:'',email:'',
virtBal:VIRT_START,realBal:0,activeAcc:'virt',hist:[],
createdAt:new Date().toLocaleDateString('fr-FR')};
AUTH.user=guest;S.virtBal=VIRT_START;S.realBal=0;S.activeAcc='virt';
authSaveUser(guest);updBal();
toast('👤 Compte créé — $'+VIRT_START+' virtuel offert','ok');
}
if(!S.slip.length){toast('⚠ Ajoute des selections!','err');return;}
var stake=parseFloat(S.stake)||0;
var bal  =getActiveBal();
if(stake<=0){
stake=SLIP_CFG.MIN_STAKE;S.stake=stake;
var inp=document.getElementById('stkinp');
if(inp)inp.value=stake;
}
if(stake<SLIP_CFG.MIN_STAKE){toast('⚠ Mise minimum:$'+SLIP_CFG.MIN_STAKE,'err');return;}
if(stake>bal){toast('⚠ Solde insuffisant — disponible:$'+fo(bal),'err');return;}
if(S.activeAcc==='real'&&stake>SLIP_CFG.MAX_STAKE_REAL){
toast('⚠ Mise max(réel):$'+SLIP_CFG.MAX_STAKE_REAL,'err');return;
}
for(var i=0;i<S.slip.length;i++){if(!validateOdd(S.slip[i].odd))return;}
var seen={};
S.slip=S.slip.filter(function(b){
if(seen[b.mid])return false;seen[b.mid]=true;return true;
});
if(!S.slip.length){toast('⚠ Panier vide!','err');return;}
var isSingle=S.mode==='single'||S.slip.length===1;
var tOdds=totalOdds();
var pGain=potentialWin(stake);
var pNet=netProfit(stake);
var ticketId=genTicketId();
var totalDeduc=isSingle?stake*S.slip.length:stake;
if(totalDeduc>bal){
stake=Math.floor((bal/(isSingle?S.slip.length:1))*100)/100;
totalDeduc=isSingle?stake*S.slip.length:stake;
pGain=potentialWin(stake);pNet=netProfit(stake);
toast('Mise ajustée à $'+fo(stake),'inf');
}
deductBal(totalDeduc);
var ticket={
id:ticketId,betNum:ticketId,
btype:isSingle?'single':'combi',
acc:S.activeAcc,
sels:S.slip.map(function(s){
return{mid:s.mid,t:s.t,lbl:s.lbl,odd:s.odd,ml:s.ml,
sport:s.sport,addedAt:s.addedAt,
settled:false,won:null,reason:null,score:null};
}),
stake:stake,totalStake:totalDeduc,
totalOdds:isSingle?null:tOdds,
gain:Math.round(pGain*100)/100,
profit:Math.round(pNet*100)/100,
status:'pending',
date:new Date().toLocaleString('fr-FR'),
placedAt:Date.now()
};
S.hist.unshift(ticket);
S.slip=[];S.stake=0;S.mode='single';
updBal();renderList();renderAllSlips();renderSub();
dbSave();authPersist();
trackEvent('bet_placed',{id:ticketId,stake:totalDeduc,odds:+tOdds.toFixed(2),mode:ticket.btype});
checkBroke();
if(isSingle&&ticket.sels.length>1){
toast('✅ '+ticket.sels.length+' paris placés | Gain:$'+fo(pGain),'ok');
}else{
toast('🎯 '+ticketId+' | Gain possible:$'+fo(pGain),'ok');
}
var fs=ticket.sels.find(function(sel){return !!S.fmatches[sel.mid];});
if(fs){
var fm=S.fmatches[fs.mid];
if(fm){
if(fm.status==='live')setTimeout(function(){openFlp(fs.mid,ticket);},400);
else if(fm.status==='upcoming'){
fm.status='live';fm.el=0;fm.gmin=0;fm.min="0'";fm.hs=0;fm.as=0;
fm.goals=[];fm.htDone=false;fm.odds=calcFifaOdds(fm);syncF();
setTimeout(function(){openFlp(fs.mid,ticket);},400);
}
}
}
}
var _flpInterval =null;
var _flpMatchId  =null;
var _flpTicket   =null;
function openFlp(matchId,ticket){
var m=S.fmatches[matchId];
if(!m)return;
_flpMatchId=matchId;
_flpTicket =ticket;
document.getElementById('flpHN').textContent =m.home;
document.getElementById('flpAN').textContent =m.away;
document.getElementById('flpHL').src         =m.hl||'';
document.getElementById('flpAL').src         =m.al||'';
document.getElementById('flpHS').textContent =m.hs||0;
document.getElementById('flpAS').textContent =m.as||0;
document.getElementById('flpMin').textContent=m.min||"0'";
document.getElementById('flpProg').style.width=(m.gmin||0)/90*100+'%';
document.getElementById('flpEvents').innerHTML='';
document.getElementById('flpResult').style.display='none';
var stakeInfo=ticket
?'<strong style="color:#38bdf8">🎯 Pari en jeu</strong><br>'
+ticket.sels.map(function(s){return '• '+s.lbl+' @ '+fo(s.odd);}).join('<br>')
+'<br><span style="color:var(--gold)">Gain potentiel:$'+fo(ticket.gain)+'</span>'
:'';
document.getElementById('flpStakeInfo').innerHTML=stakeInfo;
document.getElementById('flpOv').classList.add('open');
document.getElementById('flpPanel').classList.add('open');
clearInterval(_flpInterval);
_flpInterval=setInterval(function(){_flpTick();},1000);
}
function closeFlp(){
clearInterval(_flpInterval);
_flpInterval=null;
document.getElementById('flpOv').classList.remove('open');
document.getElementById('flpPanel').classList.remove('open');
}
function _flpTick(){
var m=_flpMatchId?S.fmatches[_flpMatchId]:null;
if(!m){clearInterval(_flpInterval);return;}
var prevHS=parseInt(document.getElementById('flpHS').textContent)||0;
var prevAS=parseInt(document.getElementById('flpAS').textContent)||0;
document.getElementById('flpMin').textContent =m.min||m.gmin+"'";
document.getElementById('flpProg').style.width=Math.min(100,(m.gmin||0)/90*100)+'%';
if(m.hs>prevHS){
document.getElementById('flpHS').textContent=m.hs;
_flpGoalAnim('flpHS');
_flpAddEvent('goal','⚽ BUT! '+m.home+' '+m.hs+'-'+m.as+' '+m.away+'('+m.min+')');
}
if(m.as>prevAS){
document.getElementById('flpAS').textContent=m.as;
_flpGoalAnim('flpAS');
_flpAddEvent('goal','⚽ BUT! '+m.away+' '+m.hs+'-'+m.as+' '+m.away+'('+m.min+')');
}
if(m.status==='fin'){
clearInterval(_flpInterval);
_flpInterval=null;
document.getElementById('flpMin').textContent="90' FT";
setTimeout(function(){
_flpShowResult(m);
},800);
}
}
function _flpGoalAnim(elId){
var el=document.getElementById(elId);
if(!el)return;
el.classList.remove('goal');
void el.offsetWidth;
el.classList.add('goal');
setTimeout(function(){el.classList.remove('goal');},600);
var panel=document.getElementById('flpPanel');
panel.style.boxShadow='0 0 0 2px rgba(34,197,94,.6),0-12px 48px rgba(0,0,0,.7)';
setTimeout(function(){panel.style.boxShadow='';},600);
}
function _flpAddEvent(type,text){
var feed=document.getElementById('flpEvents');
var el=document.createElement('div');
el.className='flp-evt '+type;
el.textContent=text;
feed.insertBefore(el,feed.firstChild);
while(feed.children.length>8)feed.removeChild(feed.lastChild);
}
function _flpShowResult(m){
if(!_flpTicket)return;
var resultEl=document.getElementById('flpResult');
var won=true;
_flpTicket.sels.forEach(function(sel){
var r=evalSel(sel,m);
if(!r.w)won=false;
});
var diff=m.hs-m.as;
var cls =won?'win':'loss';
var icon=won?'🏆':'😞';
var msg =won
?icon+' GAGNÉ!<strong>+$'+fo(_flpTicket.gain)+'</strong>crédité!'
:icon+' Perdu. Score final:'+m.home+' '+m.hs+'-'+m.as+' '+m.away;
if(!won&&diff===0){cls='draw';msg='⚖️ Match nul. '+m.home+' '+m.hs+'-'+m.as+' '+m.away;}
resultEl.className ='flp-result '+cls;
resultEl.innerHTML =msg;
resultEl.style.display='block';
_flpAddEvent(won?'goal':'ko',won?'✅ Pari gagné!':'❌ Pari perdu');
}
function selSport(id){
S.sport=id;renderNav();renderSub();renderList();
var cfg=SCFG[id];
if(cfg&&cfg.virtual){if(id==='virtual')initVirt();else initFifa();return;}
var c=S.cache[id];
var hasLive=c&&c.ms&&c.ms.some(function(m){return m.status==='live';});
var ttl=hasLive?60000:5*60*1000;
if(!c||Date.now()-c.ts>ttl)fetchSport(id);
}
function selTab(id){S.tab=id;renderSub();renderList();}
function updBal(){
renderAccHeader();
renderAccSwitcher();
renderUBadge();
animateBal();
updatePromoBanner();
buildTicker();
}
