};
var _selCrypto='USDT';
function openDeposit(){
var isVirt=S.activeAcc==='virt';
document.getElementById('depTitle').textContent=isVirt?'Dépôt Virtuel':'💳 Dépôt Réel — Crypto';
if(isVirt){
var remaining=0;
document.getElementById('depBody').innerHTML=
'<div style="text-align:center;margin-bottom:12px">'
+'<div style="font-size:11px;color:var(--text2)">Solde virtuel</div>'
+'<div style="font-size:22px;font-weight:700;color:var(--acc)">$'+fo(S.virtBal)+'</div>'
+'<div style="width:100%;height:6px;background:var(--bg4);border-radius:3px;margin:6px 0;overflow:hidden"><div style="height:100%;width:'+100+'%;background:linear-gradient(90deg,var(--acc),var(--gold));border-radius:3px"></div></div>'
+(remaining>0?'<div style="font-size:11px;color:var(--text3)">Jusqu\'à<strong style="color:var(--acc)">$'+fo(remaining)+'</strong>disponible</div>':'<div style="font-size:11px;color:var(--gold)">⚠️ Plafond atteint</div>')
+'</div>'
+(remaining>0?'<div class="dep-grid">'+[10,25,50,Math.min(100,remaining),Math.min(200,remaining)].filter(function(v,i,a){return v>0&&v<=remaining&&a.indexOf(v)===i;}).map(function(v){return'<button class="dep-btn" data-dep="virt:'+v+'" style="background:var(--acc2);border-color:rgba(0,230,118,.2);color:var(--acc)">+$'+v+'</button>';}).join('')+'</div>':'')
+'<p style="text-align:center;font-size:10px;color:var(--text3);margin-top:8px">Argent de jeu 100% virtuel — sans risque</p>';
}else{
renderCryptoDeposit();
}
document.getElementById('depMo').classList.add('open');
}
function renderCryptoDeposit(){
var cr=CRYPTO_ADDRS[_selCrypto];
var cryptoTabs=Object.keys(CRYPTO_ADDRS).map(function(k){
var cc=CRYPTO_ADDRS[k];
return'<button class="cr-sel-btn" data-cr="'+k+'" style="padding:5px 10px;border-radius:8px;border:1px solid '+(k===_selCrypto?cc.color:'rgba(255,255,255,.08)')+';background:'+(k===_selCrypto?'rgba(255,255,255,.05)':'transparent')+';color:'+(k===_selCrypto?cc.color:'var(--text3)')+';font-size:11px;font-weight:700;cursor:pointer;white-space:nowrap">'+cc.icon+' '+k+'</button>';
}).join('');
document.getElementById('depBody').innerHTML=
'<div style="background:rgba(0,230,118,.06);border:1px solid rgba(0,230,118,.15);border-radius:var(--r);padding:10px 12px;margin-bottom:12px;font-size:11px;color:var(--text2)">'
+'<strong style="color:var(--acc)">✅ Dépôt minimum:$5 USD</strong><br>Envoyez exactement le montant souhaité à l\'adresse ci-dessous. Votre compte sera crédité automatiquement après confirmation.</div>'
+'<div style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:12px">'+cryptoTabs+'</div>'
+'<div style="background:var(--bg2);border:1px solid rgba(255,255,255,.08);border-radius:var(--r);padding:12px;margin-bottom:10px">'
+'<div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">'
+'<span style="font-size:22px;color:'+cr.color+'">'+cr.icon+'</span>'
+'<div><div style="font-weight:700;font-size:14px">'+cr.name+'</div><div style="font-size:11px;color:var(--text3)">Réseau:'+(cr.name.includes('TRC20')||cr.name==='TRON'?'TRC20':'Natif')+'</div></div></div>'
+'<div style="font-size:10px;color:var(--text3);margin-bottom:4px;font-weight:600">ADRESSE DE DÉPÔT</div>'
+'<div style="background:var(--bg4);border:1px solid rgba(255,255,255,.06);border-radius:var(--r2);padding:10px;word-break:break-all;font-family:monospace;font-size:11px;color:var(--text);letter-spacing:.3px;margin-bottom:6px">'+cr.addr+'</div>'
+'<button id="copyAddrBtn" style="width:100%;padding:8px;border:1px solid rgba(0,230,118,.25);border-radius:var(--r2);background:rgba(0,230,118,.08);color:var(--acc);font-family:var(--fb);font-size:12px;font-weight:600;cursor:pointer"><i class="fas fa-copy"></i>Copier l\'adresse</button>'
+'</div>'
+'<div style="background:var(--gold2);border:1px solid rgba(255,179,0,.2);border-radius:var(--r2);padding:9px 11px;font-size:10px;color:var(--gold);margin-bottom:10px">'
+'⚠️ Envoyez uniquement<strong>'+_selCrypto+'</strong>à cette adresse. Tout autre token sera perdu définitivement.</div>'
+'<div style="font-size:12px;color:var(--text2);font-weight:600;margin-bottom:6px">J\'ai effectué le virement — indiquer le montant envoyé($)</div>'
+'<input id="depConfirmAmt" type="number" min="5" placeholder="Ex:50" style="width:100%;padding:10px 12px;border:1px solid rgba(41,121,255,.25);border-radius:var(--r2);background:var(--bg4);color:var(--text);font-family:var(--fb);font-size:15px;font-weight:600;outline:none;text-align:center;margin-bottom:8px">'
+'<button id="depSubmitBtn" style="width:100%;padding:11px;border:none;border-radius:var(--r);background:linear-gradient(135deg,var(--blue),#1565C0);color:#fff;font-family:var(--fb);font-size:14px;font-weight:700;cursor:pointer"><i class="fas fa-paper-plane"></i>Soumettre ma demande</button>'
+'<p style="text-align:center;font-size:10px;color:var(--text3);margin-top:8px">Votre compte sera crédité après vérification(1–30 min)<br><span style="color:rgba(255,255,255,.3)">🔒 Transactions sécurisées • 18+uniquement</span></p>';
}
function _copyAddr(){
var addr=CRYPTO_ADDRS[_selCrypto].addr;
if(navigator.clipboard)navigator.clipboard.writeText(addr).then(function(){toast('Adresse copiée!','ok');});
else{var t=document.createElement('textarea');t.value=addr;document.body.appendChild(t);t.select();document.execCommand('copy');t.remove();toast('Adresse copiée!','ok');}
}
function _submitDepositReq(){
var amt=parseFloat(document.getElementById('depConfirmAmt').value)||0;
if(amt<5){toast('Minimum $5 USD','err');return;}
if(!AUTH.user){toast('Connexion requise','err');return;}
var u=AUTH.user;
if(!u.depRequests)u.depRequests=[];
var req={id:Date.now(),crypto:_selCrypto,amt:amt,status:'pending',date:new Date().toLocaleString('fr-FR'),addr:CRYPTO_ADDRS[_selCrypto].addr};
u.depRequests.push(req);
authPersist();
document.getElementById('depMo').classList.remove('open');
toast('Demande envoyée! Crédit sous 30 min ⏳','ok');
trackEvent('deposit_request',{amount:amt,crypto:_selCrypto,user:u.accountNum});
}
function deposit(raw){
var parts=String(raw).split(':');
var type=parts[0],amount=parseFloat(parts[1])||0;
if(type==='virt'){S.virtBal=S.virtBal+amount;}
else{S.realBal+=amount;}
updBal();dbSave();authPersist();
document.getElementById('depMo').classList.remove('open');
toast('+$'+fo(amount)+' '+esc(type==='virt'?'virtuel':'réel'),'ok');
trackEvent('deposit',{amount:amount,type:type});
}
function _closeWithdrawMo(){var mo=document.getElementById('withdrawMo');if(mo)mo.remove();}
function openWithdraw(){
if(!AUTH.user){toast('Connexion requise','err');return;}
if(S.realBal<30){toast('Minimum de retrait:$30','err');return;}
var old2=document.getElementById('withdrawMo');if(old2)old2.remove();
var mo=document.createElement('div');
mo.id='withdrawMo';
mo.style.cssText='position:absolute;inset:0;z-index:500;background:rgba(0,0,0,.8);display:flex;align-items:flex-end;justify-content:center;padding:16px';
var cr=CRYPTO_ADDRS;
var cryptoOpts=Object.keys(cr).map(function(k){return'<option value="'+k+'">'+cr[k].icon+' '+cr[k].name+'</option>';}).join('');
mo.innerHTML='<div style="background:var(--bg1);border-radius:18px 18px 0 0;width:100%;max-width:412px;padding:20px;padding-bottom:34px">'
+'<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">'
+'<div style="font-family:var(--fh);font-size:20px;letter-spacing:1px;color:var(--gold)">💸 RETRAIT</div>'
+'<button onclick="_closeWithdrawMo()" style="background:none;border:none;color:var(--text3);font-size:20px;cursor:pointer">✕</button>'
+'</div>'
+'<div style="background:var(--gold2);border:1px solid rgba(255,179,0,.2);border-radius:var(--r);padding:10px 12px;margin-bottom:12px;font-size:11px;color:var(--gold)">'
+'⚠️<strong>Minimum de retrait:$30</strong><br>Les retraits sont traités manuellement sous 24h après approbation du propriétaire.</div>'
+'<div style="font-size:12px;color:var(--text2);font-weight:600;margin-bottom:4px">Solde disponible</div>'
+'<div style="font-size:22px;font-weight:800;color:var(--blue);margin-bottom:12px">$'+fo(S.realBal)+'</div>'
+'<div style="font-size:12px;color:var(--text2);font-weight:600;margin-bottom:4px">Montant à retirer($)</div>'
+'<input id="wdAmt" type="number" min="30" max="'+fo(S.realBal)+'" placeholder="Min. $30" style="width:100%;padding:10px 12px;border:1px solid rgba(255,179,0,.25);border-radius:var(--r2);background:var(--bg4);color:var(--text);font-family:var(--fb);font-size:15px;font-weight:600;outline:none;text-align:center;margin-bottom:10px">'
+'<div style="font-size:12px;color:var(--text2);font-weight:600;margin-bottom:4px">Crypto de réception</div>'
+'<select id="wdCrypto" style="width:100%;padding:10px 12px;border:1px solid rgba(255,255,255,.08);border-radius:var(--r2);background:var(--bg4);color:var(--text);font-family:var(--fb);font-size:13px;outline:none;margin-bottom:10px">'+cryptoOpts+'</select>'
+'<div style="font-size:12px;color:var(--text2);font-weight:600;margin-bottom:4px">Votre adresse '+Object.keys(cr)[0]+' de destination</div>'
+'<input id="wdAddr" type="text" placeholder="Adresse wallet" style="width:100%;padding:10px 12px;border:1px solid rgba(255,255,255,.08);border-radius:var(--r2);background:var(--bg4);color:var(--text);font-family:var(--fb);font-size:12px;outline:none;margin-bottom:12px">'
+'<button id="wdSubmitBtn" style="width:100%;padding:12px;border:none;border-radius:var(--r);background:linear-gradient(135deg,var(--gold),#E65100);color:#000;font-family:var(--fb);font-size:14px;font-weight:800;cursor:pointer"><i class="fas fa-paper-plane"></i>Soumettre la demande</button>'
+'</div>';
document.getElementById('app').appendChild(mo);
}
function _submitWithdraw(){
var amt=parseFloat(document.getElementById('wdAmt').value)||0;
var addr=(document.getElementById('wdAddr').value||'').trim();
var crypto=document.getElementById('wdCrypto').value;
if(amt<30){toast('Minimum $30','err');return;}
if(amt>S.realBal){toast('Solde insuffisant','err');return;}
if(!addr||addr.length<10){toast('Adresse invalide','err');return;}
S.realBal-=amt;
updBal();dbSave();authPersist();
var u=AUTH.user;
if(!u.wdRequests)u.wdRequests=[];
var req={id:Date.now(),amt:amt,crypto:crypto,addr:addr,status:'pending',date:new Date().toLocaleString('fr-FR')};
u.wdRequests.push(req);
authPersist();
_closeWithdrawMo();
toast('Demande de retrait soumise! Traitement sous 24h ✅','ok');
trackEvent('withdrawal_request',{amount:amt,crypto:crypto,user:u.accountNum});
}
document.addEventListener('click',function(e){
var ob=e.target.closest('.ob,.mob');
if(!ob)return;
var r=document.createElement('span');
var rect=ob.getBoundingClientRect();
var size=Math.max(rect.width,rect.height);
r.className='ob-ripple';
r.style.cssText='width:'+size+'px;height:'+size+'px;left:'+(e.clientX-rect.left-size/2)+'px;top:'+(e.clientY-rect.top-size/2)+'px';
ob.appendChild(r);
setTimeout(function(){if(r.parentNode)r.remove();},600);
},true);
function buildTicker(){
var items=[];
for(var sp in S.cache){
var ms=S.cache[sp]&&S.cache[sp].ms;
if(!ms)continue;
ms.filter(function(m){return m.status==='live';}).slice(0,6).forEach(function(m){
var o=m.odds||{};
items.push({home:m.home,away:m.away,hs:m.hs,as:m.as,min:m.min||'LIVE',h:o.h,a:o.a,d:o.d});
});
}
Object.values(S.vmatches||{}).filter(function(m){return m.status==='live';}).slice(0,4).forEach(function(m){
var o=m.odds||{};
items.push({home:m.home,away:m.away,hs:m.hs,as:m.as,min:m.min||'LIVE',h:o.h,a:o.a,d:o.d,virt:true});
});
if(!items.length){
items=[
{home:'Man City',away:'Arsenal',hs:1,as:0,min:"54'",h:1.45,d:4.20,a:6.50},
{home:'Real Madrid',away:'Barcelona',hs:0,as:0,min:"32'",h:2.10,d:3.30,a:3.50},
{home:'PSG',away:'Monaco',hs:2,as:1,min:"71'",h:1.22,d:5.80,a:9.00},
{home:'Bayern',away:'Dortmund',hs:3,as:0,min:"80'",h:1.05,d:12.0,a:28.0}
];
}
var html=items.concat(items).map(function(it){
return '<span class="tick-item">'
+'<span class="tick-live"><span class="ldot"></span>'+esc(it.min)+'</span>'
+'<span class="tick-teams">'+esc(it.home)+'<strong>'+it.hs+'-'+it.as+'</strong>'+esc(it.away)+'</span>'
+(it.h?'<span class="tick-odd">'+fo(it.h)+'</span>':'')
+'<span class="tick-sep">|</span></span>';
}).join('');
var t=document.getElementById('ticker');
if(t)t.innerHTML=html;
}
var _lastGoals={};
function checkGoals(){
var allMs=[];
for(var sp in S.cache){var ms=S.cache[sp]&&S.cache[sp].ms;if(ms)ms.forEach(function(m){allMs.push(m);});}
Object.values(S.vmatches||{}).forEach(function(m){allMs.push(m);});
Object.values(S.fmatches||{}).forEach(function(m){allMs.push(m);});
allMs.filter(function(m){return m.status==='live';}).forEach(function(m){
var key=m.id;
var tot=(m.hs||0)+(m.as||0);
if(_lastGoals[key]!==undefined&&tot>_lastGoals[key]){
var scorer=(m.hs>(_lastGoals[key+'h']||0))?m.home:m.away;
showGoalCelebration(scorer,m.hs,m.as);
}
_lastGoals[key]=tot;
_lastGoals[key+'h']=m.hs||0;
_lastGoals[key+'a']=m.as||0;
});
}
function showGoalCelebration(scorer,hs,as){
var card=document.querySelector('[data-mid]');
if(card)card.style.animation='goalFlash .8s var(--elf)';
document.querySelectorAll('.sc-n').forEach(function(el){el.classList.add('scored');setTimeout(function(){el.classList.remove('scored');},600);});
toast('⚽ BUT! '+esc(scorer)+' — '+hs+'-'+as,'ok');
var app=document.getElementById('app');
var colors=['#00E676','#FFB300','#FF1744','#2979FF','#BB86FC'];
for(var i=0;i<8;i++){
(function(idx){
setTimeout(function(){
var p=document.createElement('div');
p.className='confetti-piece';
p.style.cssText='left:'+(20+Math.random()*60)+'%;top:30%;background:'+colors[idx%colors.length]+';animation-delay:'+Math.random()*.3+'s;animation-duration:'+(0.9+Math.random()*.5)+'s;border-radius:'+(Math.random()>.5?'50%':'3px')+'';
app.appendChild(p);
setTimeout(function(){if(p.parentNode)p.remove();},2000);
},idx*60);
})(i);
}
}
var _prevOddsMap={};
function trackOddsChanges(){
var allMs=[];
for(var sp in S.cache){var ms=S.cache[sp]&&S.cache[sp].ms;if(ms)ms.forEach(function(m){allMs.push(m);});}
allMs.filter(function(m){return m.status==='live';}).forEach(function(m){
var o=m.odds;
if(!o)return;
var prev=_prevOddsMap[m.id];
if(prev){
[['1h',o.h,prev.h],['1x',o.d,prev.d],['1a',o.a,prev.a]].forEach(function(pair){
var t=pair[0],cur=pair[1],old=pair[2];
if(!cur||!old||Math.abs(cur-old)<0.04)return;
var btn=document.querySelector('.ob[data-mid="'+m.id+'"][data-t="'+t+'"]');
if(!btn)return;
var isUp=cur>old;
btn.classList.remove('up','dn');
void btn.offsetWidth;
btn.classList.add(isUp?'up':'dn');
var ov=btn.querySelector('.ov');
if(ov){ov.classList.remove('ov-anim');void ov.offsetWidth;ov.classList.add('ov-anim');}
var old2=btn.querySelector('.odds-change-badge');
if(old2)old2.remove();
var badge=document.createElement('span');
badge.className='odds-change-badge'+(isUp?'':' dn');
badge.textContent=(isUp?'▲':' ▼')+fo(cur);
btn.appendChild(badge);
setTimeout(function(){if(badge.parentNode)badge.remove();},2500);
});
}
_prevOddsMap[m.id]={h:o.h,d:o.d,a:o.a};
});
}
document.getElementById('promoBanner').addEventListener('click',function(){
if(!AUTH.user){openLoginModal('register');}
else{openDeposit();}
});
function updatePromoBanner(){
var banner=document.getElementById('promoBanner');
if(!banner)return;
if(AUTH.user&&(S.realBal>0||S.virtBal<VIRT_START)){
banner.style.display='none';
}else{
banner.style.display='flex';
}
}
var _lastBal=0;
function animateBal(){
var cur=getActiveBal();
if(cur !==_lastBal){
var el=document.querySelector('.bal-amt');
if(el){el.classList.remove('bump');void el.offsetWidth;el.classList.add('bump');}
_lastBal=cur;
}
}
setTimeout(buildTicker,800);
setInterval(buildTicker,15000);
setInterval(checkGoals,1000);
setInterval(trackOddsChanges,3000);
function resetApp(){showCfm('Réinitialiser tout?',function(){S.virtBal=VIRT_START;S.realBal=0;S.activeAcc='virt';S.hist=[];S.slip=[];S.stake=0;S.cache={};S.vmatches={};S.fmatches={};S.fifaSaison=null;dbClear();var ov=document.getElementById('brokeOv');if(ov)ov.remove();updBal();renderAll();fetchSport(S.sport);});}
function toggleSlip(){
S.slipOpen=!S.slipOpen;
document.getElementById('bov').classList.toggle('open',S.slipOpen);
document.getElementById('bsheet').classList.toggle('open',S.slipOpen);
if(S.slipOpen)renderAllSlips();
}
document.getElementById('bsheet').addEventListener('click',function(e){
e.stopPropagation();
});
function doRefresh(){var b=document.getElementById('refBtn');b.classList.add('spin');var cfg=SCFG[S.sport];if(cfg&&cfg.virtual){if(S.sport==='virtual'){Object.keys(S.vmatches).forEach(function(id){var m=S.vmatches[id];if(m.status!=='live'){m.status='upcoming';m.el=0;m.hs=0;m.as=0;m.goals=[];m.odds=calcOdds(m);}});syncV();}else{Object.keys(S.fmatches).forEach(function(id){var m=S.fmatches[id];if(m.status!=='live'){m.status='upcoming';m.el=0;m.hs=0;m.as=0;m.goals=[];m.odds=calcFifaOdds(m);}});syncF();}renderList();setTimeout(function(){b.classList.remove('spin');},800);}else{fetchSport(S.sport);setTimeout(function(){b.classList.remove('spin');},2000);}}
function toast(msg,type){var c=document.getElementById('tc');var t=document.createElement('div');t.className='tst '+(type||'inf');var ic=type==='ok'?'check-circle':type==='err'?'exclamation-circle':'info-circle';t.innerHTML='<i class="fas fa-'+ic+'"></i>'+esc(msg);c.appendChild(t);setTimeout(function(){t.style.opacity='0';t.style.transform='translateX(40px)';t.style.transition='.3s';},3200);setTimeout(function(){if(t.parentNode)t.remove();},3600);}
function showCfm(msg,fn){var o=document.createElement('div');o.className='cfm-ov';o.innerHTML='<div class="cfm-box"><p class="cfm-msg">'+esc(msg)+'</p><div class="cfm-acts"><button class="cfm-no">Annuler</button><button class="cfm-yes">OK</button></div></div>';document.getElementById('app').appendChild(o);o.querySelector('.cfm-no').addEventListener('click',function(){o.remove();});o.querySelector('.cfm-yes').addEventListener('click',function(){o.remove();fn();});}
document.addEventListener('click',function(e){
var t=e.target;
var ub=t.closest('#uBadge');if(ub){openProfile();return;}
var opn=t.closest('[data-openmkt]');if(opn){e.stopPropagation();openMkt(opn.dataset.openmkt);return;}
var flp=t.closest('[data-flpmid]');if(flp){e.stopPropagation();openFlp(flp.dataset.flpmid,null);return;}
var sp=t.closest('[data-sp]');if(sp&&!t.closest('[data-fifalgid]')){selSport(sp.dataset.sp);return;}
var tb=t.closest('[data-tab]');if(tb){selTab(tb.dataset.tab);return;}
var ob=t.closest('.ob[data-mid]');if(ob){e.stopPropagation();toggleBet(ob.dataset.mid,ob.dataset.t,ob.dataset.lbl,parseFloat(ob.dataset.odd));return;}
var dmb=t.closest('.mob[data-dmid]');if(dmb){toggleBet(dmb.dataset.dmid,dmb.dataset.dt,dmb.dataset.dlbl,parseFloat(dmb.dataset.dodd));return;}
var mc=t.closest('.mc[data-mid],.vc[data-mid],.fc[data-mid]');if(mc&&!t.closest('.ob,.mkt-btn')){openMkt(mc.dataset.mid);return;}
var mcat=t.closest('[data-mcat]');if(mcat){S.openMktCat=mcat.dataset.mcat;renderMktCats();var m=findM(S.openMktId);if(m)renderMktBody(m);return;}
if(t.closest('#mktMo')&&t===t.closest('#mktMo')){document.getElementById('mktMo').classList.remove('open');return;}
if(t.closest('#depMo')&&t===t.closest('#depMo')){document.getElementById('depMo').classList.remove('open');return;}
var rt=t.closest('[data-retry]');if(rt){fetchSport(rt.dataset.retry);return;}
var dp=t.closest('[data-dep]');if(dp){deposit(dp.dataset.dep);return;}
var co=t.closest('[data-cashout]');if(co){doCashout(co.dataset.cashout);return;}
var qs=t.closest('[data-qs]');if(qs){setStake(parseFloat(qs.dataset.qs));renderSlip();return;}
var qsf=t.closest('[data-qs-frac]');if(qsf){setStakeFrac(parseFloat(qsf.dataset.qsFrac));return;}
var bm=t.closest('[data-bm]');if(bm){setMode(bm.dataset.bm);return;}
var rm=t.closest('[data-rm]');if(rm){rmBet(parseInt(rm.dataset.rm));return;}
var crBtn=t.closest('.cr-sel-btn');if(crBtn){_selCrypto=crBtn.dataset.cr;renderCryptoDeposit();return;}
if(t.id==='copyAddrBtn'){_copyAddr();return;}
if(t.id==='depSubmitBtn'){_submitDepositReq();return;}
if(t.id==='wdSubmitBtn'){_submitWithdraw();return;}
if(t.closest('.pbtn')){placeBet();return;}
if(t.closest('.cbtn')){clearSlip();return;}
});
document.addEventListener('input',function(e){if(e.target&&e.target.matches&&e.target.matches('.stake-inp'))setStake(e.target.value);});
document.getElementById('flpClose').addEventListener('click',closeFlp);
document.getElementById('flpOv').addEventListener('click',closeFlp);
document.getElementById('flpPanel').addEventListener('click',function(e){e.stopPropagation();});
document.getElementById('logoBtn').addEventListener('click',resetApp);
document.getElementById('depBtn').addEventListener('click',openDeposit);
document.getElementById('refBtn').addEventListener('click',doRefresh);
document.getElementById('bfab').addEventListener('click',toggleSlip);
document.getElementById('bov').addEventListener('click',toggleSlip);
document.getElementById('moClose').addEventListener('click',function(){document.getElementById('mktMo').classList.remove('open');});
document.getElementById('depClose').addEventListener('click',function(){document.getElementById('depMo').classList.remove('open');});
var _sy=0,bs=document.getElementById('bsheet');
bs.addEventListener('touchstart',function(e){_sy=e.touches[0].clientY;});
bs.addEventListener('touchmove',function(e){var d=e.touches[0].clientY-_sy;if(d>0)bs.style.transform='translateY('+d+'px)';});
bs.addEventListener('touchend',function(e){if(e.changedTouches[0].clientY-_sy>70)toggleSlip();bs.style.transform='';});
function renderAll(){renderNav();renderSub();renderList();renderAllSlips();updBal();}
(function(){
var stored=getStoredUser();
if(stored){
AUTH.user=stored;
S.virtBal=typeof stored.virtBal==='number'?stored.virtBal:VIRT_START;
S.realBal=typeof stored.realBal==='number'?stored.realBal:0;
S.activeAcc=stored.activeAcc||'virt';
S.hist=Array.isArray(stored.hist)?stored.hist:[];
lsSet('bz_cur',stored.accountNum);
}
updateHeaderAuth();
renderAll();
checkBroke();
testProxies();
setTimeout(function(){fetchSport(S.sport);},100);
setTimeout(function(){initVirt();initFifa();},600);
})();
setInterval(function(){
if(SCFG[S.sport]&&!SCFG[S.sport].virtual&&!S.loading[S.sport]){
var c=S.cache[S.sport];
var hasLive=c&&c.ms&&c.ms.some(function(m){return m.status==='live';});
var ttl=hasLive?60000:5*60*1000;
if(!c||Date.now()-c.ts>ttl)fetchSport(S.sport,true);
}
},30000);
setInterval(function(){var c=S.cache[S.sport];if(c&&!SCFG[S.sport].virtual&&c.ms){c.ms.forEach(function(m){if(m.status==='live')m.odds=driftOdds(m.odds,m);});renderList();}},5000);
setInterval(function(){if(AUTH.user)authPersist();},30000);</script></body></html>
